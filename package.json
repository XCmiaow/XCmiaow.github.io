{
  "name": "resume-xujie-fang",
  "version": "2.0.0",
  "description": "Xujie Fang - Personal Academic Resume Website (Astro)",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/write-route.mjs disable && node scripts/generate-site-css.mjs && node scripts/generate-build-meta.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "qa": "node scripts/qa-check.mjs",
    "qa:style": "node scripts/style-source-audit.mjs",
    "qa:content": "node scripts/content-qa.mjs",
    "qa:pwa": "node scripts/pwa-qa.mjs",
    "qa:visual": "node scripts/visual-qa.mjs",
    "blog:new": "node scripts/write-blog-post.mjs",
    "write:enable": "node scripts/write-route.mjs enable",
    "write:disable": "node scripts/write-route.mjs disable",
    "check": "npm run build && npm run qa:style && npm run qa:content && npm run qa:pwa && npm run qa && npm run qa:visual",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{astro,ts,js,css,json}' README.md package.json",
    "format:check": "prettier --check 'src/**/*.{astro,ts,js,css,json}' README.md package.json",
    "prepare": "husky"
  },
  "dependencies": {
    "astro": "^6.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1"
  },
  "lint-staged": {
    "src/**/*.astro": [
      "eslint --fix"
    ],
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
