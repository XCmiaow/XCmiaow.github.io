---
import DocumentLayout from './DocumentLayout.astro';
import SiliconEmbersSiteFrame from '../components/silicon-embers/SiliconEmbersSiteFrame.astro';

interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
  icon?: 'mail' | 'github' | 'resume' | 'rss' | 'wecom' | 'wechat';
}

export interface Props {
  lang: 'zh' | 'en';
  title: string;
  description: string;
  canonicalPath: string;
  alternatePath?: string;
  footerLinks?: readonly FooterLink[];
}

const { lang, title, description, canonicalPath, alternatePath, footerLinks } = Astro.props;
---

<DocumentLayout
  lang={lang}
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
  themeColor="#050504"
  faviconPath="/silicon-ashes/logo.jpg"
  bodyClass="silicon-embers-document"
>
  <SiliconEmbersSiteFrame lang={lang} alternateHref={alternatePath} footerLinks={footerLinks}>
    <slot />
  </SiliconEmbersSiteFrame>
</DocumentLayout>
