---
export interface Props {
  title: string;
  description?: string;
  lang: 'zh' | 'en';
}

const { title, description = '', lang } = Astro.props;
const isZh = lang === 'zh';
const basePath = isZh ? '' : '/en';
const labels = isZh
  ? { about: '个人简介', education: '教育背景', honors: '获奖情况', skills: '技能专长', projects: '项目作品', modeling: '建模案例', evidence: '证书墙', contact: '联系我', onepage: '一页版', fullcv: '完整版' }
  : { about: 'About', education: 'Education', honors: 'Honors', skills: 'Skills', projects: 'Projects', modeling: 'Modeling', evidence: 'Evidence', contact: 'Contact', onepage: 'One-Page', fullcv: 'Full CV' };
const pathWithoutLocale = Astro.url.pathname
  .replace(/^\/en(?:\/|$)/, '/')
  .replace(/\/+$/, '');
const currentPage = pathWithoutLocale.replace(/^\/+/, '');
const pageKey = currentPage === '' || currentPage === 'index' ? '' : currentPage;
const zhUrl = (pageKey ? `/${pageKey}` : '/');
const enUrl = (pageKey ? `/en/${pageKey}` : '/en/');
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#102a43" />
  <link rel="stylesheet" href="/styles/site.css" />
  <link rel="manifest" href="/manifest.json" />
  <script>
    if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }
  </script>
</head>
<body>
  <div id="progress-bar"></div>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href={`${basePath}/`} aria-label={isZh ? '回到首页' : 'Home'}>
        <span class="brand-mark">{isZh ? 'FX' : 'XF'}</span>
        <span>{isZh ? '方绪杰' : 'Xujie Fang'}</span>
      </a>
      <nav class="nav-links" id="navLinks">
        <a href={`${basePath}/#about`}>{labels.about}</a>
        <a href={`${basePath}/#education`}>{labels.education}</a>
        <a href={`${basePath}/#honors`}>{labels.honors}</a>
        <a href={`${basePath}/#skills`}>{labels.skills}</a>
        <a href={`${basePath}/#projects`}>{labels.projects}</a>
        <a href={`${basePath}/modeling`}>{labels.modeling}</a>
        <a href={`${basePath}/evidence`}>{labels.evidence}</a>
        <a href={`${basePath}/#contact`}>{labels.contact}</a>
      </nav>
      <div class="nav-actions">
        <div class="lang-switch">
          <a href={zhUrl} data-lang="zh" class:list={[{ active: isZh }]}>中文</a>
          <span class="sep">|</span>
          <a href={enUrl} data-lang="en" class:list={[{ active: !isZh }]}>EN</a>
        </div>
        <button class="icon-btn" id="themeToggle" type="button" aria-label={isZh ? '切换暗色模式' : 'Toggle dark mode'}>🌓</button>
        <button class="icon-btn menu-btn" id="menuToggle" type="button" aria-expanded="false" aria-controls="navLinks" aria-label={isZh ? '打开导航菜单' : 'Open navigation menu'}>☰</button>
        <a class="btn" href={`${basePath}/resume-onepage`}>{labels.onepage}</a>
        <a class="btn" href={`${basePath}/modeling`}>{labels.modeling}</a>
        <a class="btn primary" href={`${basePath}/#contact`}>{labels.contact}</a>
      </div>
    </div>
  </header>

  <main><slot /></main>

  <footer>
    <div class="container">&copy; 2026 {isZh ? '方绪杰' : 'Xujie Fang'} · {isZh ? '个人学术简历网站' : 'Personal Academic Resume Website'}</div>
  </footer>

  <script>
    // Progress bar
    (function(){const b=document.getElementById('progress-bar');if(!b)return;let w=0,p;function step(){w+=(100-w)*0.08;b.style.width=w+'%';if(w>99){b.style.width='100%';clearInterval(p);setTimeout(function(){b.style.width='0'},400)}}
    p=setInterval(step,100);var loaded=false;window.addEventListener('load',function(){if(!loaded){loaded=true;clearInterval(p);b.style.width='100%';setTimeout(function(){b.style.width='0'},400)}})})()

    // Ripple
    document.addEventListener('click',function(e){var t=e.target.closest('.card,.btn,.tl-card,.skill-card li,.filter-btn,.cert-card');if(!t)return;var r=document.createElement('span'),b=t.getBoundingClientRect(),s=Math.max(b.width,b.height);r.style.cssText='position:absolute;width:'+s+'px;height:'+s+'px;left:'+(e.clientX-b.left-s/2)+'px;top:'+(e.clientY-b.top-s/2)+'px;border-radius:50%;background:rgba(201,162,39,0.15);animation:ripple-anim .6s ease-out forwards';var w=document.createElement('span');w.style.cssText='position:absolute;inset:0;overflow:hidden;pointer-events:none;border-radius:inherit;z-index:0';if(!t.style.position||t.style.position==='static')t.style.position='relative';w.appendChild(r);t.appendChild(w);setTimeout(function(){w.remove()},600)})

    // Theme
    var toggle=document.getElementById('themeToggle'),root=document.documentElement;
    if(localStorage.getItem('resume-theme')==='dark')root.setAttribute('data-theme','dark');
    toggle&&toggle.addEventListener('click',function(){var d=root.getAttribute('data-theme')==='dark';root.setAttribute('data-theme',d?null:'dark');localStorage.setItem('resume-theme',d?'light':'dark')})

    // Language switch with anchor preservation
    document.querySelectorAll('.lang-switch a').forEach(function(el){el.addEventListener('click',function(){var h=window.location.hash;if(h&&h.length>1){var parts=el.href.split('#');el.href=parts[0]+h}localStorage.setItem('resume-lang',el.dataset.lang)})})

    // Mobile navigation
    var menu=document.getElementById('menuToggle'),nav=document.getElementById('navLinks');
    menu&&nav&&menu.addEventListener('click',function(){
      var open=nav.classList.toggle('open');
      menu.setAttribute('aria-expanded',open?'true':'false');
    });
    nav&&nav.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){
      nav.classList.remove('open');
      menu&&menu.setAttribute('aria-expanded','false');
    })});
  </script>
</body>
</html>

<style>
  .site-header{position:sticky;top:0;z-index:20;background:rgba(247,245,239,0.82);border-bottom:1px solid rgba(226,231,238,0.85);backdrop-filter:blur(18px)}
  [data-theme="dark"] .site-header{background:rgba(15,23,32,0.84);border-bottom-color:rgba(42,58,75,0.9)}
  .nav{display:flex;align-items:center;justify-content:space-between;min-height:70px;gap:24px}
  .brand{display:flex;align-items:center;gap:12px;font-weight:800;color:var(--primary);white-space:nowrap}
  .brand-mark{display:grid;width:38px;height:38px;place-items:center;border:1px solid rgba(201,162,39,0.42);border-radius:var(--radius);background:linear-gradient(145deg,var(--primary),var(--secondary));color:#fff;font-size:15px}
  .nav-links{display:flex;align-items:center;gap:18px;color:var(--muted);font-size:14px;font-weight:650}
  .nav-links a:hover{color:var(--primary)}
  .nav-actions{display:flex;align-items:center;gap:10px}
  .icon-btn{display:inline-grid;width:40px;height:40px;place-items:center;border:1px solid var(--line);border-radius:var(--radius);background:var(--paper);color:var(--primary);cursor:pointer}
  .menu-btn{display:none}
  .lang-switch{display:flex;align-items:center;gap:4px;font-size:13px;font-weight:700}
  .lang-switch a{padding:3px 6px;border-radius:4px;color:var(--muted)}
  .lang-switch a:hover{color:var(--primary)}
  .lang-switch a.active{color:var(--primary);background:var(--accent-soft)}
  .lang-switch .sep{color:var(--line)}
  #progress-bar{position:fixed;top:0;left:0;height:3px;z-index:9998;background:linear-gradient(90deg,var(--accent,#c9a227),var(--green,#2f6f5e));width:0;transition:width 0.3s ease}
  @keyframes ripple-anim{to{transform:scale(2);opacity:0}}

  @media (max-width: 980px){
    .nav{position:relative;gap:12px;min-height:64px}
    .nav-links{display:none;position:absolute;top:100%;left:14px;right:14px;align-items:stretch;flex-direction:column;gap:2px;padding:10px;border:1px solid var(--line);border-radius:var(--radius);background:var(--paper);box-shadow:var(--shadow)}
    .nav-links.open{display:flex}
    .nav-links a{padding:10px 12px;border-radius:6px}
    .nav-links a:hover{background:var(--accent-soft)}
    .menu-btn{display:inline-grid}
    .nav-actions>.btn{display:none}
  }

  @media (max-width: 460px){
    .nav{gap:8px}
    .brand{gap:8px}
    .brand-mark{width:36px;height:36px}
    .nav-actions{gap:6px}
    .icon-btn{width:38px;height:38px}
  }
</style>
