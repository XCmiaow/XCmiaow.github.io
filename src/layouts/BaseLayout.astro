---
import ClientBehaviors from '../components/ClientBehaviors.astro';
import Molecule3D from '../components/Molecule3D.astro';
import i18n from '../data/i18n.json';

export interface Props {
  title: string;
  description?: string;
  lang: 'zh' | 'en';
  alternateZhUrl?: string;
  alternateEnUrl?: string;
}

const { title, description = '', lang, alternateZhUrl, alternateEnUrl } = Astro.props;
const isZh = lang === 'zh';
const basePath = isZh ? '' : '/en';
const labels = i18n.nav[lang];
const buildDate = new Date().toLocaleDateString(isZh ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pathWithoutLocale = Astro.url.pathname.replace(/^\/en(?:\/|$)/, '/').replace(/\/+$/, '');
const currentPage = pathWithoutLocale.replace(/^\/+/, '');
const pageKey = currentPage === '' || currentPage === 'index' ? '' : currentPage;
const zhUrl = alternateZhUrl ?? (pageKey ? `/${pageKey}` : '/');
const enUrl = alternateEnUrl ?? (pageKey ? `/en/${pageKey}` : '/en/');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#102a43" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://XCmiaow.github.io/assets/avatar.jpg" />
    <meta property="og:url" content={`https://XCmiaow.github.io${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="a4ca01a5-020c-41c7-946c-7bd2a29fa5b3"
    ></script>
    <link rel="stylesheet" href="/styles/site.css" />
    <link rel="manifest" href="/manifest.json" />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>
  <body>
    <div class="skeleton-screen" id="skeleton">
      <div class="sk-header"><div class="sk-line w-20"></div><div class="sk-line w-10"></div></div>
      <div class="sk-hero">
        <div class="sk-circle"></div><div class="sk-block">
          <div class="sk-line w-60"></div><div class="sk-line w-80"></div><div class="sk-line w-40"></div>
        </div>
      </div>
    </div>
    <script>
      !(function () {
        var s = document.getElementById('skeleton');
        function hide() {
          if (!s) return;
          s.style.opacity = '0';
          setTimeout(function () {
            s && s.remove();
          }, 300);
        }
        window.addEventListener('load', hide);
        setTimeout(hide, 3000);
      })();
    </script>

    <a href="#main" class="skip-link">{isZh ? '跳到主要内容' : 'Skip to content'}</a>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href={`${basePath}/`} aria-label={isZh ? '回到首页' : 'Home'}>
          <span class="brand-mark">{isZh ? 'FX' : 'XF'}</span>
          <span>{isZh ? '方绪杰' : 'Xujie Fang'}</span>
        </a>
        <nav class="nav-links" id="navLinks">
          <a href={`${basePath}/#about`}>{labels.about}</a>
          <a href={`${basePath}/#education`}>{labels.education}</a>
          <a href={`${basePath}/#honors`}>{labels.honors}</a>
          <a href={`${basePath}/#skills`}>{labels.skills}</a>
          <a href={`${basePath}/#projects`}>{labels.projects}</a>
          <a href={`${basePath}/modeling`}>{labels.modeling}</a>
          <a href={`${basePath}/evidence`}>{labels.evidence}</a>
          <a href={`${basePath}/blog`}>{labels.blog}</a>
          <a href={`${basePath}/#contact`}>{labels.contact}</a>
        </nav>
        <div class="nav-actions">
          <div class="lang-switch">
            <a href={zhUrl} data-lang="zh" class:list={[{ active: isZh }]}>中文</a>
            <span class="sep">|</span>
            <a href={enUrl} data-lang="en" class:list={[{ active: !isZh }]}>EN</a>
          </div>
          <button
            class="icon-btn"
            id="layoutToggle"
            type="button"
            aria-label={isZh ? '切换极简模式' : 'Toggle minimal mode'}
            title={isZh ? '极简模式' : 'Minimal'}>⬜</button
          >
          <button
            class="icon-btn"
            id="themeToggle"
            type="button"
            aria-label={isZh ? '切换暗色模式' : 'Toggle dark mode'}>🌓</button
          >
          <button
            class="icon-btn menu-btn"
            id="menuToggle"
            type="button"
            aria-expanded="false"
            aria-controls="navLinks"
            aria-label={isZh ? '打开导航菜单' : 'Open navigation menu'}>☰</button
          >
          <a class="btn" href={`${basePath}/resume-onepage`}>{labels.onepage}</a>
          <a class="btn" href={`${basePath}/modeling`}>{labels.modeling}</a>
          <a class="btn primary" href={`${basePath}/#contact`}>{labels.contact}</a>
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1"><slot /></main>

    <Molecule3D />
    <ClientBehaviors />
    <footer role="contentinfo">
      <div class="container">
        &copy; 2026 {isZh ? '方绪杰' : 'Xujie Fang'} · {i18n.footer[lang]} · {isZh ? '更新于' : 'Updated'}
        {buildDate} · <a href="/write/" class="footer-admin">{isZh ? '写文章' : 'Write'}</a> · <a
          href="/admin/"
          class="footer-admin">{isZh ? '管理' : 'Admin'}</a
        >
      </div>
    </footer>

    <script>
      (function () {
        var b = document.getElementById('layoutToggle'),
          r = document.documentElement;
        if (!b) return;
        if (localStorage.getItem('resume-layout') === 'minimal') r.classList.add('minimal-mode');
        b.onclick = function () {
          r.classList.toggle('minimal-mode');
          localStorage.setItem('resume-layout', r.classList.contains('minimal-mode') ? 'minimal' : 'academic');
        };
      })();
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(247, 245, 239, 0.82);
    border-bottom: 1px solid rgba(226, 231, 238, 0.85);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }
  [data-theme='dark'] .site-header {
    background: rgba(15, 23, 32, 0.84);
    border-bottom-color: rgba(42, 58, 75, 0.9);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 70px;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 800;
    color: var(--primary);
    white-space: nowrap;
  }
  .brand-mark {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid rgba(201, 162, 39, 0.42);
    border-radius: var(--radius);
    background: linear-gradient(145deg, var(--primary), var(--secondary));
    color: #fff;
    font-size: 15px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 18px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 650;
  }
  .nav-links a:hover {
    color: var(--primary);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .icon-btn {
    display: inline-grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--primary);
    cursor: pointer;
  }
  .menu-btn {
    display: none;
  }
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 700;
  }
  .lang-switch a {
    padding: 3px 6px;
    border-radius: 4px;
    color: var(--muted);
  }
  .lang-switch a:hover {
    color: var(--primary);
  }
  .lang-switch a.active {
    color: var(--primary);
    background: var(--accent-soft);
  }
  .lang-switch .sep {
    color: var(--line);
  }
  #progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    z-index: 9998;
    background: linear-gradient(90deg, var(--accent, #c9a227), var(--green, #2f6f5e));
    width: 0;
    transition: width 0.3s ease;
  }
  @keyframes ripple-anim {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  @media (max-width: 980px) {
    .nav {
      position: relative;
      gap: 12px;
      min-height: 64px;
    }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 14px;
      right: 14px;
      align-items: stretch;
      flex-direction: column;
      gap: 2px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--paper);
      box-shadow: var(--shadow);
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a {
      padding: 10px 12px;
      border-radius: 6px;
    }
    .nav-links a:hover {
      background: var(--accent-soft);
    }
    .menu-btn {
      display: inline-grid;
    }
    .nav-actions > .btn {
      display: none;
    }
  }

  .skip-link {
    position: fixed;
    top: -100%;
    left: 8px;
    z-index: 10000;
    padding: 8px 16px;
    background: var(--primary);
    color: #fff;
    border-radius: 0 0 var(--radius) var(--radius);
    font-size: 14px;
    font-weight: 700;
  }
  .skeleton-screen {
    position: fixed;
    inset: 0;
    z-index: 9997;
    background: var(--bg);
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .skeleton-screen .sk-header {
    display: flex;
    gap: 16px;
    padding: 20px;
    max-width: var(--max);
    margin: 0 auto;
  }
  .skeleton-screen .sk-hero {
    display: flex;
    gap: 24px;
    padding: 60px 20px;
    max-width: var(--max);
    margin: 0 auto;
    align-items: center;
  }
  .skeleton-screen .sk-circle {
    width: 138px;
    height: 138px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .skeleton-screen .sk-block {
    flex: 1;
    display: grid;
    gap: 16px;
  }
  .skeleton-screen .sk-line {
    height: 16px;
    border-radius: 8px;
  }
  .skeleton-screen .sk-line.w-60 {
    width: 60%;
  }
  .skeleton-screen .sk-line.w-80 {
    width: 80%;
  }
  .skeleton-screen .sk-line.w-40 {
    width: 40%;
  }
  .skeleton-screen .sk-line.w-20 {
    width: 200px;
  }
  .skeleton-screen .sk-line.w-10 {
    width: 80px;
  }
  .skeleton-screen .sk-header .sk-line,
  .skeleton-screen .sk-line,
  .skeleton-screen .sk-circle {
    background: linear-gradient(90deg, var(--line) 25%, transparent 50%, var(--line) 75%);
    background-size: 200% 100%;
    animation: skeleton 1.5s ease-in-out infinite;
  }
  .footer-admin {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s;
  }
  .footer-admin:hover {
    text-decoration-color: var(--accent);
  }
  .skip-link:focus {
    top: 0;
  }
  @media (max-width: 460px) {
    .nav {
      gap: 8px;
    }
    .brand {
      gap: 8px;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
    }
    .nav-actions {
      gap: 6px;
    }
    .icon-btn {
      width: 38px;
      height: 38px;
    }
  }
</style>
