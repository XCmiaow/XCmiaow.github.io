---
import BaseLayout from '../layouts/BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';
import PageTrail from '../components/PageTrail.astro';

const certs = [
  'national-inspirational-scholarship-2025.jpg',
  'cumcm-2024-jiangsu-first.jpg',
  'mcm-2025-honorable-mention.jpg',
  'mcm-2026-honorable-mention.jpg',
  'mathorcup-2025-second.png',
  'math-competition-2025-third.jpg',
  'three-good-student-2025.png',
  'chemistry-olympiad-2023.jpg',
  'chemistry-olympiad-2022.jpg',
  'debate-second-2024.jpg',
  'card-house-volunteer-2024.jpg',
  'volleyball-freshman-2024-second.jpg',
  'volleyball-college-2026-fourth.jpg',
  'high-jump-2025-fourth.jpg',
];
const imgBase = '/assets/evidence/public/';
const imgUrls = certs.map((f) => imgBase + f);
---

<BaseLayout title="方绪杰 | 证书墙" lang="zh">
  <section class="hero">
    <div class="container">
      <h1>证明材料墙</h1>
      <p class="lead">集中展示竞赛、荣誉、学生工作相关证书。点击查看大图，键盘左右键切换。</p>
    </div>
  </section>

  <PageTrail
    eyebrow="证据路径"
    title="证书不是终点，要能回到简历叙事"
    description="证据墙用于核验材料真实性，回到首页荣誉区可看结构化奖项，打开一页简历可用于投递。"
    links={[
      { href: '/#honors', label: '回到荣誉区', note: '按级别查看完整奖项链路' },
      { href: '/modeling', label: '查看建模能力', note: '理解竞赛奖项背后的能力形成', primary: true },
      { href: '/resume-onepage', label: '打开一页简历', note: '把证据转化为可投递材料' },
    ]}
  />

  <div class="container" style="margin-bottom:60px">
    <div class="grid-3">
      {
        certs.map((f, i) => (
          <a class="cert-card" href={imgBase + f} target="_blank">
            <img src={imgBase + f} alt={f} loading="lazy" />
          </a>
        ))
      }
    </div>
  </div>

  <Lightbox images={imgUrls} />
</BaseLayout>

<style>
  .hero {
    padding: 80px 0 30px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 54px);
    color: var(--primary);
  }
  .lead {
    max-width: 600px;
    margin-top: 12px;
    color: var(--muted);
  }
  .cert-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    cursor: pointer;
  }
  .cert-card img {
    width: 100%;
    height: 240px;
    object-fit: contain;
    background: #f5f5f5;
  }
  .cert-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }
</style>
