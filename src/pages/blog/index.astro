---
import CompatibilityEntry from '../../components/silicon-embers/CompatibilityEntry.astro';
import SiliconEmbersLayout from '../../layouts/SiliconEmbersLayout.astro';
import { alternatePath, routePath } from '../../lib/siteRoutes';

const lang = 'zh' as const;
const canonicalPath = routePath('writing', lang);
---

<SiliconEmbersLayout
  lang={lang}
  title="博客已迁移 | 硅基余烬"
  description="旧博客索引的兼容入口。"
  canonicalPath={canonicalPath}
  alternatePath={alternatePath('writing', lang)}
>
  <CompatibilityEntry
    title="博客已并入硅基余烬"
    message="旧地址不再维护独立内容；文章索引统一位于规范博客地址。"
    href={canonicalPath}
    action="进入博客索引"
  />
</SiliconEmbersLayout>
