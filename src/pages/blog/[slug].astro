---
import { getCollection, type CollectionEntry } from 'astro:content';
import CompatibilityEntry from '../../components/silicon-embers/CompatibilityEntry.astro';
import { siliconEmbersArticleAlternates } from '../../data/siliconEmbersHome';
import SiliconEmbersLayout from '../../layouts/SiliconEmbersLayout.astro';
import { routePath } from '../../lib/siteRoutes';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props as { post: BlogPost };
const canonicalPath = routePath('writing-entry', 'zh').replace(':slug', post.id);
const alternateId = siliconEmbersArticleAlternates[post.id];
const englishIds = new Set(
  (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft)).map((entry) => entry.id),
);
const alternatePath =
  alternateId && englishIds.has(alternateId)
    ? routePath('writing-entry', 'en').replace(':slug', alternateId)
    : undefined;
---

<SiliconEmbersLayout
  lang="zh"
  title={`${post.data.title} | 兼容入口`}
  description={post.data.description ?? post.data.title}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
>
  <CompatibilityEntry
    title={post.data.title}
    message="这篇文章已迁移到硅基余烬的规范博客地址。"
    href={canonicalPath}
    action="阅读规范版本"
  />
</SiliconEmbersLayout>
