---
import PrintLayout from '../layouts/PrintLayout.astro';
import common from '../data/common.json';

const gpa = common.education.gpa.toFixed(2);
const github = common.person.github;
const email = common.person.email;
---

<PrintLayout title="方绪杰 · 一页简历" lang="zh" variant="general">
  <header class="top">
    <div class="top-main">
      <h1>方绪杰</h1>
      <p class="sub">南京林业大学 · 化学工程学院 · 林产化工专业 · 本科大二</p>
      <p class="tagline">定位：化工专业基础 + 数学建模能力 + AI / 编程工具链实践</p>
    </div>
    <div class="top-contact">
      <span>Email: {email}</span>
      <span>GitHub: {github}</span>
      <span>Location: Nanjing, China</span>
    </div>
  </header>

  <div class="metric-strip" aria-label="核心指标">
    <div class="metric"><strong>{gpa}</strong><span>GPA</span></div>
    <div class="metric"><strong>第 1</strong><span>班级排名</span></div>
    <div class="metric"><strong>第 2</strong><span>专业排名</span></div>
    <div class="metric"><strong>2 次</strong><span>MCM/ICM H 奖</span></div>
  </div>

  <p class="summary">
    林产化工专业本科生，学习成绩位居前列，GPA <strong>{gpa}</strong>，班级第 <strong>1</strong>，专业第
    <strong>2</strong>。曾获国家励志奖学金、校三好学生、大学生学科竞赛先进个人。核心能力集中在数学建模、Python
    数据分析、LaTeX 论文表达、有机化学机理学习和 AI 辅助科研工作流建设。
  </p>

  <div class="row-2">
    <section>
      <h2>教育背景</h2>
      <div class="item">
        <div class="item-head"><strong>南京林业大学 · 化学工程学院</strong><span>2024.09 - 至今</span></div>
        <p>林产化工专业 · 本科在读 · 当前年级：大二</p>
        <p class="keyword-line">GPA {gpa} · 班级第 1 · 专业第 2</p>
      </div>
    </section>
    <section>
      <h2>投递定位</h2>
      <p class="small"><strong>保研 / 评优：</strong>成绩排名、国家级奖学金、省级建模奖项与学生工作经历完整。</p>
      <p class="small"><strong>实习 / 项目：</strong>能完成问题抽象、数据处理、论文表达和静态网站工程化落地。</p>
    </section>
  </div>

  <section>
    <h2>核心荣誉</h2>
    <div class="row-2 tight">
      <ul class="compact-list">
        <li>2025、2026 年美国大学生数学建模竞赛 MCM/ICM Honorable Mention</li>
        <li>2024-2025 学年国家励志奖学金</li>
        <li>2024 年全国大学生数学建模竞赛江苏省一等奖</li>
      </ul>
      <ul class="compact-list">
        <li>第二十二届江苏省高等数学竞赛本科一级 A 类三等奖</li>
        <li>MathorCup 高校数学建模挑战赛区域赛二等奖</li>
        <li>校三好学生、大学生学科竞赛先进个人</li>
      </ul>
    </div>
  </section>

  <section>
    <h2>项目与竞赛实践</h2>
    <div class="item">
      <div class="item-head"><strong>数学建模竞赛实践</strong><span>Python · 数据分析 · 论文写作</span></div>
      <p class="small">
        参与 CUMCM、MCM/ICM、MathorCup
        等竞赛，完成问题拆解、变量筛选、模型假设、数据处理、算法求解、结果分析和论文撰写。
        训练形成从开放问题到可解释结论的完整建模流程意识。
      </p>
    </div>
    <div class="item">
      <div class="item-head">
        <strong>个人学术简历网站</strong><span>Astro · Responsive Design · GitHub Pages</span>
      </div>
      <p class="small">
        基于 Astro 构建中英文个人学术主页，包含首页、证据墙、建模页、ChemAI
        Lab、一页简历和博客模块；配置构建、格式化、Lint、静态 QA 检查，形成可长期维护的个人材料中心。
      </p>
    </div>
    <div class="item">
      <div class="item-head">
        <strong>ChemAI Lab</strong><span>Python · PyTorch · RDKit · Computational Chemistry</span>
      </div>
      <p class="small">
        面向 AI
        辅助化学研究的学习型项目，关注分子特征、机器学习建模、量子化学接口和可解释性分析，为后续计算化学方向探索积累工程基础。
      </p>
    </div>
  </section>

  <div class="row-2">
    <section>
      <h2>技能专长</h2>
      <p class="small"><strong>专业基础：</strong>有机化学机理、Clayden、March、有机合成切断法、林产化工基础。</p>
      <p class="small"><strong>建模表达：</strong>数学建模、Python、Markdown、LaTeX、Origin、论文结构化表达。</p>
      <p class="small">
        <strong>开发工具：</strong>HTML、CSS、JavaScript、React、Astro、VS Code、Codex、Zotero、Obsidian。
      </p>
    </section>
    <section>
      <h2>学生工作与志愿服务</h2>
      <ul class="tiny">
        <li>班级学习委员（2024.09 - 2025.06）：负责作业收发、学习事务协调和教学配合。</li>
        <li>教学信息员（2024.09 - 2025.06）：负责教学信息传达、课程反馈收集与师生沟通。</li>
        <li>白马校区第一届排球新生杯第一组织责任人；参与“纸牌搭屋”志愿服务和无偿献血活动。</li>
      </ul>
    </section>
  </div>
</PrintLayout>
