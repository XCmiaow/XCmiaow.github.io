---
import PrintLayout from '../layouts/PrintLayout.astro';
import zh from '../data/zh.json';

const p = zh.person;
const edu = zh.education;
const awards = {
  international: zh.competitions.filter((c) => c.level === 'international'),
  national: zh.competitions.filter((c) => c.level === 'national'),
  provincial: zh.competitions.filter((c) => c.level === 'provincial'),
};
const allAwards = [...awards.international, ...awards.national, ...awards.provincial];
---

<PrintLayout title="方绪杰 · 一页简历" lang="zh">
  <header class="top">
    <div class="top-main">
      <h1>{p.name}</h1>
      <p class="sub">{edu.school} · {edu.college} · {edu.major} · {edu.degree}</p>
    </div>
    <div class="top-contact">
      <span>📧 2332797170@njfu.edu.cn</span>
      <span>🐙 github.com/XCmiaow</span>
      <span>📍 {edu.school}</span>
    </div>
  </header>

  <p class="summary">
    {p.name}，{edu.major}{edu.degree}，GPA <strong>3.60</strong>（<strong>班级第1</strong>、<strong>专业第2</strong
    >）。获国家励志奖学金、校三好学生。数学建模核心奖项：全国大学生数学建模竞赛<strong>江苏省一等奖</strong>，连续两年
    MCM/ICM <strong>H 奖</strong>。课外持续阅读 Clayden、March 等有机化学经典教材，自学 Python
    建模与深度学习基础，关注计算化学与 AI 辅助有机合成方向。
  </p>

  <div class="row-2">
    <section>
      <h2>教育背景</h2>
      <div class="item">
        <div class="item-head"><strong>{edu.school} · {edu.college}</strong><span>{edu.period}</span></div>
        <p>{edu.major} · {edu.degree} · {edu.year}</p>
        <p>GPA：<strong>3.60</strong> · 班级排名：第 1 · 专业排名：第 2</p>
      </div>
    </section>
    <section>
      <h2>研究兴趣</h2>
      <p class="small">{zh.researchInterests.summary.substring(0, 120)}…</p>
      <p class="small" style="margin-top:4px">
        {
          zh.researchInterests.areas
            .slice(0, 2)
            .map((a) => a.name)
            .join(' · ')
        }
      </p>
    </section>
  </div>

  <!-- HONORS — Full table -->
  <section>
    <h2>获奖与荣誉</h2>
    <table class="honors-table">
      {
        allAwards.map((a) => (
          <tr>
            <>
              <td class="yr">{a.year}</td>
              <td class="lvl">{a.level === 'international' ? '国际' : a.level === 'national' ? '国家' : '省级'}</td>
              <td>{a.title}</td>
            </>
          </tr>
        ))
      }
    </table>
  </section>

  <!-- PROJECTS -->
  <section>
    <h2>项目与实践</h2>
    {
      zh.projects
        .filter((pr) => pr.id !== 'ai-km')
        .map((pr) => (
          <div class="item">
            <div class="item-head">
              <strong>{pr.title}</strong>
            </div>
            <p class="small">{pr.desc}</p>
            <p class="small" style="color:var(--secondary)">
              <strong>能力：</strong>
              {pr.abilities}
            </p>
          </div>
        ))
    }
  </section>

  <div class="row-2">
    <section>
      <h2>技能专长</h2>
      {
        zh.skills.map((s) => (
          <p class="small">
            <strong>{s.category}：</strong>
            {s.items.join('、')}
          </p>
        ))
      }
    </section>
    <section>
      <h2>学生工作与服务</h2>
      <ul class="tiny">
        {
          zh.experience.map((e) => (
            <li>
              <b>{e.title}</b>（{e.period}）{e.desc}
            </li>
          ))
        }
        {zh.volunteer.map((v) => <li>{v}</li>)}
      </ul>
    </section>
  </div>
</PrintLayout>
