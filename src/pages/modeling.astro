---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import Card from '../components/Card.astro';
import PageTrail from '../components/PageTrail.astro';
---

<BaseLayout title="方绪杰 | 数学建模竞赛实践" lang="zh">
  <section class="hero">
    <div class="container">
      <h1>数学建模竞赛实践</h1>
      <p class="lead">把竞赛奖项转化为可解释的能力证据：问题抽象、模型构建、数据处理、算法求解、结果分析与论文表达。</p>
      <div class="tag-row">
        <span class="tag">CUMCM 江苏省一等奖</span>
        <span class="tag">MCM/ICM H 奖 x2</span>
        <span class="tag">MathorCup 区域二等奖</span>
      </div>
    </div>
  </section>

  <PageTrail
    eyebrow="材料路径"
    title="从建模能力跳转到证据与投递简历"
    description="这页负责解释能力形成过程，下一步可以直接查看证书证据、项目作品或一页投递简历。"
    links={[
      { href: '/#projects', label: '回到项目区', note: '查看建模、网站与 ChemAI Lab 的并列证据' },
      { href: '/evidence', label: '查看证据墙', note: '核对证书、奖项与活动材料', primary: true },
      { href: '/resume-onepage', label: '打开一页简历', note: '用于打印、PDF 和正式投递' },
    ]}
  />

  <section>
    <div class="container">
      <SectionHead title="能力定位" />
      <div class="grid-3">
        <article class="card pad">
          <h3>对保研 / 评优</h3>
          <p>证明数学基础、科研表达、英文论文写作、跨学科建模和团队协作能力，是 GPA 之外最强的能力补充。</p>
        </article>
        <article class="card pad">
          <h3>对求职 / 作品集</h3>
          <p>证明可以把开放问题拆成变量、假设、模型、代码和结论，适合数据分析和技术学习型岗位。</p>
        </article>
        <article class="card pad">
          <h3>逻辑与表达</h3>
          <p>从问题中抽象变量、建立假设、选择模型、验证结果，并用严谨的学术语言表达建模过程。</p>
        </article>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead title="建模流程" />
      <div class="flow">
        <div class="step"><b>01</b>问题理解</div>
        <div class="step"><b>02</b>模型假设</div>
        <div class="step"><b>03</b>数据处理</div>
        <div class="step"><b>04</b>算法求解</div>
        <div class="step"><b>05</b>结果分析</div>
        <div class="step"><b>06</b>论文表达</div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead title="个人职责" />
      <div class="grid-2">
        <Card pad>
          <h3>可确认能力</h3>
          <ul class="evidence-list">
            <li>参与问题抽象、模型构建、数据分析与论文表达。</li>
            <li>熟悉 Python、LaTeX、Markdown、Origin 等工具。</li>
            <li>具备跨学科资料检索、团队协作和限时交付意识。</li>
          </ul>
        </Card>
        <Card pad>
          <h3>拓展方向</h3>
          <ul class="evidence-list">
            <li>每场竞赛中负责的模块：建模、编程、论文撰写与可视化。</li>
            <li>应用过的模型包括回归分析、优化算法与数值模拟。</li>
            <li>具备将复杂问题拆解为可计算框架的系统思维。</li>
          </ul>
        </Card>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 80px 0 40px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    color: var(--primary);
  }
  .lead {
    max-width: 640px;
    margin-top: 16px;
    color: var(--muted);
    font-size: 17px;
  }
  .flow {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
  }
  .step {
    text-align: center;
    padding: 20px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .step b {
    display: block;
    color: var(--accent);
    font-size: 22px;
    margin-bottom: 6px;
  }
  @media (max-width: 640px) {
    .flow {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
