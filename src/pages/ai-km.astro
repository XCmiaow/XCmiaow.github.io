---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTrail from '../components/PageTrail.astro';
import SectionHead from '../components/SectionHead.astro';
import claimsData from '../data/claims.json';

const claims = claimsData.items;
const workflow = [
  ['01', '文献收集', '用数据库、导师建议和 AI 检索提示形成初始阅读池，再用 Zotero 保留来源信息。'],
  ['02', '阅读标注', '把摘要、核心图表、方法细节和疑问拆开记录，避免只保存 PDF 而没有可复用理解。'],
  ['03', '知识组织', '用 Obsidian 把课程概念、文献笔记、术语卡片和研究问题连接成可回访的网络。'],
  ['04', '表达输出', '用 Markdown 与 LaTeX 把笔记转成周复盘、研究设想、汇报提纲和项目说明。'],
];
const tools = [
  ['AI 工具', '生成检索式、拆解论文结构、辅助英文表达，但不替代原文阅读和事实核对。'],
  ['Zotero', '管理题录、PDF、标签和引用信息，让材料来源可追溯。'],
  ['Obsidian', '沉淀概念卡片、文献笔记和主题地图，形成长期知识库。'],
  ['Markdown / LaTeX', '把阅读结果转成清晰、可版本管理的科研表达草稿。'],
];
const outputs = ['文献阅读模板', '主题地图', '周复盘记录', '研究问题清单', '汇报提纲', '中英文表达草稿'];
const statusLabels: Record<string, string> = {
  'evidence-backed': '证据支撑',
  'case-backed': '案例支撑',
  'narrative-only': '叙事边界',
};
const routeLabels: Record<string, string> = {
  '/': '主页',
  '/en/': '英文主页',
  '/modeling': '数学建模',
  '/en/modeling': '英文建模页',
  '/chem-ai-lab': 'ChemAI Lab',
  '/en/chem-ai-lab': '英文 ChemAI Lab',
  '/evidence': '证据墙',
  '/en/evidence': '英文证据墙',
  '/materials': '材料中心',
  '/en/materials': '英文材料中心',
  '/resume-academic': '保研评优简历',
  '/en/resume-academic': '英文保研评优简历',
};
---

<BaseLayout
  title="AI 辅助科研学习与知识管理 | 方绪杰"
  description="方绪杰的 AI-KM 工作流案例，说明如何用 AI 工具、Zotero、Obsidian、Markdown 与 LaTeX 支撑文献阅读、知识整理和科研表达。"
  lang="zh"
>
  <section class="km-hero">
    <div class="container">
      <span class="eyebrow">AI-KM Workflow</span>
      <h1>AI 辅助科研学习与知识管理</h1>
      <p class="lead">
        这个页面把“会用 AI 工具”拆成可解释的学习工作流：如何收集文献、阅读标注、组织知识，再把笔记转成研究表达。
      </p>
      <div class="tag-row">
        <span class="tag">AI Workflow</span>
        <span class="tag">Zotero</span>
        <span class="tag">Obsidian</span>
      </div>
    </div>
  </section>

  <PageTrail
    eyebrow="项目路径"
    title="把 AI-KM 放回可信材料体系"
    description="这一页不公开私人知识库，而是说明工作流边界。你可以回到项目区、材料中心，或直接查看下方能力证据矩阵。"
    links={[
      { href: '/#projects', label: '回到项目区', note: '和建模、ChemAI Lab、简历网站并列查看' },
      { href: '/materials', label: '材料中心', note: '按使用场景选择公开材料' },
      { href: '#claim-matrix', label: '能力证据矩阵', note: '查看每个能力声明的证据状态', primary: true },
    ]}
  />

  <section>
    <div class="container">
      <SectionHead title="工作流地图" description="用轻量工具链把阅读、整理和表达连接起来。" />
      <div class="workflow-grid">
        {
          workflow.map(([step, title, desc]) => (
            <article class="workflow-card">
              <span>{step}</span>
              <h3>{title}</h3>
              <p>{desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead title="工具栈" description="工具只服务于可追溯的学习过程，不把自动生成内容当作事实本身。" />
      <div class="tool-grid">
        {
          tools.map(([title, desc]) => (
            <article class="tool-card">
              <h3>{title}</h3>
              <p>{desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container split-section">
      <div>
        <SectionHead title="可公开说明的输出" />
        <div class="output-list">
          {outputs.map((item) => <span>{item}</span>)}
        </div>
      </div>
      <article class="boundary-panel">
        <h2>公开边界</h2>
        <p>
          当前公开的是工作流说明，不公开私人 Obsidian vault、原始
          PDF、账号信息、未脱敏笔记截图或正式申请包。没有公开证据的内容，会标记为案例支撑或叙事边界。
        </p>
      </article>
    </div>
  </section>

  <section id="claim-matrix" class="claim-section">
    <div class="container">
      <SectionHead
        title="能力证据矩阵"
        description="每条能力声明都标注证据状态、公开边界和可回访页面，避免把叙事误当成硬证明。"
      />
      <div class="claim-grid">
        {
          claims.map((item) => (
            <article class:list={['claim-card', `status-${item.status}`]}>
              <div class="claim-meta">
                <span>{statusLabels[item.status]}</span>
                <span>{item.risk === 'medium' ? '中等公开风险' : '低公开风险'}</span>
              </div>
              <h3>{item.zh.title}</h3>
              <p>{item.zh.claim}</p>
              <dl>
                <div>
                  <dt>公开边界</dt>
                  <dd>{item.zh.boundary}</dd>
                </div>
                <div>
                  <dt>证据数量</dt>
                  <dd>{item.evidenceIds.length ? `${item.evidenceIds.length} 项公开证据` : '暂无证书型证据'}</dd>
                </div>
              </dl>
              <div class="claim-links" aria-label={`${item.zh.title} 相关页面`}>
                {item.routes.slice(0, 4).map((route) => (
                  <a href={route}>{routeLabels[route] ?? route}</a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .km-hero {
    padding: 96px 0 46px;
  }
  .km-hero .container {
    max-width: 860px;
  }
  .km-hero .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .km-hero h1 {
    max-width: 720px;
    margin: 10px 0 0;
    color: var(--primary);
    font-size: clamp(36px, 5.6vw, 62px);
    line-height: 1.08;
  }
  .km-hero .lead {
    max-width: 700px;
    margin-top: 18px;
    color: var(--muted);
    font-size: 17px;
  }
  .km-hero .tag-row {
    margin-top: 18px;
  }
  .workflow-grid,
  .tool-grid,
  .claim-grid {
    display: grid;
    gap: 14px;
  }
  .workflow-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .tool-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .claim-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .workflow-card,
  .tool-card,
  .claim-card,
  .boundary-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .workflow-card,
  .tool-card,
  .claim-card {
    padding: 20px;
  }
  .workflow-card span {
    color: var(--accent);
    font-size: 22px;
    font-weight: 900;
  }
  .workflow-card h3,
  .tool-card h3,
  .claim-card h3,
  .boundary-panel h2 {
    margin: 8px 0 0;
    color: var(--primary);
    font-size: 18px;
  }
  .workflow-card p,
  .tool-card p,
  .claim-card p,
  .claim-card dd,
  .boundary-panel p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.62;
  }
  .split-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: start;
  }
  .output-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .output-list span,
  .claim-meta span,
  .claim-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 850;
    line-height: 1.25;
  }
  .output-list span {
    padding: 0 12px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.68);
    color: var(--primary);
  }
  :root[data-theme='dark'] .output-list span,
  :root.dark .output-list span {
    background: rgba(255, 255, 255, 0.05);
  }
  .boundary-panel {
    padding: 22px;
    border-left: 4px solid var(--accent);
    background: rgba(201, 162, 39, 0.1);
  }
  :root[data-theme='dark'] .boundary-panel,
  :root.dark .boundary-panel {
    background: rgba(224, 189, 78, 0.1);
  }
  .claim-section {
    padding-bottom: 72px;
  }
  .claim-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .claim-meta span {
    min-height: 28px;
    padding: 0 9px;
    background: rgba(47, 111, 94, 0.1);
    color: var(--secondary);
  }
  .status-case-backed .claim-meta span:first-child {
    background: rgba(201, 162, 39, 0.16);
    color: #8a6515;
  }
  :root[data-theme='dark'] .status-case-backed .claim-meta span:first-child,
  :root.dark .status-case-backed .claim-meta span:first-child {
    color: var(--accent);
  }
  .claim-card dl {
    display: grid;
    gap: 8px;
    margin: 12px 0 0;
  }
  .claim-card dt {
    color: var(--secondary);
    font-size: 12px;
    font-weight: 900;
  }
  .claim-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }
  .claim-links a {
    min-height: 36px;
    padding: 7px 11px;
    background: var(--accent-soft);
    color: var(--primary);
    text-decoration: none;
  }
  .claim-links a:hover {
    border-color: rgba(201, 162, 39, 0.45);
    background: rgba(201, 162, 39, 0.18);
  }
  @media (max-width: 980px) {
    .workflow-grid,
    .claim-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .split-section {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 680px) {
    .km-hero {
      padding-top: 64px;
    }
    .workflow-grid,
    .tool-grid,
    .claim-grid {
      grid-template-columns: 1fr;
    }
    .workflow-card,
    .tool-card,
    .claim-card,
    .boundary-panel {
      padding: 18px;
    }
  }
</style>
