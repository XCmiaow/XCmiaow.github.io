---
import ResourceTemplatePage from '../../../components/ResourceTemplatePage.astro';
import { resourceTemplates } from '../../../data/siliconAshesResources';
import SiliconEmbersLayout from '../../../layouts/SiliconEmbersLayout.astro';

export function getStaticPaths() {
  return resourceTemplates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props;
const data = template.zh;
const canonicalPath = `/silicon-ashes/resources/${template.slug}/`;
const alternatePath = `/en/silicon-ashes/resources/${template.slug}/`;
---

<SiliconEmbersLayout
  lang="zh"
  title={`${data.title} | 硅基余烬资源`}
  description={data.summary}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
>
  <ResourceTemplatePage lang="zh" template={template} />
</SiliconEmbersLayout>
