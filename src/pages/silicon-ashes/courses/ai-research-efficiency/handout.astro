---
import { getCollection, render } from 'astro:content';

import { coursePaths } from '../../../../data/courseCatalog';
import { courseComponents } from '../../../../lib/courseComponents';
import { validateCourse } from '../../../../lib/course';
import CourseLayout from '../../../../layouts/CourseLayout.astro';

const entries = await getCollection('course');
const { sorted } = validateCourse(entries);
const rendered = await Promise.all(sorted.map(async (entry) => ({ entry, ...(await render(entry)) })));
---

<CourseLayout
  title="连续讲义"
  summary="把六个单元合并成一份适合通读和打印的中文讲义。打印时会隐藏网站导航、章节轨道和交互提示。"
  canonicalPath={`${coursePaths.zh}/handout/`}
  entries={sorted}
  durationMinutes={720}
  eyebrow="课程辅助材料 · Handout / Print"
>
  {
    rendered.map(({ entry, Content }) => (
      <section class="course-handout-unit" aria-label={`单元 ${entry.data.order}：${entry.data.title}`}>
        <p class="course-block__label">
          单元 {entry.data.order} / 6 · {entry.data.durationMinutes} 分钟
        </p>
        <h2>{entry.data.title}</h2>
        <p>{entry.data.summary}</p>
        <Content components={courseComponents} />
      </section>
    ))
  }
</CourseLayout>
