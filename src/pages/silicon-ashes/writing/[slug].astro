---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const homeHref = '/silicon-ashes/';
const writingHref = '/silicon-ashes/writing/';
const articleBase = '/silicon-ashes/writing/';
const allPosts = (await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const currentIndex = allPosts.findIndex((item) => item.id === post.id);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const relatedPosts = post.data.series
  ? allPosts.filter((item) => item.id !== post.id && item.data.series === post.data.series).slice(0, 3)
  : [];
const articleHref = (item: (typeof allPosts)[number]) => `${articleBase}${item.id}/`;

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
};
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} | 硅基余烬</title>
    {post.data.description && <meta name="description" content={post.data.description} />}
    <meta name="theme-color" content="#050504" />
    <link rel="stylesheet" href="/styles/site.css" />
    <meta property="og:title" content={`${post.data.title} | 硅基余烬`} />
    {post.data.description && <meta property="og:description" content={post.data.description} />}
    <meta property="og:type" content="article" />
  </head>
  <body>
    <div class="ad-shell">
      <header class="ad-nav">
        <a class="ad-brand" href={homeHref}>
          <span class="brand-mark">SA</span>
          <span class="brand-name">硅基余烬</span>
        </a>
        <nav>
          <a href={writingHref}>写作</a>
          <a href="/silicon-ashes/courses/">课程</a>
          <a href="/silicon-ashes/resources/">资源</a>
          <a href="/silicon-ashes/about/">关于</a>
        </nav>
      </header>

      <main id="main" class="article-main">
        <article>
          <header class="article-header">
            {post.data.series && <p class="series-label">{post.data.series}</p>}
            <h1>{post.data.title}</h1>
            <div class="article-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              {post.data.readingTime && <span>{post.data.readingTime} 分钟阅读</span>}
            </div>
            {post.data.tags && (
              <ul class="tag-list">
                {post.data.tags.map((tag: string) => <li>{tag}</li>)}
              </ul>
            )}
          </header>
          <div class="prose">
            <Content />
          </div>
        </article>

        {(newerPost || olderPost || relatedPosts.length > 0) && (
          <nav class="article-nav" aria-label="文章导航">
            <div class="next-prev">
              {newerPost && (
                <a href={articleHref(newerPost)}>
                  <span>上一篇</span>
                  <strong>{newerPost.data.title}</strong>
                </a>
              )}
              {olderPost && (
                <a href={articleHref(olderPost)}>
                  <span>下一篇</span>
                  <strong>{olderPost.data.title}</strong>
                </a>
              )}
            </div>
            {relatedPosts.length > 0 && (
              <section class="related" aria-labelledby="related-title">
                <h2 id="related-title">同系列继续读</h2>
                <div>
                  {relatedPosts.map((item) => (
                    <a href={articleHref(item)}>
                      <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
                      <span>{item.data.title}</span>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </nav>
        )}
      </main>

      <footer class="ad-footer">
        <a href={writingHref}>← 返回写作中心</a>
      </footer>
    </div>
  </body>
</html>

<style>
  :global(html) { scroll-behavior: smooth; background: #080705; }
  :global(body) { margin: 0; background: #080705; color: #e9e0d0; font-family: 'Satoshi', 'Avenir Next', 'Segoe UI', 'Microsoft YaHei', sans-serif; }
  :global(*), :global(*::before), :global(*::after) { box-sizing: border-box; }
  :global(a) { color: inherit; }

  .ad-shell {
    min-height: 100dvh;
    background:
      linear-gradient(90deg, rgba(226,187,116,0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(226,187,116,0.028) 1px, transparent 1px),
      linear-gradient(180deg, #080705 0%, #0e0d0b 42%, #070706 100%);
    background-size: 64px 64px, 64px 64px, auto, auto;
  }

  .ad-nav, .article-main, .ad-footer { width: min(100% - 44px, 780px); margin: 0 auto; }
  .ad-nav { display: flex; min-height: 76px; align-items: center; justify-content: space-between; gap: 24px; border-bottom: 1px solid rgba(218,166,86,0.2); background: rgba(8,7,5,0.86); backdrop-filter: blur(18px); position: sticky; top: 0; z-index: 12; }
  .ad-brand { display: inline-flex; align-items: center; gap: 12px; text-decoration: none; }
  .brand-mark { display: grid; width: 40px; height: 40px; place-items: center; border: 1px solid rgba(218,166,86,0.7); border-radius: 5px; background: linear-gradient(135deg, rgba(238,181,92,0.22), transparent 50%), #11100d; color: #ffe4aa; font-family: Consolas, monospace; font-size: 13px; font-weight: 900; }
  .brand-name { color: #f3e3c5; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 20px; font-weight: 800; }
  .ad-nav nav { display: flex; gap: 6px; }
  .ad-nav nav a { display: inline-flex; min-height: 38px; align-items: center; border-radius: 4px; padding: 0 10px; color: rgba(233,224,208,0.72); font-size: 14px; font-weight: 700; text-decoration: none; }
  .ad-nav nav a:hover { background: rgba(218,166,86,0.1); color: #ffe2aa; }

  .article-main { padding: 80px 0 120px; }
  .article-header { margin-bottom: 48px; padding-bottom: 32px; border-bottom: 1px solid rgba(218,166,86,0.18); }
  .series-label { margin: 0 0 12px; color: #d8aa63; font-family: Consolas, monospace; font-size: 13px; font-weight: 800; }
  h1 { margin: 0; color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; line-height: 1.15; }
  .article-meta { display: flex; gap: 16px; margin-top: 16px; }
  .article-meta time, .article-meta span { color: rgba(168,177,176,0.6); font-family: Consolas, monospace; font-size: 13px; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 6px; margin: 14px 0 0; padding: 0; list-style: none; }
  .tag-list li { border: 1px solid rgba(168,177,176,0.18); border-radius: 3px; padding: 3px 8px; color: rgba(220,228,224,0.55); font-size: 12px; }

  .prose { color: rgba(233,224,208,0.85); font-size: 17px; line-height: 1.9; }
  .prose :global(h2) { color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 26px; font-weight: 800; margin: 48px 0 18px; }
  .prose :global(h3) { color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 21px; font-weight: 800; margin: 36px 0 14px; }
  .prose :global(p) { margin: 0 0 18px; }
  .prose :global(a) { color: #d8aa63; text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { color: #ffe4aa; }
  .prose :global(blockquote) { margin: 24px 0; padding: 16px 24px; border-left: 3px solid #d8aa63; background: rgba(218,166,86,0.06); border-radius: 0 6px 6px 0; }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(code) { background: rgba(218,166,86,0.1); border-radius: 3px; padding: 2px 6px; font-size: 0.9em; }
  .prose :global(pre) { background: rgba(0,0,0,0.4); border: 1px solid rgba(218,166,86,0.15); border-radius: 6px; padding: 20px; overflow-x: auto; margin: 24px 0; }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 24px 0; }
  .prose :global(th), .prose :global(td) { padding: 10px 14px; border-bottom: 1px solid rgba(218,166,86,0.15); text-align: left; }
  .prose :global(th) { color: #d8aa63; font-weight: 800; font-size: 14px; }
  .prose :global(ul), .prose :global(ol) { padding-left: 24px; margin: 0 0 18px; }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(strong) { color: #f2dfbd; }
  .prose :global(hr) { border: none; border-top: 1px solid rgba(218,166,86,0.18); margin: 40px 0; }

  .ad-footer { padding: 24px 0 40px; border-top: 1px solid rgba(218,166,86,0.18); }
  .ad-footer a { color: rgba(233,224,208,0.72); font-size: 14px; text-decoration: none; }
  .ad-footer a:hover { color: #f2dfbd; }
  .article-nav { border-top: 1px solid rgba(218,166,86,0.18); margin-top: 72px; padding-top: 28px; }
  .next-prev { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .next-prev a, .related a { border: 1px solid rgba(218,166,86,0.18); border-radius: 6px; background: rgba(13,12,10,0.78); text-decoration: none; transition: border-color 160ms ease, background 160ms ease; }
  .next-prev a { display: grid; min-height: 108px; align-content: start; gap: 8px; padding: 18px; }
  .next-prev a:hover, .related a:hover { border-color: rgba(241,223,189,0.38); background: rgba(18,16,12,0.96); }
  .next-prev span, .related time { color: rgba(168,177,176,0.62); font-family: Consolas, monospace; font-size: 12px; font-weight: 800; }
  .next-prev strong, .related span { color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 17px; line-height: 1.35; }
  .related { margin-top: 28px; }
  .related h2 { margin: 0 0 14px; color: #d8aa63; font-family: Consolas, monospace; font-size: 13px; font-weight: 900; text-transform: uppercase; }
  .related div { display: grid; gap: 10px; }
  .related a { display: grid; min-height: 64px; align-content: center; gap: 4px; padding: 14px 16px; }

  @media (max-width: 720px) {
    .ad-nav, .article-main, .ad-footer { width: min(100% - 28px, 780px); }
    .ad-nav { position: static; flex-direction: column; align-items: flex-start; padding: 14px 0; }
    .ad-nav nav { display: flex; flex-wrap: wrap; }
    .article-main { padding: 48px 0 80px; }
    .next-prev { grid-template-columns: 1fr; }
  }
</style>
