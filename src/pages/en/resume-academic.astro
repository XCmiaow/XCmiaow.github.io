---
import PrintLayout from '../../layouts/PrintLayout.astro';
import common from '../../data/common.json';

const gpa = common.education.gpa.toFixed(2);
const github = common.person.github;
const email = common.person.email;
---

<PrintLayout title="Xujie Fang · Academic Resume" lang="en" variant="academic">
  <header class="top">
    <div class="top-main">
      <h1>Xujie Fang</h1>
      <p class="sub">Chemical Engineering of Forest Products · College of Chemical Engineering · NJFU</p>
      <p class="tagline">Academic track: ranking evidence, competition awards, service, and leadership</p>
    </div>
    <div class="top-contact">
      <span>Email: {email}</span>
      <span>GitHub: {github}</span>
      <span>Location: Nanjing, China</span>
    </div>
  </header>

  <div class="metric-strip" aria-label="Academic metrics">
    <div class="metric"><strong>{gpa}</strong><span>GPA</span></div>
    <div class="metric"><strong>1st</strong><span>Class rank</span></div>
    <div class="metric"><strong>2nd</strong><span>Major rank</span></div>
    <div class="metric"><strong>6+</strong><span>Provincial+ awards</span></div>
  </div>

  <p class="summary">
    Sophomore undergraduate at Nanjing Forestry University with GPA <strong>{gpa}</strong>, ranked <strong>1st</strong>
    in class and <strong>2nd</strong> in major. The academic evidence chain combines coursework, scholarships, math modeling
    awards, merit recognition, student work, and public service.
  </p>

  <div class="row-2">
    <section>
      <h2>Education</h2>
      <div class="item">
        <div class="item-head"><strong>Nanjing Forestry University</strong><span>2024.09 - Present</span></div>
        <p>College of Chemical Engineering · Chemical Engineering of Forest Products · Undergraduate</p>
        <p class="keyword-line">GPA {gpa} · Class rank 1st · Major rank 2nd · Sophomore</p>
      </div>
    </section>
    <section>
      <h2>Review Strengths</h2>
      <ul class="compact-list">
        <li>Clear ranking metrics for fast academic screening.</li>
        <li>Mathematical modeling awards demonstrate quantitative reasoning and writing.</li>
        <li>Leadership and volunteer records complete the comprehensive-evaluation profile.</li>
      </ul>
    </section>
  </div>

  <section>
    <h2>Selected Honors</h2>
    <div class="row-2 tight">
      <ul class="compact-list">
        <li>2025 and 2026 MCM/ICM Honorable Mention</li>
        <li>2024-2025 National Inspirational Scholarship</li>
        <li>2024 CUMCM Jiangsu Provincial First Prize</li>
        <li>Jiangsu Advanced Mathematics Competition, A-level undergraduate track, 3rd Prize</li>
      </ul>
      <ul class="compact-list">
        <li>MathorCup Mathematical Modeling Challenge, Regional 2nd Prize</li>
        <li>University Merit Student, 2024-2025</li>
        <li>Outstanding Individual in Academic Competitions</li>
        <li>Freshman Debate Cup runner-up; Baima Campus Freshman Volleyball Cup runner-up</li>
      </ul>
    </div>
  </section>

  <section>
    <h2>Academic & Competition Practice</h2>
    <div class="item">
      <div class="item-head">
        <strong>Mathematical modeling training</strong><span>CUMCM · MCM/ICM · MathorCup</span>
      </div>
      <p class="small">
        Practiced open-ended problem decomposition, assumption design, data processing, algorithmic solving,
        visualization, and paper writing under time constraints, turning ambiguous tasks into structured conclusions.
      </p>
    </div>
    <div class="item">
      <div class="item-head">
        <strong>Chemistry foundation and direction</strong><span>Organic chemistry · AI workflows</span>
      </div>
      <p class="small">
        Studying organic chemistry mechanisms, Clayden, March, disconnection analysis, and forest-product chemical
        engineering while exploring computational chemistry and AI-assisted organic synthesis.
      </p>
    </div>
  </section>

  <div class="row-2">
    <section>
      <h2>Leadership</h2>
      <ul class="tiny">
        <li>Class Academic Representative, 2024.09 - 2025.06: assignment coordination and academic affairs support.</li>
        <li>
          Teaching Information Liaison, 2024.09 - 2025.06: course feedback collection and student-teacher communication.
        </li>
        <li>Freshman debate runner-up with teamwork, public speaking, and on-site response practice.</li>
      </ul>
    </section>
    <section>
      <h2>Service & Skills</h2>
      <ul class="tiny">
        <li>
          Primary organizer of the 1st Baima Campus Freshman Volleyball Cup; volunteer service and blood donation.
        </li>
        <li>Skills: Python, Markdown, LaTeX, Origin, Office/WPS, Zotero, Obsidian, Astro.</li>
        <li>Public materials: academic homepage, evidence gallery, project pages, and printable resume versions.</li>
      </ul>
    </section>
  </div>
</PrintLayout>
