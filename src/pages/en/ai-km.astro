---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTrail from '../../components/PageTrail.astro';
import SectionHead from '../../components/SectionHead.astro';
import claimsData from '../../data/claims.json';

const claims = claimsData.items;
const workflow = [
  [
    '01',
    'Collect Literature',
    'Use databases, advisor suggestions, and AI-assisted search prompts to build an initial reading pool, then preserve source metadata in Zotero.',
  ],
  [
    '02',
    'Read and Annotate',
    'Separate abstracts, figures, methods, and questions so a PDF becomes reusable understanding instead of a saved file only.',
  ],
  [
    '03',
    'Organize Knowledge',
    'Use Obsidian to connect course concepts, reading notes, terminology cards, and research questions into a revisitable network.',
  ],
  [
    '04',
    'Turn Notes into Output',
    'Use Markdown and LaTeX to turn notes into weekly reviews, research ideas, presentation outlines, and project narratives.',
  ],
];
const tools = [
  [
    'AI Tools',
    'Draft search strings, decompose paper structure, and support English expression while keeping original reading and fact checks in the loop.',
  ],
  ['Zotero', 'Manage bibliographic records, PDFs, tags, and citation metadata so sources remain traceable.'],
  ['Obsidian', 'Store concept cards, reading notes, and topic maps as a long-term knowledge base.'],
  ['Markdown / LaTeX', 'Convert reading outcomes into clear, versionable research-writing drafts.'],
];
const outputs = [
  'Reading note template',
  'Topic map',
  'Weekly review',
  'Research question list',
  'Presentation outline',
  'Bilingual writing draft',
];
const statusLabels: Record<string, string> = {
  'evidence-backed': 'Evidence-backed',
  'case-backed': 'Case-backed',
  'narrative-only': 'Narrative boundary',
};
const routeLabels: Record<string, string> = {
  '/': 'Home',
  '/en/': 'Home',
  '/modeling': 'Modeling',
  '/en/modeling': 'Modeling',
  '/chem-ai-lab': 'ChemAI Lab',
  '/en/chem-ai-lab': 'ChemAI Lab',
  '/evidence': 'Evidence',
  '/en/evidence': 'Evidence',
  '/materials': 'Materials',
  '/en/materials': 'Materials',
  '/resume-academic': 'Academic Resume',
  '/en/resume-academic': 'Academic Resume',
};
---

<BaseLayout
  title="AI-Assisted Learning & Knowledge Management | Xujie Fang"
  description="Xujie Fang's AI-KM workflow case, showing how AI tools, Zotero, Obsidian, Markdown, and LaTeX support literature reading, knowledge organization, and research communication."
  lang="en"
>
  <section class="km-hero">
    <div class="container">
      <span class="eyebrow">AI-KM Workflow</span>
      <h1>AI-Assisted Learning &amp; Knowledge Management</h1>
      <p class="lead">
        This page turns "using AI tools" into a reviewable learning workflow: how literature is collected, read,
        organized, and converted into research communication.
      </p>
      <div class="tag-row">
        <span class="tag">AI Workflow</span>
        <span class="tag">Zotero</span>
        <span class="tag">Obsidian</span>
      </div>
    </div>
  </section>

  <PageTrail
    eyebrow="Project path"
    title="Place AI-KM inside the evidence system"
    description="This page explains the workflow boundary without publishing a private knowledge vault. Reviewers can return to projects, open the materials hub, or inspect the claim matrix below."
    links={[
      {
        href: '/en/#projects',
        label: 'Back to projects',
        note: 'Compare with modeling, ChemAI Lab, and the resume site',
      },
      { href: '/en/materials', label: 'Materials hub', note: 'Choose public materials by scenario' },
      { href: '#claim-matrix', label: 'Claim matrix', note: 'Check each claim and its evidence status', primary: true },
    ]}
  />

  <section>
    <div class="container">
      <SectionHead
        title="Workflow Map"
        description="A lightweight toolchain connects reading, organization, and output."
      />
      <div class="workflow-grid">
        {
          workflow.map(([step, title, desc]) => (
            <article class="workflow-card">
              <span>{step}</span>
              <h3>{title}</h3>
              <p>{desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead
        title="Tool Stack"
        description="Tools support a traceable learning process; generated text is not treated as fact by itself."
      />
      <div class="tool-grid">
        {
          tools.map(([title, desc]) => (
            <article class="tool-card">
              <h3>{title}</h3>
              <p>{desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container split-section">
      <div>
        <SectionHead title="Publicly Explainable Outputs" />
        <div class="output-list">
          {outputs.map((item) => <span>{item}</span>)}
        </div>
      </div>
      <article class="boundary-panel">
        <h2>Publication Boundary</h2>
        <p>
          The public page explains the workflow, not the private Obsidian vault, raw PDFs, account information,
          unsanitized note screenshots, or formal application packets. Claims without public certificates remain marked
          as case-backed or narrative-bound.
        </p>
      </article>
    </div>
  </section>

  <section id="claim-matrix" class="claim-section">
    <div class="container">
      <SectionHead
        title="Claim-to-Evidence Matrix"
        description="Each ability claim shows its evidence status, publication boundary, and related routes so narrative is not mistaken for hard proof."
      />
      <div class="claim-grid">
        {
          claims.map((item) => (
            <article class:list={['claim-card', `status-${item.status}`]}>
              <div class="claim-meta">
                <span>{statusLabels[item.status]}</span>
                <span>{item.risk === 'medium' ? 'Medium public risk' : 'Low public risk'}</span>
              </div>
              <h3>{item.en.title}</h3>
              <p>{item.en.claim}</p>
              <dl>
                <div>
                  <dt>Boundary</dt>
                  <dd>{item.en.boundary}</dd>
                </div>
                <div>
                  <dt>Evidence count</dt>
                  <dd>
                    {item.evidenceIds.length
                      ? `${item.evidenceIds.length} public evidence item(s)`
                      : 'No certificate evidence yet'}
                  </dd>
                </div>
              </dl>
              <div class="claim-links" aria-label={`${item.en.title} related routes`}>
                {item.routes.slice(0, 4).map((route) => (
                  <a href={route}>{routeLabels[route] ?? route}</a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .km-hero {
    padding: 96px 0 46px;
  }
  .km-hero .container {
    max-width: 860px;
  }
  .km-hero .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .km-hero h1 {
    max-width: 760px;
    margin: 10px 0 0;
    color: var(--primary);
    font-size: clamp(36px, 5.6vw, 62px);
    line-height: 1.08;
  }
  .km-hero .lead {
    max-width: 700px;
    margin-top: 18px;
    color: var(--muted);
    font-size: 17px;
  }
  .km-hero .tag-row {
    margin-top: 18px;
  }
  .workflow-grid,
  .tool-grid,
  .claim-grid {
    display: grid;
    gap: 14px;
  }
  .workflow-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .tool-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .claim-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .workflow-card,
  .tool-card,
  .claim-card,
  .boundary-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .workflow-card,
  .tool-card,
  .claim-card {
    padding: 20px;
  }
  .workflow-card span {
    color: var(--accent);
    font-size: 22px;
    font-weight: 900;
  }
  .workflow-card h3,
  .tool-card h3,
  .claim-card h3,
  .boundary-panel h2 {
    margin: 8px 0 0;
    color: var(--primary);
    font-size: 18px;
  }
  .workflow-card p,
  .tool-card p,
  .claim-card p,
  .claim-card dd,
  .boundary-panel p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.62;
  }
  .split-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: start;
  }
  .output-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .output-list span,
  .claim-meta span,
  .claim-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 850;
    line-height: 1.25;
  }
  .output-list span {
    padding: 0 12px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.68);
    color: var(--primary);
  }
  :root[data-theme='dark'] .output-list span,
  :root.dark .output-list span {
    background: rgba(255, 255, 255, 0.05);
  }
  .boundary-panel {
    padding: 22px;
    border-left: 4px solid var(--accent);
    background: rgba(201, 162, 39, 0.1);
  }
  :root[data-theme='dark'] .boundary-panel,
  :root.dark .boundary-panel {
    background: rgba(224, 189, 78, 0.1);
  }
  .claim-section {
    padding-bottom: 72px;
  }
  .claim-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .claim-meta span {
    min-height: 28px;
    padding: 0 9px;
    background: rgba(47, 111, 94, 0.1);
    color: var(--secondary);
  }
  .status-case-backed .claim-meta span:first-child {
    background: rgba(201, 162, 39, 0.16);
    color: #8a6515;
  }
  :root[data-theme='dark'] .status-case-backed .claim-meta span:first-child,
  :root.dark .status-case-backed .claim-meta span:first-child {
    color: var(--accent);
  }
  .claim-card dl {
    display: grid;
    gap: 8px;
    margin: 12px 0 0;
  }
  .claim-card dt {
    color: var(--secondary);
    font-size: 12px;
    font-weight: 900;
  }
  .claim-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }
  .claim-links a {
    min-height: 36px;
    padding: 7px 11px;
    background: var(--accent-soft);
    color: var(--primary);
    text-decoration: none;
  }
  .claim-links a:hover {
    border-color: rgba(201, 162, 39, 0.45);
    background: rgba(201, 162, 39, 0.18);
  }
  @media (max-width: 980px) {
    .workflow-grid,
    .claim-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .split-section {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 680px) {
    .km-hero {
      padding-top: 64px;
    }
    .workflow-grid,
    .tool-grid,
    .claim-grid {
      grid-template-columns: 1fr;
    }
    .workflow-card,
    .tool-card,
    .claim-card,
    .boundary-panel {
      padding: 18px;
    }
  }
</style>
