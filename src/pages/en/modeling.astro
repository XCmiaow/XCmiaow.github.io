---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTrail from '../../components/PageTrail.astro';
---

<BaseLayout title="Xujie Fang | Mathematical Modeling Case Study" lang="en">
  <section class="hero">
    <div class="container">
      <h1>Mathematical Modeling in Practice</h1>
      <p class="lead">
        Turning competition awards into explainable skill evidence: problem abstraction, model construction, data
        processing, algorithm solving, and paper writing.
      </p>
      <div class="tag-row">
        <span class="tag">CUMCM Provincial 1st</span><span class="tag">MCM/ICM H Award ×2</span><span class="tag"
          >MathorCup Regional 2nd</span
        >
      </div>
    </div>
  </section>

  <PageTrail
    eyebrow="Material path"
    title="Move from modeling skills to evidence and resume"
    description="This page explains the skill formation process. The next step is to verify certificates, review projects, or open the one-page resume."
    links={[
      { href: '/en/#projects', label: 'Back to projects', note: 'Review modeling, website, and ChemAI Lab together' },
      { href: '/en/evidence', label: 'Open certificates', note: 'Check awards and activity evidence', primary: true },
      { href: '/en/resume-onepage', label: 'One-page resume', note: 'Print, save as PDF, or use for applications' },
    ]}
  />

  <section>
    <div class="container">
      <div class="section-head"><h2>Skill Positioning</h2></div>
      <div class="grid-3">
        <article class="card pad">
          <h3>For Graduate School</h3><p>
            Demonstrates mathematical foundations, research communication, English writing, and interdisciplinary
            modeling.
          </p>
        </article>
        <article class="card pad">
          <h3>For Career</h3><p>
            Proves ability to decompose open problems into variables, assumptions, models, code, and conclusions.
          </p>
        </article>
        <article class="card pad">
          <h3>Problem Solving</h3><p>
            Extracting variables, building assumptions, selecting models, validating results, and presenting findings in
            clear academic writing.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head"><h2>Modeling Workflow</h2></div>
      <div class="flow">
        <div class="step"><b>01</b> Problem Understanding</div>
        <div class="step"><b>02</b> Model Assumptions</div>
        <div class="step"><b>03</b> Data Processing</div>
        <div class="step"><b>04</b> Algorithm Solving</div>
        <div class="step"><b>05</b> Result Analysis</div>
        <div class="step"><b>06</b> Paper Writing</div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head"><h2>Personal Role</h2></div>
      <div class="grid-2">
        <div class="card pad">
          <h3>Verifiable Skills</h3>
          <ul class="evidence-list">
            <li>Contributed to problem abstraction, model construction, data analysis, and paper writing</li><li>
              Proficient in Python, LaTeX, Markdown, Origin
            </li><li>Experienced in cross-disciplinary research and deadline-driven delivery</li>
          </ul>
        </div>
        <div class="card pad">
          <h3>Areas of Growth</h3>
          <ul class="evidence-list">
            <li>Roles across contests: modeling, programming, academic writing, and visualization</li><li>
              Models applied include regression analysis, optimization, and numerical simulation
            </li><li>Systematic approach to decomposing ill-posed problems into computable frameworks</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 80px 0 40px;
  }
  .hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    color: var(--primary);
  }
  .lead {
    max-width: 640px;
    margin-top: 16px;
    color: var(--muted);
    font-size: 17px;
  }
  .flow {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
  }
  .step {
    text-align: center;
    padding: 20px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .step b {
    display: block;
    color: var(--accent);
    font-size: 22px;
    margin-bottom: 6px;
  }
  @media (max-width: 640px) {
    .flow {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
