---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Xujie Fang | One-Page Resume" lang="en">
<div class="print-bar no-print"><button class="btn primary" onclick="window.print()">Print / Save as PDF</button></div>

<article class="page">
  <header class="resume-head">
    <div>
