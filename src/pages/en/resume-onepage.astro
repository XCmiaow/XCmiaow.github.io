---
import PrintLayout from '../../layouts/PrintLayout.astro';
import en from '../../data/en.json';

const p = en.person;
const edu = en.education;
const allAwards = en.competitions;
function awardLevel(l: string) {
  if (l === 'international') return 'Intl.';
  if (l === 'national') return 'Natl.';
  if (l === 'provincial') return 'Prov.';
  if (l === 'school') return 'Univ.';
  return 'Coll.';
}
---

<PrintLayout title="Xujie Fang · One-Page Resume" lang="en">
  <header class="top">
    <div class="top-main">
      <h1>{p.name}</h1>
      <p class="sub">{edu.major} · {edu.college} · {edu.school}</p>
    </div>
    <div class="top-contact">
      <span>📧 2332797170@njfu.edu.cn</span>
      <span>🐙 github.com/XCmiaow</span>
      <span>📍 {edu.school}</span>
    </div>
  </header>

  <p class="summary">
    Undergraduate in {edu.major} · GPA <strong>3.60</strong> (Class <strong>1st</strong>, Major <strong>2nd</strong>).
    National Inspirational Scholarship. Core math modeling: CUMCM <strong>Jiangsu Provincial First Prize</strong>,
    consecutive MCM/ICM <strong>Honorable Mentions</strong> (2025, 2026). Self-studying Clayden & March in organic chemistry,
    Python modeling, and deep learning fundamentals. Research interest in computational chemistry and AI-assisted organic
    synthesis.
  </p>

  <div class="row-2">
    <section>
      <h2>Education</h2>
      <div class="item">
        <div class="item-head"><strong>{edu.school} · {edu.college}</strong><span>{edu.period}</span></div>
        <p>{edu.major} · {edu.degree} · {edu.year}</p>
        <p>GPA: <strong>3.60</strong> · Class Rank: 1st · Major Rank: 2nd</p>
      </div>
    </section>
    <section>
      <h2>Research Interest</h2>
      <p class="small">
        AI-assisted organic synthesis, computational chemistry, GNNs for molecular representation, and LLM agent
        workflows for scientific literature retrieval.
      </p>
    </section>
  </div>

  <section>
    <h2>Awards &amp; Honors</h2>
    <table class="honors-table">
      {
        allAwards.map((a) => (
          <tr>
            <>
              <td class="yr">{a.year}</td>
              <td class="lvl">{awardLevel(a.level)}</td>
              <td>{a.title}</td>
            </>
          </tr>
        ))
      }
    </table>
  </section>

  <section>
    <h2>Projects</h2>
    <div class="item">
      <div class="item-head"><strong>Mathematical Modeling Practice</strong></div>
      <p class="small">
        Problem abstraction, model construction, data processing, algorithm solving, and academic paper writing across
        CUMCM, MCM/ICM, and MathorCup competitions.
      </p>
    </div>
    <div class="item">
      <div class="item-head"><strong>ChemAI Lab</strong></div>
      <p class="small">
        ML and quantum chemistry research platform integrating RDKit, PyTorch, and Lightning across 16 subpackages for
        data, feature engineering, modeling, XAI, and QM interfaces.
      </p>
    </div>
    <div class="item">
      <div class="item-head"><strong>Bilingual Academic Resume Website</strong></div>
      <p class="small">
        Astro-powered bilingual site with component architecture, i18n, PWA, dark mode, CI/CD, and automated deployment
        via GitHub Actions.
      </p>
    </div>
  </section>

  <div class="row-2">
    <section>
      <h2>Skills</h2>
      <p class="small"><strong>Domain:</strong> Organic chemistry mechanisms, Clayden, March, disconnection approach</p>
      <p class="small"><strong>Modeling:</strong> Math modeling, Python, LaTeX, Markdown, Origin</p>
      <p class="small"><strong>Dev tools:</strong> HTML, CSS, JavaScript, React, VS Code, Codex</p>
      <p class="small"><strong>Engineering:</strong> Office/WPS, Axglyph, AutoCAD, Aspen Plus, Zotero, Obsidian</p>
    </section>
    <section>
      <h2>Experience</h2>
      <ul class="tiny">
        <li><b>Class Academic Representative</b> (2024-2025): Assignment management and academic coordination</li>
        <li><b>Teaching Information Liaison</b> (2024-2025): Student-teacher communication</li>
        <li>Organizer, 1st Baima Campus Freshman Volleyball Cup</li>
        <li>"Card House" volunteer service &amp; Red Cross blood donation</li>
      </ul>
    </section>
  </div>
</PrintLayout>
