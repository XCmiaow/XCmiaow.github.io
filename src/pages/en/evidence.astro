---
import BaseLayout from '../layouts/BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';

const certs = [
  'national-inspirational-scholarship-2025.jpg',
  'cumcm-2024-jiangsu-first.jpg',
  'mcm-2025-honorable-mention.jpg',
  'mcm-2026-honorable-mention.jpg',
  'mathorcup-2025-second.png',
  'math-competition-2025-third.jpg',
  'three-good-student-2025.png',
  'debate-second-2024.jpg',
  'card-house-volunteer-2024.jpg',
  'volleyball-freshman-2024-second.jpg',
  'volleyball-college-2026-fourth.jpg',
  'high-jump-2025-fourth.jpg',
];
const imgBase = '/assets/evidence/public/';
const imgUrls = certs.map(f => imgBase + f);
---

<BaseLayout title="Xujie Fang | Certificate Gallery" lang="en">
<section class="hero"><div class="container">
  <h1>Certificate Gallery</h1>
  <p class="lead">Click any certificate to view full size. Navigate with arrow keys.</p>
</div></section>

<div class="container" style="margin-bottom:60px">
  <div class="grid-3">
    {certs.map((f, i) => (
      <a class="cert-card" href={imgBase + f} target="_blank">
        <img src={imgBase + f} alt={f} loading="lazy" />
      </a>
    ))}
  </div>
</div>

<Lightbox images={imgUrls} />
</BaseLayout>

<style>
  .hero { padding: 80px 0 30px; } .hero h1 { font-size: clamp(36px, 6vw, 54px); color: var(--primary); }
  .lead { max-width: 600px; margin-top: 12px; color: var(--muted); }
  .cert-card { display: block; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; transition: transform 0.2s ease, box-shadow 0.2s ease; cursor: pointer; }
  .cert-card img { width: 100%; height: 240px; object-fit: contain; background: #f5f5f5; }
  .cert-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
</style>
