---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(p => p.data.lang === 'en').map(p => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | Xujie Fang`} description={post.data.description} lang="en">
<section style="padding:60px 0"><div class="container" style="max-width:740px">
  <a href="/en/blog" style="color:var(--muted);font-size:14px;display:inline-block;margin-bottom:20px">← Back to Blog</a>
  <h1 style="font-size:clamp(28px,4vw,40px);color:var(--primary);margin:0">{post.data.title}</h1>
  <div style="display:flex;gap:12px;align-items:center;margin-top:10px;color:var(--muted);font-size:14px;flex-wrap:wrap">
    <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}</time>
    {(post.data.tags || []).map(t => <span class="tag" style="font-size:11px">{t}</span>)}
  </div>
  <div class="blog-content" style="margin-top:32px;line-height:1.8;color:var(--ink)">
    <Content />
  </div>
</div></section>
</BaseLayout>

<style>
  .blog-content h2 { font-size: 22px; color: var(--primary); margin: 28px 0 12px; }
  .blog-content h3 { font-size: 18px; color: var(--secondary); margin: 22px 0 10px; }
  .blog-content p { margin: 14px 0; }
  .blog-content ul, .blog-content ol { padding-left: 20px; margin: 12px 0; }
  .blog-content li { margin: 6px 0; }
  .blog-content code { background: var(--accent-soft); padding: 2px 6px; border-radius: 4px; font-size: .9em; }
  .blog-content pre { background: #f5f5f5; padding: 16px; border-radius: var(--radius); overflow-x: auto; }
</style>
