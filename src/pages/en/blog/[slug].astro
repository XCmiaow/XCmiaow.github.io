---
import { getCollection, type CollectionEntry } from 'astro:content';
import CompatibilityEntry from '../../../components/silicon-embers/CompatibilityEntry.astro';
import { siliconEmbersArticleAlternates } from '../../../data/siliconEmbersHome';
import SiliconEmbersLayout from '../../../layouts/SiliconEmbersLayout.astro';
import { routePath } from '../../../lib/siteRoutes';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props as { post: BlogPost };
const canonicalPath = routePath('writing-entry', 'en').replace(':slug', post.id);
const alternateId = siliconEmbersArticleAlternates[post.id];
const chineseIds = new Set(
  (await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft)).map((entry) => entry.id),
);
const alternatePath =
  alternateId && chineseIds.has(alternateId)
    ? routePath('writing-entry', 'zh').replace(':slug', alternateId)
    : undefined;
---

<SiliconEmbersLayout
  lang="en"
  title={`${post.data.title} | Compatibility entry`}
  description={post.data.description ?? post.data.title}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
>
  <CompatibilityEntry
    title={post.data.title}
    message="This article has moved to its canonical silicon-embers writing address."
    href={canonicalPath}
    action="Read the canonical version"
  />
</SiliconEmbersLayout>
