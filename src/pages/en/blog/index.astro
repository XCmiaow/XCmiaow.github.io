---
import CompatibilityEntry from '../../../components/silicon-embers/CompatibilityEntry.astro';
import SiliconEmbersLayout from '../../../layouts/SiliconEmbersLayout.astro';
import { alternatePath, routePath } from '../../../lib/siteRoutes';

const lang = 'en' as const;
const canonicalPath = routePath('writing', lang);
---

<SiliconEmbersLayout
  lang={lang}
  title="Blog moved | silicon-embers"
  description="Compatibility entry for the former blog index."
  canonicalPath={canonicalPath}
  alternatePath={alternatePath('writing', lang)}
>
  <CompatibilityEntry
    title="The blog now lives inside silicon-embers"
    message="The former address no longer hosts a separate copy. Use the canonical writing index."
    href={canonicalPath}
    action="Open the writing index"
  />
</SiliconEmbersLayout>
