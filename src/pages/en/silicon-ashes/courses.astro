---
import CoursesHub from '../../../components/CoursesHub.astro';
import SiliconEmbersLayout from '../../../layouts/SiliconEmbersLayout.astro';
import { alternatePath as routeAlternatePath, routePath, type RouteId } from '../../../lib/siteRoutes';

const routeId: RouteId = 'course-home';
const lang = 'en' as const;
const canonicalPath = routePath(routeId, lang);
const alternatePath = routeAlternatePath(routeId, lang);
---

<SiliconEmbersLayout
  lang={lang}
  title="Course pack | Resources | Silicon Ashes"
  description="The course pack inside Silicon Ashes resources: AI methods and toolchain materials for chemistry teachers and zero-basis learners."
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
>
  <CoursesHub lang={lang} />
</SiliconEmbersLayout>
