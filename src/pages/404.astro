---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 · 404" lang="zh">
<section class="hero" style="min-height:60vh;display:grid;place-items:center;text-align:center">
  <div>
    <h1 style="font-size:clamp(80px,20vw,160px);color:var(--accent);margin:0">404</h1>
    <p style="font-size:20px;color:var(--muted);margin:8px 0 32px">页面不存在或已被移除</p>
    <a class="btn primary" href="/">回到首页</a>
  </div>
</section>
</BaseLayout>
