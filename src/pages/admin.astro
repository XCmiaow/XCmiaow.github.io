---
import BaseLayout from '../layouts/BaseLayout.astro';
import zh from '../data/zh.json';
import en from '../data/en.json';

// Dashboard stats
const totalTbds = zh.competitions.filter(c => c.details?.topic === 'TBD').length;
const posts = ['hello-world','getting-started']; // would use getCollection in dev
const compiled = new Date().toISOString().split('T')[0];
const compsWithDetails = zh.competitions.filter(c => c.details?.topic && c.details.topic !== 'TBD').length;
const compsTotal = zh.competitions.length;
---

<BaseLayout title="管理面板" lang="zh">
<section style="padding:60px 0 20px"><div class="container">
  <h1 style="font-size:clamp(28px,4vw,40px);color:var(--primary);margin:0">管理面板</h1>
  <p style="color:var(--muted);margin-top:6px">仪表盘 · 写文章 · 数据管理</p>
</div></section>

<section><div class="container">
  <!-- Tabs -->
  <div class="admin-tabs">
    <button class="admin-tab active" data-tab="dashboard">📊 概览</button>
    <button class="admin-tab" data-tab="write">✍️ 写文章</button>
    <button class="admin-tab" data-tab="competitions">📋 竞赛 </button>
    <button class="admin-tab" data-tab="tools">🔧 工具</button>
  </div>

  <!-- TAB: Dashboard -->
  <div class="tab-panel active" id="tab-dashboard">
    <div class="admin-grid">
      <div class="card pad">
        <h3>📊 内容完整度</h3>
        <div class="meter-bar"><div class="meter-fill" style="width:100%"></div></div>
        <div class="admin-stat"><span>教育信息</span><b>✅ 100%</b></div>
        <div class="meter-bar"><div class="meter-fill" style="width:82%"></div></div>
        <div class="admin-stat"><span>奖项录入</span><b>{compsTotal} 项</b></div>
        <div class="meter-bar"><div class="meter-fill" style="width:70%"></div></div>
        <div class="admin-stat"><span>竞赛详情</span><b>{compsWithDetails}/{compsTotal} 填写</b></div>
        <div class="meter-bar"><div class="meter-fill" style="width:50%"></div></div>
        <div class="admin-stat"><span>博客文章</span><b>{posts.length} 篇</b></div>
        <div class="admin-stat" style="margin-top:8px"><span>最后构建</span><b>{compiled}</b></div>
      </div>

      <div class="card pad">
        <h3>📋 待办事项</h3>
        {totalTbds > 0 && <div class="todo-item">⚠️ 还有 <b>{totalTbds}</b> 个竞赛详情是 TBD，<a href="#tab-competitions" onclick="switchTab('competitions')">去补全</a></div>}
        <div class="todo-item">✅ 数据文件完整性良好</div>
        <div class="todo-item" style="margin-top:12px;font-size:12px;color:var(--muted)">切换 Tab 查看详细管理功能</div>
      </div>

      <div class="card pad" style="grid-column:1/-1">
        <h3>📈 访问统计</h3>
        <iframe src="https://cloud.umami.is/share/xxxxx" style="width:100%;height:280px;border:none;border-radius:var(--radius);background:var(--paper)" loading="lazy"></iframe>
        <p style="font-size:12px;color:var(--muted);margin:6px 0 0">数据来自 Umami · <a href="https://cloud.umami.is" target="_blank" rel="noopener">详细统计 →</a></p>
      </div>
    </div>
  </div>

  <!-- TAB: Write -->
  <div class="tab-panel" id="tab-write">
    <div style="max-width:640px">
      <div class="field">
        <label for="post-lang">语言</label>
        <select id="post-lang"><option value="zh">中文</option><option value="en">English</option></select>
      </div>
      <div class="field">
        <label for="post-title">标题 *</label>
        <input id="post-title" type="text" placeholder="文章标题" />
      </div>
      <div class="field">
        <label for="post-desc">摘要</label>
        <input id="post-desc" type="text" placeholder="简短描述（可选）" />
      </div>
      <div class="field">
        <label for="post-tags">标签</label>
        <input id="post-tags" type="text" placeholder="用逗号分隔，如：有机化学,笔记" />
      </div>
      <div class="field">
        <label for="post-body">正文 * <span style="font-weight:400;color:var(--muted);font-size:13px">支持 Markdown</span></label>
        <textarea id="post-body" rows="12" placeholder="在这里写文章内容..."></textarea>
      </div>
      <div class="field">
        <label for="gh-token">GitHub Token</label>
        <input id="gh-token" type="password" placeholder="personal access token" />
        <p style="font-size:12px;color:var(--muted);margin:4px 0 0">仅需输入一次，保存在本地浏览器</p>
      </div>
      <div id="publish-status"></div>
      <button class="btn primary" id="publish-btn" type="button" style="width:100%;justify-content:center;min-height:48px">发布文章</button>
    </div>
  </div>

  <!-- TAB: Competitions -->
  <div class="tab-panel" id="tab-competitions">
    <div class="admin-grid">
      {zh.competitions.filter(c => !c.details?.topic || c.details.topic === 'TBD').map(c => (
      <div class="card pad comp-form" data-comp="{c.title}">
        <h4 style="margin:0 0 6px;color:var(--primary);font-size:15px">{c.title}</h4>
        <p style="font-size:13px;color:var(--muted);margin:0 0 10px">{c.note} · {c.year}</p>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-topic" type="text" placeholder="比赛题目" style="padding:8px 10px;font-size:13px" />
        </div>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-role" type="text" placeholder="你的角色（建模/编程/写作）" style="padding:8px 10px;font-size:13px" />
        </div>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-model" type="text" placeholder="用到的模型/方法" style="padding:8px 10px;font-size:13px" />
        </div>
        <button class="btn comp-save-btn" style="width:100%;justify-content:center;font-size:13px;min-height:36px">暂存到本地</button>
      </div>
      ))}
    </div>
    {totalTbds === 0 && <p style="text-align:center;padding:40px;color:var(--muted)">✅ 所有竞赛详情已填写完毕</p>}
  </div>

  <!-- TAB: Tools -->
  <div class="tab-panel" id="tab-tools">
    <div class="admin-grid">
      <div class="card pad">
        <h3>📅 学期切换器</h3>
        <p style="font-size:14px;color:var(--muted);margin:4px 0 14px">当前：{zh.education.year}</p>
        <button class="btn" onclick="alert('需通过 GitHub API 提交修改。当前年级: {zh.education.year}')" style="width:100%;justify-content:center;font-size:13px">升级到下学期</button>
      </div>
      <div class="card pad">
        <h3>🔗 外部链接</h3>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io" target="_blank">📦 GitHub 仓库</a>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io/actions" target="_blank">🔄 Actions 构建</a>
        <a class="admin-btn" href="https://cloud.umami.is" target="_blank">📈 Umami 统计</a>
        <a class="admin-btn" href="/blog/">📖 博客列表</a>
        <a class="admin-btn" href="/">🏠 返回首页</a>
      </div>
    </div>
  </div>
</div></section>
</BaseLayout>

<script>
  // ===== Tab switching =====
  function switchTab(name) {
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelector('.admin-tab[data-tab="' + name + '"]')?.classList.add('active');
    document.getElementById('tab-' + name)?.classList.add('active');
  }
  document.querySelectorAll('.admin-tab').forEach(function(tab) {
    tab.addEventListener('click', function() { switchTab(this.dataset.tab); });
  });

  // ===== Blog publish =====
  (function(){
    var savedToken = localStorage.getItem('gh-blog-token');
    var tokenInput = document.getElementById('gh-token');
    if (savedToken && tokenInput) tokenInput.value = savedToken;

    var btn = document.getElementById('publish-btn');
    if (!btn) return;
    btn.addEventListener('click', async function() {
      var title = document.getElementById('post-title').value.trim();
      var body = document.getElementById('post-body').value.trim();
      var lang = document.getElementById('post-lang').value;
      var desc = document.getElementById('post-desc').value.trim();
      var tags = document.getElementById('post-tags').value.split(',').map(function(t){return t.trim()}).filter(Boolean);
      var token = tokenInput.value.trim();
      var status = document.getElementById('publish-status');
      if (!title) { status.innerHTML = '<p style="color:var(--accent)">请输入标题</p>'; return; }
      if (!body) { status.innerHTML = '<p style="color:var(--accent)">请输入正文</p>'; return; }
      if (!token) { status.innerHTML = '<p style="color:var(--accent)">请输入 GitHub Token</p>'; return; }
      localStorage.setItem('gh-blog-token', token);
      status.innerHTML = '<p style="color:var(--muted)">发布中...</p>';
      btn.disabled = true;

      var slug = title.toLowerCase().replace(/[^\w\s一-鿿-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'').substring(0,80) || 'post';
      var frontmatter = '---\ntitle: "' + title + '"\ndescription: "' + (desc || '') + '"\ndate: ' + new Date().toISOString().split('T')[0] + '\nlang: ' + lang + '\ntags: [' + tags.map(function(t){return '"'+t+'"'}).join(',') + ']\ndraft: false\n---\n\n';
      var content = frontmatter + body;
      var encoded = btoa(unescape(encodeURIComponent(content)));
      var path = 'src/content/blog/' + slug + '.md';

      try {
        var res = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io/contents/' + path, {
          method: 'PUT',
          headers: { 'Authorization': 'token ' + token, 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: 'blog: add ' + slug, content: encoded, branch: 'main' })
        });
        if (res.ok) {
          status.innerHTML = '<p style="color:var(--green);font-weight:700">✅ 发布成功！正在自动部署...</p>';
          document.getElementById('post-title').value = '';
          document.getElementById('post-body').value = '';
          document.getElementById('post-desc').value = '';
          document.getElementById('post-tags').value = '';
        } else {
          var err = await res.json();
          status.innerHTML = '<p style="color:#c00">❌ 发布失败: ' + (err.message || '未知错误') + '</p>';
        }
      } catch(e) { status.innerHTML = '<p style="color:#c00">❌ 网络错误: ' + e.message + '</p>'; }
      btn.disabled = false;
    });
  })();

  // ===== Competition TBD forms =====
  (function(){
    var forms = document.querySelectorAll('.comp-form');
    forms.forEach(function(form){
      var title = form.dataset.comp;
      var topicInp = form.querySelector('.comp-topic');
      var roleInp = form.querySelector('.comp-role');
      var modelInp = form.querySelector('.comp-model');
      var saveBtn = form.querySelector('.comp-save-btn');

      // Restore saved data
      var saved = localStorage.getItem('comp-' + title);
      if (saved) {
        var data = JSON.parse(saved);
        if (data.topic) topicInp.value = data.topic;
        if (data.role) roleInp.value = data.role;
        if (data.model) modelInp.value = data.model;
      }

      saveBtn.addEventListener('click', function() {
        localStorage.setItem('comp-' + title, JSON.stringify({
          topic: topicInp.value, role: roleInp.value, model: modelInp.value
        }));
        saveBtn.textContent = '✅ 已暂存';
        setTimeout(function(){ saveBtn.textContent = '暂存到本地'; }, 2000);
      });
    });
  })();
</script>

<style>
  .admin-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
  .admin-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
  .admin-tab { padding: 10px 18px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--paper); color: var(--muted); font-weight: 700; cursor: pointer; }
  .admin-tab.active { border-color: var(--accent); background: var(--accent-soft); color: var(--primary); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .admin-stat { display: flex; justify-content: space-between; padding: 5px 0; font-size: 14px; }
  .admin-stat span { color: var(--muted); }
  .meter-bar { height: 6px; background: var(--line); border-radius: 3px; margin: 4px 0 2px; overflow: hidden; }
  .meter-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--green)); border-radius: 3px; }
  .todo-item { padding: 6px 0; font-size: 14px; color: var(--ink); }
  .admin-btn { display: block; padding: 10px 14px; margin-bottom: 8px; border: 1px solid var(--line); border-radius: var(--radius); font-size: 14px; color: var(--primary); font-weight: 650; }
  .admin-btn:hover { background: var(--accent-soft); }
  .field { margin-bottom: 16px; }
  .field label { display: block; font-weight: 700; color: var(--primary); margin-bottom: 6px; font-size: 14px; }
  .field input, .field textarea, .field select {
    width: 100%; padding: 10px 12px; border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--paper); color: var(--ink); font-size: 14px; font-family: inherit; box-sizing: border-box;
  }
  .field input:focus, .field textarea:focus, .field select:focus { outline: none; border-color: var(--accent); }
  .field textarea { resize: vertical; min-height: 160px; line-height: 1.6; }
  #publish-status p { margin: 8px 0; font-size: 14px; }
  .card h3 { margin: 0 0 12px; color: var(--primary); font-size: 16px; }
</style>
