---
import BaseLayout from '../layouts/BaseLayout.astro';
import zh from '../data/zh.json';
import en from '../data/en.json';
import common from '../data/common.json';

const totalTbds = zh.competitions.filter(c => c.details?.topic === 'TBD').length;
const compiled = new Date().toISOString().split('T')[0];
---

<BaseLayout title="管理面板" lang="zh">
<section style="padding:60px 0 20px"><div class="container">
  <h1 style="font-size:clamp(28px,4vw,40px);color:var(--primary);margin:0">管理面板</h1>
  <p style="color:var(--muted);margin-top:6px">网站状态 · 快捷操作 · 数据概览</p>
</div></section>

<div id="admin-content" style="display:none">
  <section><div class="container">
    <div class="admin-grid">
      <div class="admin-card">
        <h3>📊 数据概览</h3>
        <div class="admin-stat"><span>中文奖项</span><strong>{zh.competitions.length}</strong></div>
        <div class="admin-stat"><span>英文奖项</span><strong>{en.competitions.length}</strong></div>
        <div class="admin-stat"><span>技能分类</span><strong>{zh.skills.length}</strong></div>
        <div class="admin-stat"><span>项目数</span><strong>{zh.projects.length}</strong></div>
        <div class="admin-stat"><span>待补充 TBD</span><strong style="color:var(--accent)">{totalTbds}</strong></div>
      </div>

      <div class="admin-card">
        <h3>⚡ 快捷操作</h3>
        <a class="admin-btn" href="/write/">✍️ 写新文章</a>
        <a class="admin-btn" href="/blog/">📖 查看博客</a>
        <a class="admin-btn" href="/">🏠 返回首页</a>
      </div>

      <div class="admin-card">
        <h3>🔗 外部链接</h3>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io" target="_blank">📦 GitHub 仓库</a>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io/actions" target="_blank">🔄 Actions 构建</a>
        <a class="admin-btn" href="https://cloud.umami.is" target="_blank">📈 Umami 统计</a>
      </div>

      <div class="admin-card">
        <h3>📋 待办检查</h3>
        <div class="todo-item">{totalTbds > 0 ? '⚠️' : '✅'} 竞赛详情中 {totalTbds} 个 TBD 待补充</div>
        <div class="admin-stat" style="margin-top:12px"><span>构建日期</span><strong>{compiled}</strong></div>
      </div>
    </div>
  </div></section>
</div>

<div id="login-screen">
  <div class="login-box">
    <h2>🔐 验证</h2>
    <input type="password" id="pw-input" placeholder="输入管理密码" onkeydown="if(event.key==='Enter')checkPw()" />
    <button class="btn primary" onclick="checkPw()" style="width:100%;justify-content:center">进入</button>
    <p id="pw-error" style="color:#c00;font-size:13px;margin:8px 0 0;display:none">密码错误</p>
  </div>
</div>

<script>
  function checkPw() {
    var input = document.getElementById('pw-input');
    var hash = '';
    // Simple hash function
    var s = input.value || '';
    for (var i = 0; i < s.length; i++) {
      hash += s.charCodeAt(i).toString(16);
    }
    // Pre-computed hash of the password - you can change it below:
    // 1. Open browser console, type: btoa("your-password")
    // 2. Replace the string below with the result
    var pwB64 = 'MDYwNDIw'; // base64 of "060420" — CHANGE THIS

    if (btoa(s) === pwB64) {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('admin-content').style.display = 'block';
      localStorage.setItem('admin-auth', '1');
    } else {
      document.getElementById('pw-error').style.display = 'block';
    }
  }

  // Auto-login if already authenticated in this session
  if (localStorage.getItem('admin-auth') === '1') {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('admin-content').style.display = 'block';
  }
</script>

<style>
  #login-screen {
    position: fixed; inset: 0; z-index: 9999;
    background: var(--bg); display: flex;
    align-items: center; justify-content: center;
  }
  .login-box {
    width: 320px; padding: 32px; border: 1px solid var(--line);
    border-radius: var(--radius); background: var(--paper);
    box-shadow: var(--shadow); text-align: center;
  }
  .login-box h2 { margin: 0 0 20px; color: var(--primary); }
  .login-box input {
    width: 100%; padding: 12px 14px; margin-bottom: 12px;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--paper); color: var(--ink);
    font-size: 15px; box-sizing: border-box;
  }
  .login-box input:focus { outline: none; border-color: var(--accent); }
  .admin-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .admin-card { padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--paper); }
  .admin-card h3 { margin: 0 0 14px; color: var(--primary); font-size: 16px; }
  .admin-stat { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--line); font-size: 14px; }
  .admin-stat:last-child { border-bottom: none; }
  .admin-stat span { color: var(--muted); }
  .admin-stat strong { color: var(--primary); }
  .admin-btn { display: block; padding: 10px 14px; margin-bottom: 8px; border: 1px solid var(--line); border-radius: var(--radius); font-size: 14px; color: var(--primary); font-weight: 650; transition: background .2s; }
  .admin-btn:hover { background: var(--accent-soft); }
  .todo-item { padding: 6px 0; font-size: 14px; color: var(--muted); }
</style>
</BaseLayout>
