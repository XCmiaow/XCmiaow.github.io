---
import BaseLayout from '../layouts/BaseLayout.astro';
import zh from '../data/zh.json';

const totalTbds = zh.competitions.filter((c) => c.details?.topic === 'TBD').length;
const compsFilled = zh.competitions.filter((c) => c.details?.topic && c.details.topic !== 'TBD').length;
const compsTotal = zh.competitions.length;
const edPct = 100;
const awardsPct = Math.min(Math.round((compsFilled / Math.max(compsTotal, 1)) * 100), 100);
---

<BaseLayout title="管理面板" lang="zh">
  <div id="login-screen">
    <div class="login-card">
      <div class="login-lock">🔐</div>
      <h2>管理验证</h2>
      <p style="color:var(--muted);font-size:14px;margin:0 0 16px">请输入密码进入管理面板</p>
      <input type="password" id="pw-input" placeholder="密码" />
      <button class="btn primary" id="login-btn" style="width:100%;justify-content:center;min-height:44px">进入</button>
      <p id="pw-error" style="color:#c00;font-size:13px;margin:8px 0 0;display:none">密码错误，请重试</p>
    </div>
  </div>

  <div id="admin-content" style="display:none">
    <div class="container" style="padding-top:30px">
      <div
        style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:24px"
      >
        <div>
          <h1 style="font-size:28px;color:var(--primary);margin:0">管理面板</h1>
          <p style="color:var(--muted);margin:4px 0 0">网站数据概览</p>
        </div>
        <a class="btn" href="/">← 返回首页</a>
      </div>

      <div class="admin-grid">
        <div class="card pad">
          <h3>📊 内容统计</h3>
          <div class="row"><span>奖项总数</span><b>{compsTotal}</b></div>
          <div class="row"><span>已填写详情</span><b>{compsFilled}</b></div>
          <div class="row"><span>待补充 TBD</span><b style="color:var(--accent)">{totalTbds}</b></div>
          <div class="meter-bar" style="margin-top:8px"><div class="meter-fill" style="width:{awardsPct}%"></div></div>
          <div style="text-align:right;font-size:12px;color:var(--muted);margin-top:3px">填写进度 {awardsPct}%</div>
        </div>

        <div class="card pad">
          <h3>⚡ 快捷操作</h3>
          <a class="admin-btn" href="/write/">✍️ 写新文章</a>
          <a class="admin-btn" href="/blog/">📖 查看博客</a>
          <a class="admin-btn" href="/">🏠 回首页</a>
        </div>

        <div class="card pad">
          <h3>🔗 外部链接</h3>
          <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io" target="_blank">📦 GitHub 仓库</a>
          <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io/actions" target="_blank"
            >🔄 Actions 构建</a
          >
          <a class="admin-btn" href="https://cloud.umami.is" target="_blank">📈 Umami 统计</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var btn = document.getElementById('login-btn');
    var input = document.getElementById('pw-input');
    var screen = document.getElementById('login-screen');
    var content = document.getElementById('admin-content');
    var errEl = document.getElementById('pw-error');
    if (!btn || !input || !screen || !content) return;

    function checkPw() {
      if (btoa(input.value) === 'MDYwNDIw') {
        screen.style.display = 'none';
        content.style.display = 'block';
      } else {
        errEl.style.display = 'block';
        input.value = '';
        input.focus();
      }
    }

    btn.onclick = checkPw;
    input.onkeydown = function (e) {
      if (e.key === 'Enter') checkPw();
    };
    input.onfocus = function () {
      errEl.style.display = 'none';
    };
  })();
</script>

<style>
  #login-screen {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .login-card {
    width: 320px;
    padding: 36px 32px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow);
    text-align: center;
  }
  .login-lock {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .login-card h2 {
    margin: 0 0 4px;
    color: var(--primary);
    font-size: 20px;
  }
  .login-card input {
    width: 100%;
    padding: 12px 14px;
    margin-bottom: 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    box-sizing: border-box;
  }
  .login-card input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 16px;
  }
  .card h3 {
    margin: 0 0 12px;
    color: var(--primary);
    font-size: 16px;
  }
  .row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    font-size: 14px;
    border-bottom: 1px solid var(--line);
  }
  .row:last-of-type {
    border-bottom: none;
  }
  .row span {
    color: var(--muted);
  }
  .meter-bar {
    height: 6px;
    background: var(--line);
    border-radius: 3px;
    overflow: hidden;
  }
  .meter-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--green));
    border-radius: 3px;
  }
  .admin-btn {
    display: block;
    padding: 10px 14px;
    margin-bottom: 8px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    color: var(--primary);
    font-weight: 650;
  }
  .admin-btn:hover {
    background: var(--accent-soft);
  }
</style>
