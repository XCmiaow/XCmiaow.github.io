---
import BaseLayout from '../layouts/BaseLayout.astro';
import zh from '../data/zh.json';
import en from '../data/en.json';

// Dashboard stats
const totalTbds = zh.competitions.filter(c => c.details?.topic === 'TBD').length;
const posts = ['hello-world','getting-started']; // would use getCollection in dev
const compiled = new Date().toISOString().split('T')[0];
const compsWithDetails = zh.competitions.filter(c => c.details?.topic && c.details.topic !== 'TBD').length;
const compsTotal = zh.competitions.length;
---

<BaseLayout title="管理面板" lang="zh">
<section style="padding:60px 0 20px"><div class="container">
  <h1 style="font-size:clamp(28px,4vw,40px);color:var(--primary);margin:0">管理面板</h1>
  <p style="color:var(--muted);margin-top:6px">仪表盘 · 写文章 · 内容管理</p>
</div></section>

<div id="login-screen">
  <div class="login-box">
    <h2>🔐 验证</h2>
    <input type="password" id="pw-input" placeholder="输入管理密码" onkeydown="if(event.key==='Enter')checkPw()" />
    <button class="btn primary" onclick="checkPw()" style="width:100%;justify-content:center">进入</button>
    <p id="pw-error" style="color:#c00;font-size:13px;margin:8px 0 0;display:none">密码错误</p>
  </div>
</div>

<div id="admin-content" style="display:none">
<section><div class="container">
  <!-- Tabs -->
  <div class="admin-tabs">
    <button class="admin-tab active" data-tab="dashboard">📊 概览</button>
    <button class="admin-tab" data-tab="write">✍️ 文章</button>
    <button class="admin-tab" data-tab="content">📝 内容</button>
    <button class="admin-tab" data-tab="competitions">📋 竞赛 </button>
    <button class="admin-tab" data-tab="tools">🔧 工具</button>
  </div>

  <!-- TAB: Dashboard -->
  <div class="tab-panel active" id="tab-dashboard">
    <div class="admin-grid">
      <div class="card pad">
        <h3>📊 内容完整度</h3>
        <div class="meter-row"><div class="meter-label"><span>教育信息</span><b>100%</b></div><div class="meter-bar"><div class="meter-fill" style="width:100%"></div></div></div>
        <div class="meter-row"><div class="meter-label"><span>奖项录入</span><b>{compsTotal} 项</b></div><div class="meter-bar"><div class="meter-fill" style="width:100%"></div></div></div>
        <div class="meter-row"><div class="meter-label"><span>竞赛详情</span><b>{compsWithDetails}/{compsTotal}</b></div><div class="meter-bar"><div class="meter-fill" style="width:{compsTotal > 0 ? (compsWithDetails/compsTotal*100) : 0}%"></div></div></div>
        <div class="meter-row"><div class="meter-label"><span>博客文章</span><b>{posts.length} 篇</b></div><div class="meter-bar"><div class="meter-fill" style="width:{Math.min(posts.length * 25, 100)}%"></div></div></div>
        <div class="admin-stat" style="margin-top:10px"><span>最后构建</span><b id="build-date">{compiled}</b></div>
      </div>

      <div class="card pad" id="github-card">
        <h3>🐙 GitHub 仓库</h3>
        <div class="admin-stat"><span>简历站</span><b id="gh-stars">-</b></div>
        <div class="admin-stat"><span>ChemAI Lab</span><b id="gh-chem-stars">-</b></div>
        <div class="admin-stat" style="border:none"><span>构建状态</span><b><img src="https://img.shields.io/github/actions/workflow/status/XCmiaow/XCmiaow.github.io/deploy.yml?branch=main&label=&style=flat-square" alt="build" style="vertical-align:middle"/></b></div>
      </div>

      <div class="card pad">
        <h3>📋 待办</h3>
        {totalTbds > 0 && <div class="todo-item">⚠️ <b>{totalTbds}</b> 个竞赛 TBD · <a href="#" id="goto-competitions">补全</a></div>}
        <div class="todo-item">✅ 数据完整性良好</div>
        <div id="gh-latest-commit" class="todo-item" style="font-size:12px;margin-top:8px;color:var(--muted)">加载最近提交...</div>
      </div>

      <div class="card pad" style="grid-column:1/-1">
        <h3>📈 访问统计</h3>
        <div id="umami-placeholder" style="padding:20px;text-align:center;color:var(--muted);border:1px dashed var(--line);border-radius:var(--radius)">
          <p style="margin:0 0 10px;font-size:15px">要显示 Umami 图表，请从 Umami 后台获取分享链接</p>
          <p style="font-size:13px">1. 打开 <a href="https://cloud.umami.is" target="_blank" rel="noopener">cloud.umami.is</a> → 选择站点 → Share</p>
          <p style="font-size:13px">2. 开启 "Enable share link" → 复制链接</p>
          <p style="font-size:13px">3. 在下方输入框粘贴，或联系我硬编码</p>
          <div style="display:flex;gap:8px;margin-top:12px;max-width:500px;margin-left:auto;margin-right:auto">
            <input id="umami-url" type="url" placeholder="https://cloud.umami.is/share/xxxxx/..." style="flex:1;padding:8px 12px;border:1px solid var(--line);border-radius:var(--radius);font-size:13px" />
            <button class="btn" id="umami-embed-btn">嵌入</button>
          </div>
        </div>
        <iframe id="umami-frame" style="width:100%;height:280px;border:none;border-radius:var(--radius);display:none" loading="lazy"></iframe>
      </div>
    </div>
  </div>

  <!-- TAB: Write -->
  <div class="tab-panel" id="tab-write">
    <div style="max-width:640px">
      <div class="field">
        <label for="post-lang">语言</label>
        <select id="post-lang"><option value="zh">中文</option><option value="en">English</option></select>
      </div>
      <div class="field">
        <label for="post-title">标题 *</label>
        <input id="post-title" type="text" placeholder="文章标题" />
      </div>
      <div class="field">
        <label for="post-desc">摘要</label>
        <input id="post-desc" type="text" placeholder="简短描述（可选）" />
      </div>
      <div class="field">
        <label for="post-tags">标签</label>
        <input id="post-tags" type="text" placeholder="用逗号分隔，如：有机化学,笔记" />
      </div>
      <div class="field">
        <label for="post-body">正文 * <span style="font-weight:400;color:var(--muted);font-size:13px">支持 Markdown</span></label>
        <textarea id="post-body" rows="12" placeholder="在这里写文章内容..."></textarea>
      </div>
      <div class="field">
        <label for="gh-token">GitHub Token</label>
        <input id="gh-token" type="password" placeholder="personal access token" />
        <p style="font-size:12px;color:var(--muted);margin:4px 0 0">仅需输入一次，保存在本地浏览器</p>
      </div>
      <div id="publish-status"></div>
      <button class="btn primary" id="publish-btn" type="button" style="width:100%;justify-content:center;min-height:48px">发布文章</button>
    </div>
  </div>

  <!-- TAB: Content Editor (full website text) -->
  <div class="tab-panel" id="tab-content">
    <p style="color:var(--muted);margin-bottom:16px">修改后点底部"保存"按钮，自动 commit 到 GitHub 并触发部署</p>

    <div class="admin-grid">
      <!-- Person -->
      <fieldset class="card pad"><legend>👤 个人信息</legend>
        <div class="field"><label>姓名 (zh)</label><input id="f-zh-person-name" value="{zh.person.name}" /></div>
        <div class="field"><label>Name (en)</label><input id="f-en-person-name" value="{en.person.name}" /></div>
        <div class="field"><label>签名 (zh)</label><input id="f-zh-tagline" value="{zh.person.tagline}" /></div>
        <div class="field"><label>Tagline (en)</label><input id="f-en-tagline" value="{en.person.tagline}" /></div>
      </fieldset>

      <!-- Education -->
      <fieldset class="card pad"><legend>🎓 教育</legend>
        <div class="field"><label>学校 (zh)</label><input id="f-zh-edu-school" value="{zh.education.school}" /></div>
        <div class="field"><label>School (en)</label><input id="f-en-edu-school" value="{en.education.school}" /></div>
        <div class="field"><label>专业 (zh)</label><input id="f-zh-edu-major" value="{zh.education.major}" /></div>
        <div class="field"><label>Major (en)</label><input id="f-en-edu-major" value="{en.education.major}" /></div>
        <div class="field"><label>年级</label><input id="f-zh-edu-year" value="{zh.education.year}" /></div>
        <div class="field"><label>GPA</label><input id="f-edu-gpa" value="3.60" /></div>
      </fieldset>

      <!-- About -->
      <fieldset class="card pad" style="grid-column:1/-1"><legend>📄 个人简介段落</legend>
        <p style="font-size:13px;color:var(--muted);margin:0 0 8px">三段文字，每段独立编辑</p>
        <div class="field"><label>第一段 (zh)</label><textarea id="f-zh-about-p1" rows="3">{zh.person.name}目前就读于{zh.education.school}{zh.education.college}{zh.education.major}...</textarea></div>
        <div class="field"><label>第二段 (zh)</label><textarea id="f-zh-about-p2" rows="3">在课堂之外，我花了大量时间在数学建模上...</textarea></div>
        <div class="field"><label>第三段 (zh)</label><textarea id="f-zh-about-p3" rows="3">进入大二后，我逐渐对计算化学产生了兴趣...</textarea></div>
      </fieldset>

      <!-- Highlights -->
      <fieldset class="card pad"><legend>✨ 核心亮点</legend>
        {zh.highlights.map((h, i) => (
          <div style="margin-bottom:10px;padding:8px;border:1px solid var(--line);border-radius:6px">
            <div class="field" style="margin-bottom:4px"><input id="f-zh-highlight-{i}-title" value="{h.title}" placeholder="标题" /></div>
            <div class="field" style="margin-bottom:0"><textarea id="f-zh-highlight-{i}-desc" rows="2" placeholder="描述">{h.desc}</textarea></div>
          </div>
        ))}
      </fieldset>

      <!-- Research Interests -->
      <fieldset class="card pad"><legend>🧪 研究兴趣</legend>
        <div class="field"><label>口号 (zh)</label><input id="f-zh-ri-tagline" value="{zh.researchInterests.tagline}" /></div>
        <div class="field"><label>Tagline (en)</label><input id="f-en-ri-tagline" value="{en.researchInterests.tagline}" /></div>
        <div class="field"><label>摘要 (zh)</label><textarea id="f-zh-ri-summary" rows="3">{zh.researchInterests.summary}</textarea></div>
        <div class="field"><label>Summary (en)</label><textarea id="f-en-ri-summary" rows="3">{en.researchInterests.summary}</textarea></div>
      </fieldset>

      <!-- Skills (compact) -->
      <fieldset class="card pad"><legend>💡 技能分类</legend>
        {zh.skills.map((s, i) => (
          <div style="margin-bottom:8px;padding:8px;border:1px solid var(--line);border-radius:6px">
            <div class="field" style="margin-bottom:4px"><input id="f-zh-skill-{i}-cat" value="{s.category}" placeholder="分类名" /></div>
            <div class="field" style="margin-bottom:0"><input id="f-zh-skill-{i}-desc" value="{s.desc}" placeholder="描述" /></div>
          </div>
        ))}
      </fieldset>

      <!-- Experience -->
      <fieldset class="card pad"><legend>🏢 学生工作</legend>
        {zh.experience.map((e, i) => (
          <div style="margin-bottom:8px;padding:8px;border:1px solid var(--line);border-radius:6px">
            <div class="field" style="margin-bottom:4px"><input id="f-zh-exp-{i}-title" value="{e.title}" /></div>
            <div class="field" style="margin-bottom:0"><input id="f-zh-exp-{i}-desc" value="{e.desc}" /></div>
          </div>
        ))}
      </fieldset>

      <!-- Projects -->
      <fieldset class="card pad"><legend>📌 项目</legend>
        {zh.projects.map((p, i) => (
          <div style="margin-bottom:8px;padding:8px;border:1px solid var(--line);border-radius:6px">
            <div class="field" style="margin-bottom:4px"><input id="f-zh-proj-{i}-title" value="{p.title}" /></div>
            <div class="field" style="margin-bottom:0"><textarea id="f-zh-proj-{i}-desc" rows="2">{p.desc}</textarea></div>
          </div>
        ))}
      </fieldset>
    </div>

    <div style="max-width:400px;margin:20px 0">
      <div class="field">
        <label for="content-token">GitHub Token</label>
        <input id="content-token" type="password" placeholder="personal access token" />
      </div>
      <button class="btn primary" id="content-save-btn" style="width:100%;justify-content:center;min-height:44px">💾 保存所有内容</button>
      <div id="content-status" style="margin-top:10px"></div>
      <p style="font-size:12px;color:var(--muted);margin-top:8px">保存后自动部署，1-2 分钟生效</p>
    </div>
  </div>

  <!-- TAB: Competitions -->
  <div class="tab-panel" id="tab-competitions">
    <div class="admin-grid">
      {zh.competitions.filter(c => !c.details?.topic || c.details.topic === 'TBD').map(c => (
      <div class="card pad comp-form" data-comp="{c.title}">
        <h4 style="margin:0 0 6px;color:var(--primary);font-size:15px">{c.title}</h4>
        <p style="font-size:13px;color:var(--muted);margin:0 0 10px">{c.note} · {c.year}</p>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-topic" type="text" placeholder="比赛题目" style="padding:8px 10px;font-size:13px" />
        </div>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-role" type="text" placeholder="你的角色（建模/编程/写作）" style="padding:8px 10px;font-size:13px" />
        </div>
        <div class="field" style="margin-bottom:8px">
          <input class="comp-model" type="text" placeholder="用到的模型/方法" style="padding:8px 10px;font-size:13px" />
        </div>
        <button class="btn comp-save-btn" style="width:100%;justify-content:center;font-size:13px;min-height:36px">暂存到本地</button>
      </div>
      ))}
    </div>
    {totalTbds === 0 && <p style="text-align:center;padding:40px;color:var(--muted)">✅ 所有竞赛详情已填写完毕</p>}
  </div>

  <!-- TAB: Tools -->
  <div class="tab-panel" id="tab-tools">
    <div class="admin-grid">
      <div class="card pad">
        <h3>📅 学期切换器</h3>
        <p style="font-size:14px;color:var(--muted);margin:4px 0 14px">当前：{zh.education.year}</p>
        <button class="btn" id="semester-btn" style="width:100%;justify-content:center;font-size:13px">升级到下学期</button>
      </div>
      <div class="card pad">
        <h3>🔗 外部链接</h3>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io" target="_blank">📦 GitHub 仓库</a>
        <a class="admin-btn" href="https://github.com/XCmiaow/XCmiaow.github.io/actions" target="_blank">🔄 Actions 构建</a>
        <a class="admin-btn" href="https://cloud.umami.is" target="_blank">📈 Umami 统计</a>
        <a class="admin-btn" href="/blog/">📖 博客列表</a>
        <a class="admin-btn" href="/">🏠 返回首页</a>
      </div>
    </div>
  </div>
</div></section>
</div>
</BaseLayout>

<script is:inline>
  // ===== DOM-ready event bindings =====
  document.addEventListener('DOMContentLoaded', function() {
    // Tab competition button
    var gt = document.getElementById('goto-competitions');
    if (gt) gt.addEventListener('click', function(e) { e.preventDefault(); switchTab('competitions'); });

    // Semester button
    var sem = document.getElementById('semester-btn');
    if (sem) sem.addEventListener('click', function() { alert('当前年级: 请通过 GitHub 编辑 data/zh.json'); });

    // Umami embed button
    var umamiBtn = document.querySelector('#umami-placeholder .btn');
    if (umamiBtn) umamiBtn.addEventListener('click', function() {
      var url = document.getElementById('umami-url').value;
      document.getElementById('umami-frame').src = url;
      this.textContent = '✅';
    });
  });

  // ===== Password check =====
  function checkPw() {
    var input = document.getElementById('pw-input');
    if (!input) return;
    var s = input.value || '';
    if (btoa(s) === 'MDYwNDIw') {
      document.getElementById('login-screen').style.display = 'none';
      var content = document.getElementById('admin-content');
      if (content) content.style.display = 'block';
      localStorage.setItem('admin-auth', '1');
    } else {
      var err = document.getElementById('pw-error');
      if (err) err.style.display = 'block';
    }
  }
  if (localStorage.getItem('admin-auth') === '1') {
    document.getElementById('login-screen').style.display = 'none';
    var content2 = document.getElementById('admin-content');
    if (content2) content2.style.display = 'block';
  }

  // ===== Tab switching =====
  function switchTab(name) {
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelector('.admin-tab[data-tab="' + name + '"]')?.classList.add('active');
    document.getElementById('tab-' + name)?.classList.add('active');
  }
  document.querySelectorAll('.admin-tab').forEach(function(tab) {
    tab.addEventListener('click', function() { switchTab(this.dataset.tab); });
  });

  // ===== Blog publish =====
  (function(){
    var savedToken = localStorage.getItem('gh-blog-token');
    var tokenInput = document.getElementById('gh-token');
    if (savedToken && tokenInput) tokenInput.value = savedToken;

    var btn = document.getElementById('publish-btn');
    if (!btn) return;
    btn.addEventListener('click', async function() {
      var title = document.getElementById('post-title').value.trim();
      var body = document.getElementById('post-body').value.trim();
      var lang = document.getElementById('post-lang').value;
      var desc = document.getElementById('post-desc').value.trim();
      var tags = document.getElementById('post-tags').value.split(',').map(function(t){return t.trim()}).filter(Boolean);
      var token = tokenInput.value.trim();
      var status = document.getElementById('publish-status');
      if (!title) { status.innerHTML = '<p style="color:var(--accent)">请输入标题</p>'; return; }
      if (!body) { status.innerHTML = '<p style="color:var(--accent)">请输入正文</p>'; return; }
      if (!token) { status.innerHTML = '<p style="color:var(--accent)">请输入 GitHub Token</p>'; return; }
      localStorage.setItem('gh-blog-token', token);
      status.innerHTML = '<p style="color:var(--muted)">发布中...</p>';
      btn.disabled = true;

      var slug = title.toLowerCase().replace(/[^\w\s一-鿿-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'').substring(0,80) || 'post';
      var frontmatter = '---\ntitle: "' + title + '"\ndescription: "' + (desc || '') + '"\ndate: ' + new Date().toISOString().split('T')[0] + '\nlang: ' + lang + '\ntags: [' + tags.map(function(t){return '"'+t+'"'}).join(',') + ']\ndraft: false\n---\n\n';
      var content = frontmatter + body;
      var encoded = btoa(unescape(encodeURIComponent(content)));
      var path = 'src/content/blog/' + slug + '.md';

      try {
        var res = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io/contents/' + path, {
          method: 'PUT',
          headers: { 'Authorization': 'token ' + token, 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: 'blog: add ' + slug, content: encoded, branch: 'main' })
        });
        if (res.ok) {
          status.innerHTML = '<p style="color:var(--green);font-weight:700">✅ 发布成功！正在自动部署...</p>';
          document.getElementById('post-title').value = '';
          document.getElementById('post-body').value = '';
          document.getElementById('post-desc').value = '';
          document.getElementById('post-tags').value = '';
        } else {
          var err = await res.json();
          status.innerHTML = '<p style="color:#c00">❌ 发布失败: ' + (err.message || '未知错误') + '</p>';
        }
      } catch(e) { status.innerHTML = '<p style="color:#c00">❌ 网络错误: ' + e.message + '</p>'; }
      btn.disabled = false;
    });
  })();

  // ===== GitHub stats & latest commit =====
  (async function(){
    try {
      var r = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io');
      var d = await r.json();
      document.getElementById('gh-stars').textContent = d.stargazers_count + ' ★';
    } catch(e) { document.getElementById('gh-stars').textContent = '—'; }
    try {
      var r2 = await fetch('https://api.github.com/repos/XCmiaow/chem-ai-lab');
      var d2 = await r2.json();
      document.getElementById('gh-chem-stars').textContent = d2.stargazers_count + ' ★';
    } catch(e) { document.getElementById('gh-chem-stars').textContent = '—'; }
    try {
      var r3 = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io/commits?per_page=1');
      var d3 = await r3.json();
      if (d3.length) {
        var msg = d3[0].commit.message.split('\n')[0];
        var date = new Date(d3[0].commit.committer.date).toLocaleDateString('zh-CN');
        document.getElementById('gh-latest-commit').innerHTML = '🔄 最近: ' + msg.substring(0,50) + ' · ' + date;
      }
    } catch(e) { document.getElementById('gh-latest-commit').textContent = '—'; }
  })();

  // ===== Content editor: save full zh.json =====
  (function(){
    var btn = document.getElementById('content-save-btn');
    if (!btn) return;
    var tokInp = document.getElementById('content-token');
    var saved = localStorage.getItem('gh-blog-token');
    if (saved && tokInp) tokInp.value = saved;

    function g(id){var e=document.getElementById(id);return e?e.value:''}

    btn.addEventListener('click', async function() {
      var token = tokInp.value.trim();
      if (!token) { document.getElementById('content-status').innerHTML = '<p style="color:var(--accent)">请输入 Token</p>'; return; }
      localStorage.setItem('gh-blog-token', token);
      document.getElementById('content-status').innerHTML = '<p style="color:var(--muted)">更新 zh.json...</p>';
      btn.disabled = true;

      try {
        // Fetch current zh.json
        var r = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io/contents/src/data/zh.json', {
          headers: { 'Authorization': 'token ' + token }
        });
        var d = await r.json();
        var sha = d.sha;
        var data = JSON.parse(decodeURIComponent(escape(atob(d.content))));

        // Person
        data.person.name = g('f-zh-person-name');
        data.person.tagline = g('f-zh-tagline');

        // Education
        data.education.school = g('f-zh-edu-school');
        data.education.major = g('f-zh-edu-major');
        data.education.year = g('f-zh-edu-year');

        // Highlights
        data.highlights.forEach(function(h, i){
          h.title = g('f-zh-highlight-' + i + '-title') || h.title;
          h.desc = g('f-zh-highlight-' + i + '-desc') || h.desc;
        });

        // Research interests
        if (data.researchInterests) {
          data.researchInterests.tagline = g('f-zh-ri-tagline');
          data.researchInterests.summary = g('f-zh-ri-summary');
        }

        // Skills
        data.skills.forEach(function(s, i){
          s.category = g('f-zh-skill-' + i + '-cat') || s.category;
          s.desc = g('f-zh-skill-' + i + '-desc') || s.desc;
        });

        // Experience
        data.experience.forEach(function(e, i){
          e.title = g('f-zh-exp-' + i + '-title') || e.title;
          e.desc = g('f-zh-exp-' + i + '-desc') || e.desc;
        });

        // Projects
        data.projects.forEach(function(p, i){
          p.title = g('f-zh-proj-' + i + '-title') || p.title;
          p.desc = g('f-zh-proj-' + i + '-desc') || p.desc;
        });

        // Save zh.json
        var encoded = btoa(unescape(encodeURIComponent(JSON.stringify(data, null, 2))));
        var putR = await fetch('https://api.github.com/repos/XCmiaow/XCmiaow.github.io/contents/src/data/zh.json', {
          method: 'PUT',
          headers: { 'Authorization': 'token ' + token, 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: 'admin: update zh.json', content: encoded, sha: sha, branch: 'main' })
        });
        if (!putR.ok) throw new Error((await putR.json()).message);

        document.getElementById('content-status').innerHTML = '<p style="color:var(--green);font-weight:700">✅ zh.json 保存成功！正在部署...</p>';
      } catch(e) {
        document.getElementById('content-status').innerHTML = '<p style="color:#c00">❌ 保存失败: ' + e.message + '</p>';
      }
      btn.disabled = false;
    });
  })();

  // ===== Competition TBD forms =====
  (function(){
    var forms = document.querySelectorAll('.comp-form');
    forms.forEach(function(form){
      var title = form.dataset.comp;
      var topicInp = form.querySelector('.comp-topic');
      var roleInp = form.querySelector('.comp-role');
      var modelInp = form.querySelector('.comp-model');
      var saveBtn = form.querySelector('.comp-save-btn');

      // Restore saved data
      var saved = localStorage.getItem('comp-' + title);
      if (saved) {
        var data = JSON.parse(saved);
        if (data.topic) topicInp.value = data.topic;
        if (data.role) roleInp.value = data.role;
        if (data.model) modelInp.value = data.model;
      }

      saveBtn.addEventListener('click', function() {
        localStorage.setItem('comp-' + title, JSON.stringify({
          topic: topicInp.value, role: roleInp.value, model: modelInp.value
        }));
        saveBtn.textContent = '✅ 已暂存';
        setTimeout(function(){ saveBtn.textContent = '暂存到本地'; }, 2000);
      });
    });
  })();
</script>

