---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Local Blog Composer" lang="en">
  <section class="hero" style="padding:60px 0 20px">
    <div class="container">
      <h1 style="font-size:clamp(28px,4vw,40px);color:var(--primary);margin:0">Local Blog Composer</h1>
      <p style="color:var(--muted);margin-top:6px">
        Generate a Markdown post locally, then commit and push it with git.
      </p>
    </div>
  </section>

  <section>
    <div class="container composer-shell">
      <div id="form-area">
        <div class="field">
          <label for="post-lang">Language</label>
          <select id="post-lang">
            <option value="zh">Chinese</option>
            <option value="en">English</option>
          </select>
        </div>
        <div class="field">
          <label for="post-title">Title *</label>
          <input id="post-title" type="text" placeholder="Post title" />
        </div>
        <div class="field">
          <label for="post-desc">Description</label>
          <input id="post-desc" type="text" placeholder="Short summary" />
        </div>
        <div class="field">
          <label for="post-tags">Tags</label>
          <input id="post-tags" type="text" placeholder="Comma separated tags" />
        </div>
        <div class="field">
          <label for="post-body">Body * <span>Markdown supported</span></label>
          <textarea id="post-body" rows="12" placeholder="Write the post body here..."></textarea>
        </div>
        <div id="status"></div>
        <div class="actions">
          <button class="btn primary" id="generate-btn" type="button">Generate Markdown</button>
          <button class="btn" id="copy-btn" type="button" disabled>Copy</button>
          <button class="btn" id="download-btn" type="button" disabled>Download</button>
        </div>
      </div>

      <aside class="preview-panel" aria-live="polite">
        <div class="output-meta">
          <span id="post-path">src/content/blog/post.md</span>
        </div>
        <textarea id="post-output" readonly placeholder="Generated Markdown appears here."></textarea>
      </aside>
    </div>
  </section>
</BaseLayout>

<script type="module" is:inline>
  import { composeBlogPost } from '/src/tools/blogComposer.js';

  const state = { post: null };
  const fields = {
    lang: document.getElementById('post-lang'),
    title: document.getElementById('post-title'),
    desc: document.getElementById('post-desc'),
    tags: document.getElementById('post-tags'),
    body: document.getElementById('post-body'),
    path: document.getElementById('post-path'),
    output: document.getElementById('post-output'),
    copy: document.getElementById('copy-btn'),
    download: document.getElementById('download-btn'),
  };

  function setStatus(message, type) {
    const status = document.getElementById('status');
    if (!status) return;
    status.textContent = message;
    status.className = type ? `status-${type}` : '';
  }

  function updateOutput(post) {
    state.post = post;
    fields.path.textContent = post.path;
    fields.output.value = post.content;
    fields.copy.disabled = false;
    fields.download.disabled = false;
  }

  document.getElementById('generate-btn').addEventListener('click', () => {
    try {
      const post = composeBlogPost({
        title: fields.title.value,
        body: fields.body.value,
        lang: fields.lang.value,
        description: fields.desc.value,
        tags: fields.tags.value,
      });
      updateOutput(post);
      setStatus(`Ready: ${post.path}`, 'success');
    } catch (error) {
      setStatus(error.message || 'Unable to generate post', 'warn');
    }
  });

  fields.copy.addEventListener('click', async () => {
    if (!state.post) return;
    await navigator.clipboard.writeText(state.post.content);
    setStatus('Copied Markdown to clipboard.', 'success');
  });

  fields.download.addEventListener('click', () => {
    if (!state.post) return;
    const blob = new Blob([state.post.content], { type: 'text/markdown;charset=utf-8' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = state.post.filename;
    link.click();
    URL.revokeObjectURL(link.href);
  });
</script>

<style>
  .composer-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .field {
    margin-bottom: 20px;
  }

  .field label {
    display: block;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 6px;
    font-size: 14px;
  }

  .field label span {
    font-weight: 400;
    color: var(--muted);
    font-size: 13px;
  }

  .field input,
  .field textarea,
  .field select,
  #post-output {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus,
  #post-output:focus {
    outline: none;
    border-color: var(--accent);
  }

  .field textarea {
    resize: vertical;
    min-height: 220px;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .actions .btn {
    min-height: 44px;
  }

  .actions .btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .preview-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--card);
    padding: 14px;
  }

  .output-meta {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 8px;
    overflow-wrap: anywhere;
  }

  #post-output {
    min-height: 520px;
    resize: vertical;
    line-height: 1.55;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  #status {
    margin: 12px 0;
    font-size: 15px;
  }

  #status:empty {
    margin: 0;
  }

  #status.status-warn {
    color: var(--accent);
  }

  #status.status-success {
    color: var(--green);
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .composer-shell {
      grid-template-columns: 1fr;
    }

    #post-output {
      min-height: 320px;
    }
  }
</style>
