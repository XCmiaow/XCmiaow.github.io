---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProfile } from '../../lib/resumeData';
import type { SiteLang } from '../../data/resumeCatalog';

interface Props {
  lang: SiteLang;
}

const { lang } = Astro.props;
const data = getProfile(lang);
const isZh = lang === 'zh';
const base = isZh ? '' : '/en';
const copy = isZh
  ? {
      title: `${data.person.name} | 林产化工本科生 | 数学建模与 AI 工具链`,
      description: `${data.person.name}，${data.education.school}${data.education.major}本科生，GPA ${data.education.gpa}。`,
      context: `${data.education.school} · ${data.education.college} · ${data.education.major}`,
      subtitle: '面向化工问题的建模、表达与 AI 工具链实践者',
      lead: `GPA ${data.education.gpa}，班级第 ${data.education.rankClass}，专业第 ${data.education.rankMajor}。以化学与工程基础为根，以建模、编程和 AI 工具拓展科研工作流。`,
      about: '个人简介',
      education: '教育背景',
      honors: '获奖与荣誉',
      skills: '技能结构',
      projects: '项目与实践',
      experience: '学生工作与服务',
      research: '研究兴趣',
      evidence: '查看证明材料',
      materials: '材料中心',
      generalResume: '通用一页简历',
      abilities: '能力',
      contact: '公开联系',
      level: { international: '国际', national: '国家', provincial: '省级', university: '校级', college: '院级' },
    }
  : {
      title: `${data.person.name} | Chemical Engineering | Modeling & AI Workflows`,
      description: `${data.person.name}, ${data.education.major} undergraduate at ${data.education.school}, GPA ${data.education.gpa}.`,
      context: `${data.education.major} · ${data.education.college} · ${data.education.school}`,
      subtitle: 'Modeling, research communication, and AI-assisted workflows for chemical problems',
      lead: `GPA ${data.education.gpa}, ranked ${data.education.rankClass}st in class and ${data.education.rankMajor}nd in major. Building from chemistry and engineering fundamentals toward modeling, programming, and AI-assisted research workflows.`,
      about: 'About',
      education: 'Education',
      honors: 'Awards & Honors',
      skills: 'Skills',
      projects: 'Projects & Practice',
      experience: 'Leadership & Service',
      research: 'Research Interests',
      evidence: 'View evidence',
      materials: 'Materials hub',
      generalResume: 'General resume',
      abilities: 'Capabilities',
      contact: 'Public contact',
      level: {
        international: 'International',
        national: 'National',
        provincial: 'Provincial',
        university: 'University',
        college: 'College',
      },
    };
---

<BaseLayout title={copy.title} description={copy.description} lang={lang}>
  <section class="hero" id="about">
    <div class="container profile-hero">
      <div>
        <p class="eyebrow">{copy.context}</p>
        <h1>{data.person.name}</h1>
        <p class="subtitle">{copy.subtitle}</p>
        <p class="lead">{copy.lead}</p>
        <div class="hero-actions no-print">
          <a class="btn primary" href="#honors">{copy.honors}</a>
          <a class="btn" href={`${base}/resume-onepage`}>{copy.generalResume}</a>
          <a class="btn" href={`${base}/materials`}>{copy.materials}</a>
        </div>
      </div>
      <aside class="profile-card">
        <img src={data.person.avatar} alt={data.person.name} loading="eager" />
        <strong>{data.person.name}</strong>
        <span>{data.person.tagline}</span>
        <a href={`mailto:${data.person.email}`}>{data.person.email}</a>
        <a href={`https://${data.person.github}`}>{data.person.github}</a>
      </aside>
    </div>
  </section>

  <div class="container profile-sections">
    <section id="education">
      <h2>{copy.education}</h2>
      <article class="panel">
        <h3>{data.education.school} · {data.education.college}</h3>
        <p>{data.education.major} · {data.education.degree} · {data.education.period}</p>
        <p>
          GPA {data.education.gpa} · {isZh ? '班级第' : 'Class rank'}
          {data.education.rankClass} · {isZh ? '专业第' : 'Major rank'}
          {data.education.rankMajor}
        </p>
      </article>
    </section>

    <section id="honors">
      <div class="section-line"><h2>{copy.honors}</h2><a href={`${base}/evidence`}>{copy.evidence}</a></div>
      <div class="card-grid">
        {
          data.achievements.map((item) => (
            <article class="panel">
              <p class="eyebrow">
                {item.period} · {copy.level[item.level]}
              </p>
              <>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>

    <section id="skills">
      <h2>{copy.skills}</h2>
      <div class="card-grid">
        {
          data.skills.map((item) => (
            <article class="panel">
              <>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <p class="tags">{item.items.join(' · ')}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>

    <section id="projects">
      <h2>{copy.projects}</h2>
      <div class="card-grid">
        {
          data.projects.map((item) => (
            <article class="panel">
              <>
                <h3>
                  <a href={item.href}>{item.title}</a>
                </h3>
                <p>{item.summary}</p>
                <p>
                  <strong>{copy.abilities}：</strong>
                  {item.abilities}
                </p>
                <p class="tags">{item.tags.join(' · ')}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>

    <section id="experience">
      <h2>{copy.experience}</h2>
      <div class="card-grid">
        {
          data.experience.map((item) => (
            <article class="panel">
              <>
                <p class="eyebrow">{item.period}</p>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </>
            </article>
          ))
        }
      </div>
      <ul>{data.service.map((item) => <li>{item.summary}</li>)}</ul>
    </section>

    <section id="research">
      <h2>{copy.research}</h2>
      <p class="lead">{data.research.tagline}</p><p>{data.research.summary}</p>
      <div class="card-grid">
        {
          data.research.areas.map((item) => (
            <article class="panel">
              <>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contact">
      <h2>{copy.contact}</h2>
      <div class="panel contact-links">
        <a href={`mailto:${data.person.email}`}>{data.person.email}</a>
        <a href={`https://${data.person.github}`} rel="me">{data.person.github}</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .profile-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 2rem;
    align-items: center;
  }
  .profile-card,
  .panel {
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--surface);
    padding: 1.25rem;
  }
  .profile-card {
    display: grid;
    gap: 0.65rem;
  }
  .profile-card img {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
  }
  .profile-sections {
    display: grid;
    gap: 3rem;
    padding-block: 2.5rem 5rem;
  }
  .section-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .panel h3 {
    margin-top: 0;
  }
  .panel h3 a {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
  }
  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }
  .eyebrow,
  .tags {
    color: var(--secondary);
    font-size: 0.9rem;
  }
  @media (max-width: 720px) {
    .profile-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
