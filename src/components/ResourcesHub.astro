---
import { getResourceIndexGroups } from '../data/siliconAshesResources';
import type { SiliconEmbersLang } from '../data/siliconEmbersHome';

export interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const groups = getResourceIndexGroups(lang);
---

<div class="resources-index">
  <header class="resources-head">
    <h1>{isZh ? '资源' : 'Resources'}</h1>
  </header>

  <div class="resource-groups">
    {
      groups.map((group, index) => (
        <section id={group.id} class="resource-group" aria-labelledby={`resource-group-${index + 1}`}>
          <div class="group-copy">
            <h2 id={`resource-group-${index + 1}`}>{group.title}</h2>
            <p>{group.summary}</p>
          </div>

          <div class="resource-list">
            {group.items.map((item) => (
              <a
                class="resource-row"
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >
                <span class="resource-copy">
                  <strong>{item.title}</strong>
                  <small>{item.summary}</small>
                </span>
                <span class="resource-meta">
                  {item.meta.map((meta) => (
                    <em>{meta}</em>
                  ))}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</div>

<style>
  .resources-index {
    padding-bottom: clamp(76px, 9vw, 116px);
  }

  .resources-head {
    border-bottom: 1px solid var(--line);
    padding: clamp(64px, 9vw, 108px) 0 clamp(34px, 5vw, 58px);
  }

  h1,
  h2 {
    margin: 0;
    color: var(--paper);
    font-family: var(--font-display);
    font-weight: 850;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    line-height: 0.96;
  }

  .resource-groups {
    display: grid;
  }

  .resource-group {
    display: grid;
    grid-template-columns: minmax(170px, 0.26fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 72px);
    scroll-margin-top: 96px;
    border-bottom: 1px solid var(--line);
    padding: clamp(34px, 6vw, 64px) 0;
  }

  .group-copy {
    display: grid;
    align-content: start;
    gap: 12px;
  }

  .group-copy h2 {
    font-size: clamp(1.7rem, 3vw, 2.8rem);
    line-height: 1.05;
  }

  .group-copy p {
    max-width: 20rem;
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.68;
  }

  .resource-list {
    display: grid;
    border-top: 1px solid rgba(232, 174, 98, 0.18);
  }

  .resource-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(150px, auto);
    gap: 18px;
    align-items: center;
    border-bottom: 1px solid rgba(232, 174, 98, 0.16);
    padding: 16px 0;
    color: inherit;
    text-decoration: none;
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .resource-row:hover,
  .resource-row:focus-visible {
    transform: translateX(2px);
    color: var(--paper);
    outline: none;
  }

  .resource-copy {
    display: grid;
    gap: 7px;
    min-width: 0;
  }

  .resource-copy strong {
    color: var(--paper);
    font-family: var(--font-display);
    font-size: clamp(1.02rem, 1.55vw, 1.32rem);
    line-height: 1.3;
  }

  .resource-copy small {
    max-width: 46rem;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.62;
  }

  .resource-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
  }

  .resource-meta em {
    border: 1px solid rgba(168, 177, 176, 0.2);
    border-radius: 4px;
    padding: 5px 9px;
    color: var(--muted);
    font-size: 12px;
    font-style: normal;
  }

  @media (max-width: 720px) {
    .resources-head {
      padding: 34px 0 26px;
    }

    h1 {
      font-size: clamp(2rem, 11vw, 3.3rem);
    }

    .resource-group {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 30px 0;
    }

    .group-copy h2 {
      font-size: clamp(1.32rem, 6vw, 1.72rem);
    }

    .group-copy p,
    .resource-copy small {
      font-size: 13px;
      line-height: 1.6;
    }

    .resource-row {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 15px 0;
    }

    .resource-meta {
      justify-content: flex-start;
    }
  }
</style>
