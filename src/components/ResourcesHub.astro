---
import common from '../data/common.json';

export interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const homeHref = isZh ? '/silicon-ashes/' : '/en/silicon-ashes/';
const writingHref = isZh ? '/silicon-ashes/writing/' : '/en/silicon-ashes/writing/';
const coursesHref = isZh ? '/silicon-ashes/courses/' : '/en/silicon-ashes/courses/';
const aboutHref = isZh ? '/silicon-ashes/about/' : '/en/silicon-ashes/about/';
const email = common.person.email;

const courseBase = '/silicon-ashes/courses/ai-research-efficiency/';

const t = isZh
  ? {
      brand: '硅基余烬',
      htmlLabel: '资源与工具',
      nav: [
        ['主站', homeHref],
        ['写作', writingHref],
        ['课程', coursesHref],
        ['关于', aboutHref],
      ],
      eyebrow: 'resources',
      title: '资源不是仓库，是工作流的入口',
      lead: '把课程、写作和日常实践里会反复用到的工具、模板、清单放在这里。',
      featuredTitle: '优先使用',
      featured: [
        {
          title: 'AI 科研效率课程讲义',
          body: '适合先通读一遍，理解工具链如何从零散按钮变成完整工作流。',
          meta: ['PDF', '课程配套'],
          href: `${courseBase}course-handout.pdf`,
        },
        {
          title: '工具链实操页',
          body: 'WorkBuddy、Claude Code、Codex、DeepSeek、GitHub 的最小可用路径。',
          meta: ['网页', '实操'],
          href: `${courseBase}toolchain.html`,
        },
        {
          title: '课程参考资料',
          body: '把前置概念、进阶阅读和可复查材料集中到一处。',
          meta: ['网页', '索引'],
          href: `${courseBase}reference.html`,
        },
      ],
      groupsTitle: '资源分层',
      groups: [
        {
          index: '01',
          title: '工具入口',
          body: '不追新工具，先建立稳定组合：一个写作工具、一个编程代理、一个模型入口、一个版本库。',
          items: ['WorkBuddy', 'Claude Code', 'Codex', 'DeepSeek', 'GitHub'],
        },
        {
          index: '02',
          title: '模板与清单',
          body: '给非计算机背景使用者准备的最小模板：任务说明、Prompt、验收、复盘。',
          items: ['任务说明模板', 'Prompt 模板', '验收清单', '课程复盘表'],
        },
        {
          index: '03',
          title: '学习路线',
          body: '从 AI 基础、LLM 概念、网络基础、Git 部署到科研加速，按顺序补齐底层知识。',
          items: ['AI 发展史', 'LLM 基础', '网络基础', 'Git 部署', '科研加速'],
        },
        {
          index: '04',
          title: '写作与表达',
          body: '把工具使用转成可传播的方法：文章、讲义、课程页、项目案例。',
          items: ['写作中心', '课程讲义', '项目案例', '方法复盘'],
        },
      ],
      routeTitle: '推荐进入顺序',
      route: [
        ['先看讲义', '快速建立全局地图。'],
        ['再做工具链', '把账号、代理、编辑器和 Git 跑通。'],
        ['最后读写作', '用真实问题反推方法。'],
      ],
      footerNote: '硅基余烬 · 资源与工具',
    }
  : {
      brand: 'Silicon Ashes',
      htmlLabel: 'Resources and tools',
      nav: [
        ['Main', homeHref],
        ['Writing', writingHref],
        ['Courses', coursesHref],
        ['About', aboutHref],
      ],
      eyebrow: 'resources',
      title: 'Resources are workflow entry points',
      lead: 'Tools, templates, checklists, and course materials used repeatedly across the site.',
      featuredTitle: 'Start here',
      featured: [
        {
          title: 'AI research efficiency handout',
          body: 'Read this first to see how scattered tools become a working system.',
          meta: ['PDF', 'Course'],
          href: `${courseBase}course-handout.pdf`,
        },
        {
          title: 'Toolchain practice',
          body: 'The minimum usable path for WorkBuddy, Claude Code, Codex, DeepSeek, and GitHub.',
          meta: ['Web', 'Practice'],
          href: `${courseBase}toolchain.html`,
        },
        {
          title: 'Course reference',
          body: 'A central index for prerequisite concepts, deeper reading, and review materials.',
          meta: ['Web', 'Index'],
          href: `${courseBase}reference.html`,
        },
      ],
      groupsTitle: 'Resource layers',
      groups: [
        {
          index: '01',
          title: 'Tool entry points',
          body: 'Do not chase every new tool. Build a stable set: writing tool, coding agent, model gateway, and repository.',
          items: ['WorkBuddy', 'Claude Code', 'Codex', 'DeepSeek', 'GitHub'],
        },
        {
          index: '02',
          title: 'Templates and checklists',
          body: 'Small templates for non-CS users: task briefs, prompts, review checklists, and retrospectives.',
          items: ['Task brief', 'Prompt template', 'Review checklist', 'Course retrospective'],
        },
        {
          index: '03',
          title: 'Learning route',
          body: 'AI basics, LLM concepts, networking, Git deployment, and research acceleration in sequence.',
          items: ['AI history', 'LLM basics', 'Networking', 'Git deployment', 'Research acceleration'],
        },
        {
          index: '04',
          title: 'Writing and expression',
          body: 'Turn tool usage into shareable methods: articles, handouts, course pages, and project cases.',
          items: ['Writing center', 'Course handout', 'Project cases', 'Method notes'],
        },
      ],
      routeTitle: 'Recommended path',
      route: [
        ['Read the handout', 'Build the map first.'],
        ['Run the toolchain', 'Connect accounts, proxy, editor, and Git.'],
        ['Then read the essays', 'Let real tasks test the method.'],
      ],
      footerNote: 'Silicon Ashes · Resources',
    };
---

<div class="rh-shell">
  <a class="skip-link" href="#main">{isZh ? '跳到正文' : 'Skip to content'}</a>

  <header class="rh-nav" aria-label={t.htmlLabel}>
    <a class="rh-brand" href={homeHref} aria-label={t.brand}>
      <span class="brand-mark">SA</span>
      <span class="brand-name">{t.brand}</span>
    </a>
    <nav aria-label={isZh ? '资源页导航' : 'Resources navigation'}>
      {t.nav.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </header>

  <main id="main">
    <section class="hero" aria-labelledby="resources-title">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1 id="resources-title">{t.title}</h1>
      <p class="lead">{t.lead}</p>
    </section>

    <section class="featured" aria-labelledby="featured-title">
      <div class="section-head">
        <p class="kicker">selected</p>
        <h2 id="featured-title">{t.featuredTitle}</h2>
      </div>
      <div class="featured-grid">
        {t.featured.map((item) => (
          <a class="featured-card" href={item.href}>
            <div class="resource-meta">
              {item.meta.map((meta) => <span>{meta}</span>)}
            </div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="groups" aria-labelledby="groups-title">
      <div class="section-head wide">
        <p class="kicker">layers</p>
        <h2 id="groups-title">{t.groupsTitle}</h2>
      </div>
      <div class="group-ledger">
        {t.groups.map((group) => (
          <article>
            <span class="group-index">{group.index}</span>
            <div>
              <h3>{group.title}</h3>
              <p>{group.body}</p>
            </div>
            <ul>
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="route" aria-labelledby="route-title">
      <div class="section-head wide">
        <p class="kicker">route</p>
        <h2 id="route-title">{t.routeTitle}</h2>
      </div>
      <ol class="route-list">
        {t.route.map(([title, body]) => (
          <li>
            <h3>{title}</h3>
            <p>{body}</p>
          </li>
        ))}
      </ol>
    </section>
  </main>

  <footer class="rh-footer">
    <p>{t.footerNote}</p>
    <div>
      <a href={`mailto:${email}`}>Email</a>
      <a href={writingHref}>{isZh ? '写作' : 'Writing'}</a>
    </div>
  </footer>
</div>

<style>
  :global(html) {
    scroll-behavior: smooth;
    background: #080705;
  }

  :global(body) {
    margin: 0;
    background: #080705;
    color: #e9e0d0;
    font-family: 'Satoshi', 'Avenir Next', 'Segoe UI', 'Microsoft YaHei', sans-serif;
  }

  :global(*),
  :global(*::before),
  :global(*::after) {
    box-sizing: border-box;
  }

  :global(a) {
    color: inherit;
  }

  .rh-shell {
    min-height: 100dvh;
    overflow-x: hidden;
    background:
      linear-gradient(90deg, rgba(226, 187, 116, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(226, 187, 116, 0.028) 1px, transparent 1px),
      linear-gradient(112deg, transparent 0 58%, rgba(168, 103, 38, 0.08) 58.2%, transparent 58.5%),
      linear-gradient(180deg, #080705 0%, #0e0d0b 42%, #070706 100%);
    background-size:
      64px 64px,
      64px 64px,
      auto,
      auto;
  }

  .skip-link {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 20;
    transform: translateY(-160%);
    border: 1px solid #d6a04f;
    border-radius: 4px;
    padding: 10px 12px;
    background: #e3b66c;
    color: #100d09;
    font-weight: 800;
    text-decoration: none;
    transition: transform 180ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .rh-nav,
  main,
  .rh-footer {
    width: min(100% - 44px, 1240px);
    margin: 0 auto;
  }

  .rh-nav {
    position: sticky;
    top: 0;
    z-index: 12;
    display: flex;
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid rgba(218, 166, 86, 0.2);
    background: rgba(8, 7, 5, 0.86);
    backdrop-filter: blur(18px);
  }

  .rh-brand {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid rgba(218, 166, 86, 0.7);
    border-radius: 5px;
    background: linear-gradient(135deg, rgba(238, 181, 92, 0.22), transparent 50%), #11100d;
    color: #ffe4aa;
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 900;
  }

  .brand-name {
    color: #f3e3c5;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: 20px;
    font-weight: 800;
  }

  .rh-nav nav {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .rh-nav nav a {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    border-radius: 4px;
    padding: 0 10px;
    color: rgba(233, 224, 208, 0.72);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 160ms ease,
      color 160ms ease;
  }

  .rh-nav nav a:hover,
  .rh-nav nav a:focus-visible {
    background: rgba(218, 166, 86, 0.1);
    color: #ffe2aa;
    outline: none;
  }

  .hero {
    max-width: 920px;
    padding: 100px 0 62px;
  }

  .eyebrow,
  .kicker {
    margin: 0;
    color: #d8aa63;
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 800;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2 {
    margin: 0;
    color: #f2dfbd;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', 'Times New Roman', serif;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.06;
    text-wrap: balance;
  }

  h1 {
    max-width: 880px;
    margin-top: 22px;
    font-size: clamp(3.2rem, 5.8vw, 5rem);
  }

  .lead {
    max-width: 720px;
    margin: 26px 0 0;
    color: rgba(233, 224, 208, 0.76);
    font-size: 20px;
    line-height: 1.88;
    text-wrap: pretty;
  }

  .featured,
  .groups,
  .route {
    border-top: 1px solid rgba(218, 166, 86, 0.18);
    padding: 76px 0;
  }

  .section-head h2 {
    margin-top: 14px;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
  }

  .section-head.wide {
    max-width: 860px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 36px;
  }

  .featured-card {
    min-height: 260px;
    border: 1px solid rgba(218, 166, 86, 0.22);
    border-radius: 8px;
    padding: 26px;
    background:
      linear-gradient(135deg, rgba(216, 170, 99, 0.1), transparent 44%),
      rgba(13, 12, 10, 0.78);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .featured-card:hover,
  .featured-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(241, 223, 189, 0.42);
    background:
      linear-gradient(135deg, rgba(216, 170, 99, 0.14), transparent 44%),
      rgba(13, 12, 10, 0.92);
    outline: none;
  }

  .resource-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .resource-meta span,
  .group-ledger li {
    border: 1px solid rgba(168, 177, 176, 0.2);
    border-radius: 4px;
    padding: 5px 9px;
    color: rgba(220, 228, 224, 0.68);
    font-size: 13px;
  }

  h3 {
    margin: 0;
    color: #f2dfbd;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: 24px;
    font-weight: 800;
    line-height: 1.24;
  }

  .featured-card p,
  .group-ledger p,
  .route-list p,
  .rh-footer p {
    color: rgba(233, 224, 208, 0.72);
    line-height: 1.78;
  }

  .featured-card p {
    margin: 16px 0 0;
    font-size: 16px;
  }

  .group-ledger {
    display: grid;
    margin-top: 42px;
    border-top: 1px solid rgba(218, 166, 86, 0.2);
  }

  .group-ledger article {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr) minmax(260px, 0.36fr);
    gap: 32px;
    align-items: start;
    border-bottom: 1px solid rgba(218, 166, 86, 0.2);
    padding: 30px 0;
  }

  .group-index {
    color: #a8b1b0;
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 14px;
    font-weight: 800;
  }

  .group-ledger p {
    max-width: 720px;
    margin: 12px 0 0;
    font-size: 16px;
  }

  .group-ledger ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .route-list {
    counter-reset: step;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin: 34px 0 0;
    padding: 1px;
    background: rgba(218, 166, 86, 0.18);
    list-style: none;
  }

  .route-list li {
    min-height: 170px;
    padding: 24px;
    background: rgba(14, 13, 11, 0.94);
    counter-increment: step;
  }

  .route-list li::before {
    content: '0' counter(step);
    display: block;
    margin-bottom: 18px;
    color: #d8aa63;
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 900;
  }

  .route-list p {
    margin: 10px 0 0;
  }

  .rh-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: start;
    border-top: 1px solid rgba(218, 166, 86, 0.18);
    padding: 28px 0 40px;
  }

  .rh-footer p {
    max-width: 560px;
    margin: 0;
    font-size: 14px;
  }

  .rh-footer div {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
  }

  .rh-footer a {
    display: inline-flex;
    min-height: 36px;
    min-width: 36px;
    align-items: center;
    color: rgba(233, 224, 208, 0.72);
    font-size: 14px;
    text-decoration: none;
  }

  .rh-footer a:hover {
    color: #f2dfbd;
  }

  @media (max-width: 960px) {
    .featured-grid,
    .route-list {
      grid-template-columns: 1fr;
    }

    .group-ledger article {
      grid-template-columns: 56px 1fr;
    }

    .group-ledger ul {
      grid-column: 2;
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .rh-nav,
    main,
    .rh-footer {
      width: min(100% - 28px, 1240px);
    }

    .rh-nav {
      position: static;
      flex-direction: column;
      align-items: flex-start;
      padding: 14px 0;
    }

    .rh-nav nav {
      width: 100%;
      flex-wrap: wrap;
    }

    .hero {
      padding: 58px 0 42px;
    }

    h1 {
      font-size: 2.75rem;
    }

    .featured,
    .groups,
    .route {
      padding: 54px 0;
    }

    .featured-card {
      min-height: auto;
      padding: 22px;
    }

    .group-ledger article {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .group-ledger ul {
      grid-column: auto;
    }

    .rh-footer {
      grid-template-columns: 1fr;
    }

    .rh-footer div {
      justify-content: flex-start;
    }
  }
</style>
