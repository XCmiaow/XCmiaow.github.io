---
interface LightboxItem {
  src: string;
  alt: string;
}

interface Props {
  items: LightboxItem[];
  label: string;
  closeLabel: string;
  previousLabel: string;
  nextLabel: string;
}

const { items, label, closeLabel, previousLabel, nextLabel } = Astro.props;
const fallbackSrc = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
const serializedItems = JSON.stringify(items).replace(/</g, '\\u003c');
---

<dialog class="lightbox" id="lightbox" aria-label={label}>
  <button class="lightbox-close" id="lb-close" type="button" aria-label={closeLabel}>✕</button>
  <button class="lightbox-nav lightbox-prev" id="lb-prev" type="button" aria-label={previousLabel}>‹</button>
  <button class="lightbox-nav lightbox-next" id="lb-next" type="button" aria-label={nextLabel}>›</button>
  <div class="lightbox-image-wrap">
    <img id="lb-img" src={fallbackSrc} alt="" />
  </div>
  <div class="lightbox-counter" id="lb-counter" role="status" aria-live="polite"></div>
</dialog>

<div id="lightbox-items" data-items={serializedItems} hidden></div>

<script>
  (function () {
    const config = document.getElementById('lightbox-items');
    const dialog = document.getElementById('lightbox');
    const img = document.getElementById('lb-img');
    const closeButton = document.getElementById('lb-close');
    const previousButton = document.getElementById('lb-prev');
    const nextButton = document.getElementById('lb-next');
    const counter = document.getElementById('lb-counter');
    if (
      !config ||
      !(dialog instanceof HTMLDialogElement) ||
      !(img instanceof HTMLImageElement) ||
      !(closeButton instanceof HTMLButtonElement) ||
      !(previousButton instanceof HTMLButtonElement) ||
      !(nextButton instanceof HTMLButtonElement) ||
      !(counter instanceof HTMLElement)
    )
      return;

    const items: Array<{ src: string; alt: string }> = JSON.parse(config.getAttribute('data-items') ?? '[]');
    if (items.length === 0) return;
    const lightbox = dialog;
    const lightboxImage = img;
    const lightboxClose = closeButton;
    const lightboxPrevious = previousButton;
    const lightboxNext = nextButton;
    const lightboxCounter = counter;

    let currentIndex = 0;
    let opener: HTMLAnchorElement | null = null;

    function renderCurrent() {
      const item = items[currentIndex] ?? items[0]!;
      lightboxImage.classList.remove('lb-fade');
      lightboxImage.src = item.src;
      lightboxImage.alt = item.alt;
      lightboxCounter.textContent = `${currentIndex + 1} / ${items.length}`;
      void lightboxImage.offsetWidth;
      lightboxImage.classList.add('lb-fade');
    }

    function openLightbox(index: number, anchor: HTMLAnchorElement) {
      currentIndex = index;
      opener = anchor;
      renderCurrent();
      lightbox.showModal();
      lightboxClose.focus();
    }

    function closeLightbox() {
      if (lightbox.open) lightbox.close();
    }

    function go(step: number) {
      currentIndex = (currentIndex + step + items.length) % items.length;
      renderCurrent();
    }

    document.querySelectorAll<HTMLAnchorElement>('a.cert-card').forEach(function (anchor, index) {
      anchor.addEventListener('click', function (event) {
        event.preventDefault();
        openLightbox(index, anchor);
      });
    });

    let touchX = 0;
    lightbox.addEventListener('touchstart', function (event) {
      touchX = event.touches[0]?.clientX ?? 0;
    });
    lightbox.addEventListener('touchend', function (event) {
      const diff = touchX - (event.changedTouches[0]?.clientX ?? touchX);
      if (Math.abs(diff) > 50) go(diff > 0 ? 1 : -1);
    });

    lightboxClose.addEventListener('click', closeLightbox);
    lightboxPrevious.addEventListener('click', () => go(-1));
    lightboxNext.addEventListener('click', () => go(1));
    lightbox.addEventListener('click', function (event) {
      if (event.target === lightbox) closeLightbox();
    });
    lightbox.addEventListener('keydown', function (event) {
      if (event.key === 'ArrowLeft') go(-1);
      if (event.key === 'ArrowRight') go(1);
    });
    lightbox.addEventListener('close', function () {
      opener?.focus();
      opener = null;
    });
  })();
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    width: 100vw;
    max-width: none;
    height: 100vh;
    max-height: none;
    margin: 0;
    border: 0;
    padding: 0;
    background: rgba(0, 0, 0, 0.88);
    color: #fff;
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.88);
  }
  .lightbox-image-wrap {
    display: flex;
    max-width: 90vw;
    max-height: 90vh;
    align-items: center;
    justify-content: center;
  }
  .lightbox-image-wrap img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .lightbox-image-wrap img.lb-fade {
    opacity: 1;
  }
  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    z-index: 1;
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: #fff;
    cursor: pointer;
  }
  .lightbox-close:hover,
  .lightbox-nav:hover,
  .lightbox-close:focus-visible,
  .lightbox-nav:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .lightbox-close {
    top: 16px;
    right: 20px;
    font-size: 28px;
  }
  .lightbox-nav {
    top: 50%;
    width: 56px;
    height: 56px;
    transform: translateY(-50%);
    font-size: 42px;
  }
  .lightbox-prev {
    left: 16px;
  }
  .lightbox-next {
    right: 16px;
  }
  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.78);
    font-size: 14px;
  }
  @media (max-width: 640px) {
    .lightbox-nav {
      width: 44px;
      height: 44px;
      font-size: 28px;
    }
    .lightbox-prev {
      left: 4px;
    }
    .lightbox-next {
      right: 4px;
    }
    .lightbox-close {
      top: 8px;
      right: 10px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox-image-wrap img {
      transition: none;
    }
  }
</style>
