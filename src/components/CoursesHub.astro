---
import type { SiliconEmbersLang } from '../data/siliconEmbersHome';
import ActionButton from './silicon-embers/ActionButton.astro';
import EmberField from './silicon-embers/EmberField.astro';
import SiliconEmbersSiteFrame from './silicon-embers/SiliconEmbersSiteFrame.astro';

export interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const courseBase = '/silicon-ashes/courses/ai-research-efficiency/';
const alternateHref = isZh ? '/en/silicon-ashes/courses/' : '/silicon-ashes/courses/';

const t = isZh
  ? {
      eyebrow: '资源 / 课程',
      title: 'AI 科研效率课程包',
      lead: '面向化工教师与零基础用户，把 AI 方法和工具链整理成可进入、可复用的资源。',
      path: {
        kicker: '学习路径',
        title: '四步走完一套科研 AI 工作流',
        body: '先建立概念地图，再完成工具实操，最后把真实科研任务沉淀成自己的流程包。',
        cta: '进入课程首页 →',
        steps: [
          ['01', '基础概念', '听懂 LLM、API、Prompt、Context、CLI/GUI。', `${courseBase}foundations.html`],
          ['02', '工具实操', '跑通 WorkBuddy、Claude Code、Codex 与 GitHub。', `${courseBase}toolchain.html`],
          ['03', '工作流工坊', '把文献、表达、数据或课程任务拆成可检查流程。', `${courseBase}workflow-lab.html`],
          ['04', '项目实战', '用一项真实任务完成个人科研 AI 工作流包。', `${courseBase}project-lab.html`],
        ],
      },
      roadmap: {
        kicker: '后续方向',
        title: '后续路线',
        items: [
          ['02', '工作流进阶', '筹备'],
          ['03', '科研表达', '概念'],
          ['04', '内训师包', '概念'],
        ],
      },
      gateway: {
        kicker: '课程子模块',
        title: 'AI 编程与科研效率基础课',
        body: '不是一个孤立网页，而是一套可以直接进入、打印、复用和扩展的课程资料包。',
        stats: [
          ['标准课', '8 小时'],
          ['扩展版', '12 小时'],
          ['主工具', 'WorkBuddy'],
        ],
        groups: [
          {
            title: '先进入',
            links: [
              ['课程总览', `${courseBase}index.html`],
              ['课程安排', `${courseBase}schedule.html`],
              ['基础概念', `${courseBase}foundations.html`],
            ],
          },
          {
            title: '再实操',
            links: [
              ['工具实操', `${courseBase}toolchain.html`],
              ['工作流工坊', `${courseBase}workflow-lab.html`],
              ['项目实战', `${courseBase}project-lab.html`],
            ],
          },
          {
            title: '交付与复用',
            links: [
              ['讲师手册', `${courseBase}instructor.html`],
              ['代码审阅', `${courseBase}code-review.html`],
              ['速查附录', `${courseBase}reference.html`],
              ['打印讲义', `${courseBase}handout.html`],
              ['PDF 讲义', `${courseBase}course-handout.pdf`],
            ],
          },
        ],
      },
    }
  : {
      eyebrow: 'Resources / Courses',
      title: 'AI research efficiency course pack',
      lead: 'Turning AI methods and toolchains into reusable resources for chemistry teachers and zero-basis learners.',
      path: {
        kicker: 'Learning path',
        title: 'Build one research AI workflow in four steps',
        body: 'Map the concepts, run the tools, then turn a real research task into a reusable workflow pack.',
        cta: 'Enter course home →',
        steps: [
          [
            '01',
            'Foundations',
            'Understand LLMs, APIs, prompts, context, CLI, and GUI.',
            `${courseBase}foundations.html`,
          ],
          ['02', 'Toolchain', 'Run WorkBuddy, Claude Code, Codex, and GitHub.', `${courseBase}toolchain.html`],
          [
            '03',
            'Workflow lab',
            'Turn reading, expression, data, or course tasks into checkable flows.',
            `${courseBase}workflow-lab.html`,
          ],
          [
            '04',
            'Project lab',
            'Ship a personal research AI workflow pack from a real task.',
            `${courseBase}project-lab.html`,
          ],
        ],
      },
      roadmap: {
        kicker: 'Next directions',
        title: 'Next course directions',
        items: [
          ['02', 'Workflow advanced', 'Planned'],
          ['03', 'Research expression', 'Concept'],
          ['04', 'Trainer kit', 'Concept'],
        ],
      },
      gateway: {
        kicker: 'Course submodule',
        title: 'AI Programming and Research Efficiency Basics',
        body: 'A directly usable course package: overview, schedule, toolchain labs, instructor notes, printable handout, and PDF.',
        stats: [
          ['Core', '8 hours'],
          ['Extended', '12 hours'],
          ['Main tool', 'WorkBuddy'],
        ],
        groups: [
          {
            title: 'Start',
            links: [
              ['Overview', `${courseBase}index.html`],
              ['Schedule', `${courseBase}schedule.html`],
              ['Foundations', `${courseBase}foundations.html`],
            ],
          },
          {
            title: 'Practice',
            links: [
              ['Toolchain', `${courseBase}toolchain.html`],
              ['Workflow lab', `${courseBase}workflow-lab.html`],
              ['Project lab', `${courseBase}project-lab.html`],
            ],
          },
          {
            title: 'Reuse',
            links: [
              ['Instructor notes', `${courseBase}instructor.html`],
              ['Code review', `${courseBase}code-review.html`],
              ['Reference', `${courseBase}reference.html`],
              ['Printable handout', `${courseBase}handout.html`],
              ['PDF handout', `${courseBase}course-handout.pdf`],
            ],
          },
        ],
      },
    };
---

<SiliconEmbersSiteFrame lang={lang} alternateHref={alternateHref}>
  <div class="courses-hub">
    <section class="course-hero" aria-labelledby="ch-title">
      <EmberField />
      <div class="hero-copy">
        <p class="eyebrow">{t.eyebrow}</p>
        <h1 id="ch-title">{t.title}</h1>
        <p class="lead">{t.lead}</p>
      </div>
    </section>

    <section class="course-gateway" aria-labelledby="gateway-title">
      <div class="gateway-copy">
        <p class="kicker">{t.gateway.kicker}</p>
        <h2 id="gateway-title">{t.gateway.title}</h2>
        <p>{t.gateway.body}</p>
        <dl class="gateway-stats">
          {
            t.gateway.stats.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <div class="gateway-links">
        {
          t.gateway.groups.map((group) => (
            <article>
              <h3>{group.title}</h3>
              <div>
                {group.links.map(([label, href]) =>
                  href ? (
                    <ActionButton href={href} size="compact" className="gateway-link">
                      {label}
                    </ActionButton>
                  ) : null,
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="learning-path" aria-labelledby="path-title">
      <div class="path-head">
        <div>
          <p class="kicker">{t.path.kicker}</p>
          <h2 id="path-title">{t.path.title}</h2>
          <p>{t.path.body}</p>
        </div>
        <ActionButton href={`${courseBase}index.html`} variant="primary" className="primary-course-link"
          >{t.path.cta}</ActionButton
        >
      </div>

      <div class="path-grid">
        {
          t.path.steps.map(([index, title, body, href]) => (
            <a class="path-step" href={href}>
              <span>{index}</span>
              <strong>{title}</strong>
              <em>{body}</em>
            </a>
          ))
        }
      </div>
    </section>

    <section class="roadmap" aria-labelledby="roadmap-title">
      <div class="roadmap-head">
        <p class="kicker">{t.roadmap.kicker}</p>
        <h2 id="roadmap-title">{t.roadmap.title}</h2>
      </div>
      <div class="roadmap-rail">
        {
          t.roadmap.items.map(([index, title, status]) => (
            <article class="roadmap-item">
              <span>{index}</span>
              <strong>{title}</strong>
              <em>{status}</em>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</SiliconEmbersSiteFrame>

<style>
  .courses-hub {
    padding-bottom: clamp(82px, 10vw, 128px);
  }

  /* ── hero ── */
  .course-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    max-width: none;
    min-height: min(560px, calc(100dvh - 76px));
    border-bottom: 1px solid rgba(218, 166, 86, 0.14);
    padding: 100px 0 72px;
    background:
      linear-gradient(90deg, rgba(7, 6, 5, 0.98) 0%, rgba(7, 6, 5, 0.9) 46%, rgba(7, 6, 5, 0.36) 100%),
      radial-gradient(circle at 84% 76%, rgba(217, 121, 63, 0.2), transparent 30rem);
  }

  .course-hero::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 174, 98, 0.68), transparent);
    opacity: 0.52;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 880px;
  }

  .eyebrow,
  .kicker {
    margin: 0;
    color: #d8aa63;
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 800;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2 {
    margin: 0;
    color: #f2dfbd;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', 'Times New Roman', serif;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.06;
    text-wrap: balance;
  }

  h1 {
    max-width: 880px;
    margin-top: 22px;
    font-size: clamp(3.2rem, 5.5vw, 4.8rem);
  }

  .lead {
    max-width: 680px;
    margin: 28px 0 0;
    color: rgba(233, 224, 208, 0.76);
    font-size: 20px;
    line-height: 1.88;
    text-wrap: pretty;
  }

  /* ── course gateway ── */
  .course-gateway {
    display: grid;
    grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
    gap: clamp(34px, 6vw, 72px);
    border-bottom: 1px solid rgba(218, 166, 86, 0.16);
    padding: clamp(56px, 7vw, 84px) 0;
  }

  .gateway-copy h2 {
    max-width: 620px;
    margin-top: 14px;
    font-size: clamp(2rem, 4.5vw, 4.2rem);
    line-height: 1;
  }

  .gateway-copy > p:not(.kicker) {
    max-width: 560px;
    margin: 22px 0 0;
    color: rgba(233, 224, 208, 0.66);
    font-size: 17px;
    line-height: 1.78;
  }

  .gateway-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin: 28px 0 0;
    border: 1px solid rgba(218, 166, 86, 0.14);
    background: rgba(218, 166, 86, 0.14);
  }

  .gateway-stats div {
    padding: 16px;
    background: rgba(8, 7, 5, 0.9);
  }

  .gateway-stats dt {
    color: rgba(168, 177, 176, 0.72);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 12px;
    font-weight: 800;
  }

  .gateway-stats dd {
    margin: 7px 0 0;
    color: #f2dfbd;
    font-size: 18px;
    font-weight: 800;
  }

  .gateway-links {
    display: grid;
    gap: 16px;
  }

  .gateway-links article {
    display: grid;
    grid-template-columns: minmax(120px, 0.24fr) 1fr;
    gap: 22px;
    align-items: start;
    border-top: 1px solid rgba(218, 166, 86, 0.14);
    padding-top: 18px;
  }

  .gateway-links h3 {
    color: rgba(242, 223, 189, 0.78);
    font-size: 18px;
  }

  .gateway-links article > div {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── learning path ── */
  .learning-path {
    border-bottom: 1px solid rgba(218, 166, 86, 0.16);
    padding: clamp(54px, 7vw, 84px) 0;
  }

  .path-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    margin-bottom: 34px;
  }

  .path-head h2,
  .roadmap-head h2 {
    max-width: 760px;
    margin-top: 14px;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1;
  }

  .path-head p:not(.kicker) {
    max-width: 680px;
    margin: 18px 0 0;
    color: rgba(233, 224, 208, 0.66);
    font-size: 17px;
    line-height: 1.78;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid rgba(218, 166, 86, 0.15);
    background: rgba(218, 166, 86, 0.15);
  }

  .path-step {
    display: grid;
    min-height: 220px;
    align-content: space-between;
    padding: 22px;
    background: linear-gradient(160deg, rgba(216, 170, 99, 0.06), transparent 48%), rgba(10, 9, 8, 0.94);
    text-decoration: none;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .path-step:hover,
  .path-step:focus-visible {
    transform: translateY(-2px);
    background: linear-gradient(160deg, rgba(216, 170, 99, 0.13), transparent 52%), rgba(12, 11, 9, 0.98);
    outline: none;
  }

  .path-step span,
  .roadmap-item span {
    color: rgba(168, 177, 176, 0.48);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 28px;
    font-weight: 900;
    line-height: 1;
  }

  .path-step strong,
  .roadmap-item strong {
    display: block;
    color: #f2dfbd;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: 22px;
    font-weight: 850;
    line-height: 1.2;
  }

  .path-step em,
  .roadmap-item em {
    display: block;
    margin-top: 12px;
    color: rgba(233, 224, 208, 0.58);
    font-size: 14px;
    font-style: normal;
    line-height: 1.62;
  }

  .roadmap {
    padding: 50px 0 112px;
  }

  .roadmap-head {
    margin-bottom: 24px;
  }

  .roadmap-head h2 {
    color: rgba(242, 223, 189, 0.78);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
  }

  .roadmap-rail {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border-top: 1px solid rgba(218, 166, 86, 0.12);
    border-bottom: 1px solid rgba(218, 166, 86, 0.12);
    background: rgba(218, 166, 86, 0.12);
  }

  .roadmap-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 14px;
    align-items: center;
    padding: 18px 16px;
    background: rgba(8, 7, 5, 0.94);
  }

  .roadmap-item span {
    font-size: 16px;
  }

  .roadmap-item strong {
    font-size: 17px;
  }

  .roadmap-item em {
    margin: 0;
    color: rgba(216, 170, 99, 0.68);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 12px;
    font-weight: 800;
  }

  h3 {
    margin: 0;
    color: #f2dfbd;
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: 24px;
    font-weight: 800;
    line-height: 1.2;
  }

  /* ── footer ── */
  /* ── responsive ── */
  @media (max-width: 860px) {
    .course-gateway {
      grid-template-columns: 1fr;
    }

    .path-head {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .path-grid,
    .roadmap-rail {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .course-hero {
      min-height: auto;
      padding: 34px 0 30px;
    }

    h1 {
      margin-top: 12px;
      font-size: clamp(1.45rem, 6.5vw, 1.95rem);
      line-height: 1.16;
    }

    .lead {
      max-width: 29rem;
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .course-gateway {
      padding: 38px 0;
    }

    .gateway-copy h2,
    .path-head h2 {
      margin-top: 10px;
      font-size: clamp(1.32rem, 6.2vw, 1.78rem);
      line-height: 1.16;
    }

    .gateway-copy > p:not(.kicker),
    .path-head p:not(.kicker) {
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .gateway-stats,
    .gateway-links article {
      grid-template-columns: 1fr;
    }

    .gateway-stats {
      margin-top: 20px;
    }

    .gateway-stats div {
      padding: 12px;
    }

    .gateway-stats dd {
      font-size: 16px;
    }

    .gateway-links {
      gap: 12px;
    }

    .gateway-links article {
      gap: 12px;
      padding-top: 14px;
    }

    .learning-path {
      padding: 38px 0;
    }

    .path-head {
      margin-bottom: 22px;
    }

    .path-step {
      min-height: auto;
      gap: 14px;
      padding: 16px;
    }

    .path-step span {
      font-size: 17px;
    }

    .path-step strong {
      font-size: 17px;
    }

    .path-step em {
      margin-top: 0;
      font-size: 13.5px;
      line-height: 1.58;
    }

    .roadmap {
      padding: 34px 0 58px;
    }

    .roadmap-head h2 {
      font-size: 1.35rem;
    }

    .roadmap-item {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .roadmap-item em {
      grid-column: 2;
    }

    h3 {
      font-size: 17px;
    }
  }

  @media (max-width: 420px) {
    h1 {
      font-size: clamp(1.38rem, 6.2vw, 1.72rem);
    }

    :global(.gateway-link),
    :global(.primary-course-link) {
      width: 100%;
    }
  }
</style>
