---
import { getCollection } from 'astro:content';
import { siliconEmbersHomeCopy, type SiliconEmbersLang } from '../data/siliconEmbersHome';
import EmberHero from './silicon-embers/EmberHero.astro';
import SiteCompass from './silicon-embers/SiteCompass.astro';
import WritingPreview from './silicon-embers/WritingPreview.astro';
import SignalLinksSection from './silicon-embers/SignalLinksSection.astro';
import SiliconEmbersSiteFrame from './silicon-embers/SiliconEmbersSiteFrame.astro';

export interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const copy = siliconEmbersHomeCopy[lang];

const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const latestPosts = posts.slice(0, 3);
---

<SiliconEmbersSiteFrame lang={lang}>
  <div class="home-content">
    <EmberHero copy={copy.hero} wordmark={copy.wordmark} />
    <SiteCompass label={copy.compassLabel} items={copy.compass} />
    <WritingPreview copy={copy.writing} lang={lang} posts={latestPosts} />
    <SignalLinksSection id="resources" titleId="resources-title" variant="resource-band" copy={copy.resources} />
  </div>
</SiliconEmbersSiteFrame>
