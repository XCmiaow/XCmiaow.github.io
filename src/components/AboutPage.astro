---
import common from '../data/common.json';
import ActionButton from './silicon-embers/ActionButton.astro';
import type { SiliconEmbersLang } from '../data/siliconEmbersHome';

export interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const githubUrl = `https://${common.person.github}`;

const t = isZh
  ? {
      eyebrow: 'about / silicon-embers',
      title: '把技术经验翻译成人能继续使用的语言',
      intro: '硅基余烬从化工、科研、教育与 AI 工作流的交叉处出发，关注技术如何重新安排人的工作、学习、科研和表达。',
      focusTitle: '现在正在做',
      focus: [
        '继续建设硅基余烬品牌主站，让博客和资源形成同一套系统。',
        '设计面向非计算机背景教师的 AI 科研效率课程，把工具链整理成资源包。',
        '记录 AI 工作流、科研方法、化工表达和技术批判之间的真实摩擦。',
      ],
      backgroundTitle: '背景与经验',
      background: [
        '化学工程专业背景，接触有机化学、催化研究、论文表达和科研训练。',
        '做过数学建模、课程项目、知识库整理、Astro 站点建设和 AI 工具链实践。',
        '偏好把复杂问题拆成可复盘流程：先看现场，再写清楚，最后做成可复用模板。',
      ],
      contactTitle: '联系与入口',
      contactLead: '如果你想从文章或资源开始，直接进入对应页面；课程资料也收在资源里。',
      resumeLabel: '个人信息',
      writingLabel: '博客',
      resourcesLabel: '资源',
      emailLabel: '邮箱',
      wecomLabel: '企业微信',
      wecomLead: '扫码添加企业微信。',
      wecomAlt: '企业微信二维码',
      githubLabel: 'GitHub',
      wechatLabel: '公众号',
      wechatHref: '/silicon-ashes/feed/',
      resumeHref: '/profile/',
      writingHref: '/silicon-ashes/writing/',
      resourcesHref: '/silicon-ashes/resources/',
    }
  : {
      eyebrow: 'about / silicon-embers',
      title: 'Translating technical experience into language people can keep using',
      intro:
        'silicon-embers works from the intersection of chemical engineering, research, education, and AI workflows, focusing on how technology rearranges work, learning, research, and expression.',
      focusTitle: 'Current work',
      focus: [
        'Continuing to build silicon-embers as a brand site where blog and resources form one system.',
        'Designing AI research efficiency courses for non-CS teachers and packaging toolchains as resources.',
        'Documenting AI workflows, research methods, chemistry expression, and the real friction behind technical change.',
      ],
      backgroundTitle: 'Background',
      background: [
        'Chemical engineering background with exposure to organic chemistry, catalysis research, thesis work, and research training.',
        'Experience in mathematical modeling, course projects, knowledge-base work, Astro site building, and AI toolchain practice.',
        'I prefer turning complex problems into repeatable flows: observe the field, write it clearly, then make it reusable.',
      ],
      contactTitle: 'Contact and entry points',
      contactLead: 'Start from blog or resources. Course materials live inside resources.',
      resumeLabel: 'Personal info',
      writingLabel: 'Blog',
      resourcesLabel: 'Resources',
      emailLabel: 'Email',
      wecomLabel: 'WeCom',
      wecomLead: 'Scan to add my WeCom contact.',
      wecomAlt: 'WeCom QR code',
      githubLabel: 'GitHub',
      wechatLabel: 'WeChat',
      wechatHref: '/en/silicon-ashes/feed/',
      resumeHref: '/en/profile/',
      writingHref: '/en/silicon-ashes/writing/',
      resourcesHref: '/en/silicon-ashes/resources/',
    };
---

<div class="about-page">
  <section class="about-hero" aria-labelledby="about-title">
    <p class="kicker">{t.eyebrow}</p>
    <h1 id="about-title">{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <section class="about-ledger" aria-labelledby="focus-title">
    <div class="section-copy">
      <p class="kicker">current</p>
      <h2 id="focus-title">{t.focusTitle}</h2>
    </div>
    <ol>
      {
        t.focus.map((item, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="about-ledger compact" aria-labelledby="background-title">
    <div class="section-copy">
      <p class="kicker">background</p>
      <h2 id="background-title">{t.backgroundTitle}</h2>
    </div>
    <ol>
      {
        t.background.map((item, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="contact-board" aria-labelledby="contact-title">
    <div class="contact-copy">
      <p class="kicker">route</p>
      <h2 id="contact-title">{t.contactTitle}</h2>
      <p>{t.contactLead}</p>
    </div>
    <div class="contact-actions">
      <nav aria-label={t.contactTitle}>
        <ActionButton href={t.writingHref} className="contact-link">{t.writingLabel}</ActionButton>
        <ActionButton href={t.resourcesHref} className="contact-link">{t.resourcesLabel}</ActionButton>
        <ActionButton href={t.wechatHref} className="contact-link">{t.wechatLabel}</ActionButton>
        <ActionButton href={`mailto:${common.person.email}`} className="contact-link">{t.emailLabel}</ActionButton>
        <ActionButton href={githubUrl} className="contact-link">{t.githubLabel}</ActionButton>
        <ActionButton href={t.resumeHref} className="contact-link">{t.resumeLabel}</ActionButton>
      </nav>

      <article id="wecom" class="wecom-card" aria-labelledby="wecom-title">
        <div>
          <h3 id="wecom-title">{t.wecomLabel}</h3>
          <p>{t.wecomLead}</p>
        </div>
        <img src={common.person.wecomQr} alt={t.wecomAlt} width="144" height="144" loading="lazy" decoding="async" />
      </article>
    </div>
  </section>
</div>

<style>
  .about-page {
    position: relative;
  }

  .about-hero {
    display: grid;
    min-height: min(620px, calc(100dvh - 82px));
    align-content: center;
    border-bottom: 1px solid var(--line);
    padding: clamp(78px, 11vw, 132px) 0;
  }

  .about-hero h1 {
    max-width: 1050px;
    margin-top: 16px;
    font-size: clamp(3.2rem, 7.2vw, 7.4rem);
    line-height: 0.96;
    overflow-wrap: normal;
    text-wrap: balance;
    word-break: normal;
  }

  .about-hero > p:not(.kicker) {
    max-width: 760px;
    margin: 30px 0 0;
    color: rgba(247, 230, 196, 0.76);
    font-size: clamp(1.08rem, 1.7vw, 1.38rem);
    line-height: 1.86;
  }

  .about-ledger {
    display: grid;
    grid-template-columns: minmax(0, 0.48fr) minmax(0, 0.72fr);
    gap: clamp(34px, 7vw, 96px);
    border-bottom: 1px solid var(--line);
    padding: clamp(72px, 10vw, 112px) 0;
  }

  .about-ledger.compact {
    padding-top: clamp(56px, 8vw, 92px);
  }

  .about-ledger ol {
    display: grid;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(120, 155, 145, 0.34);
    list-style: none;
  }

  .about-ledger li {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 18px;
    border-bottom: 1px solid rgba(120, 155, 145, 0.2);
    padding: 22px 0;
  }

  .about-ledger li span {
    color: rgba(232, 174, 98, 0.72);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 900;
  }

  .about-ledger li p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.78;
  }

  .contact-board {
    display: grid;
    grid-template-columns: minmax(0, 0.58fr) minmax(280px, 0.42fr);
    gap: clamp(34px, 7vw, 92px);
    align-items: end;
    padding: clamp(72px, 10vw, 112px) 0;
  }

  .contact-board h2 {
    margin-top: 14px;
    font-size: clamp(2.5rem, 5.6vw, 5.8rem);
    line-height: 0.98;
  }

  .contact-copy > p:not(.kicker) {
    max-width: 650px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.78;
  }

  .contact-board nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .contact-actions {
    display: grid;
    gap: 18px;
  }

  .wecom-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    scroll-margin-top: 96px;
    border: 1px solid rgba(242, 223, 189, 0.14);
    border-radius: 7px;
    padding: 16px;
    background: linear-gradient(135deg, rgba(232, 174, 98, 0.07), transparent 52%), rgba(242, 223, 189, 0.03);
  }

  .wecom-card h3 {
    margin: 0;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 850;
    line-height: 1.2;
  }

  .wecom-card p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .wecom-card img {
    width: 144px;
    height: 144px;
    border: 1px solid rgba(242, 223, 189, 0.16);
    border-radius: 6px;
    background: #fff;
    object-fit: cover;
  }

  @media (max-width: 960px) {
    .about-ledger,
    .contact-board {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .about-hero {
      min-height: auto;
      padding: 34px 0 32px;
    }

    .about-hero h1 {
      margin-top: 12px;
      font-size: clamp(1.45rem, 6.4vw, 1.95rem);
      line-height: 1.16;
    }

    .about-hero > p:not(.kicker) {
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .about-ledger,
    .contact-board {
      padding: 40px 0;
    }

    .contact-board h2 {
      font-size: clamp(1.32rem, 6.2vw, 1.78rem);
      line-height: 1.16;
    }

    .contact-copy > p:not(.kicker) {
      font-size: 14.5px;
      line-height: 1.68;
    }

    .about-ledger li {
      padding: 18px 0;
    }

    .about-ledger li p {
      font-size: 14.5px;
      line-height: 1.68;
    }

    .contact-board :global(.contact-link) {
      flex: 1 1 calc(50% - 8px);
      min-width: 132px;
    }

    .wecom-card {
      grid-template-columns: 1fr;
      justify-items: start;
      padding: 14px;
    }

    .wecom-card img {
      width: 132px;
      height: 132px;
    }
  }

  @media (max-width: 360px) {
    .about-hero h1 {
      font-size: clamp(1.38rem, 6.2vw, 1.72rem);
    }

    .about-ledger li {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
