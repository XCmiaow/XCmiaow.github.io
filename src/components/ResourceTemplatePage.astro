---
import type { ResourceTemplate } from '../data/siliconAshesResources';
import type { SiliconEmbersLang } from '../data/siliconEmbersHome';
import ActionButton from './silicon-embers/ActionButton.astro';

export interface Props {
  lang: SiliconEmbersLang;
  template: ResourceTemplate;
}

const { lang, template } = Astro.props;
const isZh = lang === 'zh';
const data = template[lang];
const resourcesHref = isZh ? '/silicon-ashes/resources/' : '/en/silicon-ashes/resources/';

const copy = isZh
  ? {
      purpose: '用途',
      sections: '包含模块',
      checklist: '使用前检查',
      copy: '可复制模板',
      back: '返回资源中心',
    }
  : {
      purpose: 'Purpose',
      sections: 'Sections',
      checklist: 'Before use',
      copy: 'Copyable template',
      back: 'Back to resources',
    };
---

<article class="resource-template">
  <header class="template-hero">
    <p class="eyebrow">{data.eyebrow}</p>
    <h1>{data.title}</h1>
    <p class="lead">{data.summary}</p>
    <ul class="meta-list">
      {data.meta.map((item) => <li>{item}</li>)}
    </ul>
  </header>

  <section class="purpose" aria-labelledby="purpose-title">
    <div class="section-head">
      <p class="kicker">why</p>
      <h2 id="purpose-title">{copy.purpose}</h2>
    </div>
    <p>{data.purpose}</p>
  </section>

  <section class="layout-grid" aria-label={isZh ? '模板结构' : 'Template structure'}>
    <article>
      <h2>{copy.sections}</h2>
      <ul>
        {data.sections.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article>
      <h2>{copy.checklist}</h2>
      <ul>
        {data.checklist.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="template-block" aria-labelledby="template-title">
    <div class="section-head wide">
      <p class="kicker">copy</p>
      <h2 id="template-title">{copy.copy}</h2>
    </div>
    <pre><code>{data.template}</code></pre>
  </section>

  <footer class="template-return">
    <ActionButton href={resourcesHref}>{copy.back}</ActionButton>
  </footer>
</article>

<style>
  .resource-template {
    width: min(100%, 1120px);
    margin: 0 auto;
    padding-bottom: clamp(82px, 10vw, 128px);
  }

  .template-hero {
    max-width: 900px;
    padding: clamp(78px, 10vw, 118px) 0 clamp(54px, 7vw, 82px);
  }

  h1,
  h2,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2 {
    margin: 0;
    color: var(--paper);
    font-family: var(--font-display);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.05;
    text-wrap: balance;
  }

  h1 {
    margin-top: 20px;
    font-size: clamp(3rem, 6.3vw, 6.1rem);
  }

  .lead {
    max-width: 760px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 1.65vw, 1.35rem);
    line-height: 1.84;
  }

  .meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 26px 0 0;
    padding: 0;
    list-style: none;
  }

  .meta-list li {
    border: 1px solid rgba(168, 177, 176, 0.22);
    padding: 6px 10px;
    color: rgba(220, 228, 224, 0.68);
    font-size: 13px;
  }

  .purpose,
  .layout-grid,
  .template-block {
    border-top: 1px solid var(--line);
    padding: clamp(56px, 7vw, 84px) 0;
  }

  .section-head h2 {
    margin-top: 12px;
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .section-head.wide {
    max-width: 840px;
  }

  .purpose > p {
    max-width: 790px;
    margin: 22px 0 0;
    color: rgba(239, 227, 205, 0.76);
    font-size: 17px;
    line-height: 1.84;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .layout-grid article {
    border: 1px solid rgba(232, 174, 98, 0.2);
    padding: 28px;
    background: rgba(13, 12, 10, 0.78);
  }

  .layout-grid h2 {
    font-size: 26px;
  }

  .layout-grid ul {
    display: grid;
    gap: 11px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .layout-grid li {
    position: relative;
    padding-left: 18px;
    color: rgba(239, 227, 205, 0.76);
    line-height: 1.64;
  }

  .layout-grid li::before {
    content: '';
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 6px;
    height: 6px;
    background: var(--ember-strong);
  }

  .template-block pre {
    overflow-x: auto;
    margin: 30px 0 0;
    border: 1px solid rgba(232, 174, 98, 0.2);
    padding: 26px;
    background: rgba(0, 0, 0, 0.42);
    white-space: pre-wrap;
  }

  .template-block code {
    color: rgba(246, 236, 214, 0.92);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 14px;
    line-height: 1.76;
  }

  .template-return {
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  @media (max-width: 760px) {
    .template-hero {
      padding: 34px 0 28px;
    }

    h1 {
      margin-top: 12px;
      font-size: clamp(1.45rem, 6.4vw, 1.95rem);
      line-height: 1.16;
    }

    .lead {
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .section-head h2 {
      font-size: clamp(1.28rem, 6vw, 1.72rem);
    }

    .purpose,
    .layout-grid,
    .template-block {
      padding: 38px 0;
    }

    .purpose > p,
    .layout-grid li {
      font-size: 14.5px;
      line-height: 1.66;
    }

    .layout-grid {
      grid-template-columns: 1fr;
    }

    .layout-grid article,
    .template-block pre {
      padding: 20px;
    }

    .layout-grid h2 {
      font-size: 18px;
    }

    .template-block code {
      font-size: 12.5px;
      line-height: 1.64;
    }
  }

  @media (max-width: 360px) {
    h1 {
      font-size: clamp(1.38rem, 6.2vw, 1.72rem);
    }

    .meta-list li {
      font-size: 12px;
    }
  }
</style>
