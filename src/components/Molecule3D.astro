<canvas id="mol-bg" aria-hidden="true"></canvas>

<script>
  (function () {
    var canvas = document.getElementById('mol-bg');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var W = 0,
      H = 0,
      angle = 0,
      animId;

    var elementStyle = {
      C: { r: 7, c: '70,78,88', label: 'C' },
      N: { r: 8, c: '34,92,180', label: 'N' },
      O: { r: 8, c: '205,68,68', label: 'O' },
    };

    // Caffeine, CID 2519: CN1C=NC2=C1C(=O)N(C)C(=O)N2C
    // Explicit topology avoids the previous distance-based false bonds.
    var atoms = [
      { x: -132, y: -78, z: 30, e: 'C' },
      { x: -76, y: -48, z: 8, e: 'N' },
      { x: -58, y: 13, z: 0, e: 'C' },
      { x: 0, y: 31, z: 0, e: 'N' },
      { x: 47, y: -13, z: 0, e: 'C' },
      { x: 10, y: -68, z: 0, e: 'C' },
      { x: 29, y: -130, z: 0, e: 'C' },
      { x: -9, y: -180, z: -4, e: 'O' },
      { x: 94, y: -146, z: 0, e: 'N' },
      { x: 113, y: -208, z: -32, e: 'C' },
      { x: 141, y: -102, z: 0, e: 'C' },
      { x: 204, y: -118, z: 4, e: 'O' },
      { x: 122, y: -40, z: 0, e: 'N' },
      { x: 169, y: 4, z: 28, e: 'C' },
    ];

    var bonds = [
      [0, 1, 1],
      [1, 2, 1],
      [2, 3, 2],
      [3, 4, 1],
      [4, 5, 2],
      [5, 1, 1],
      [5, 6, 1],
      [6, 7, 2],
      [6, 8, 1],
      [8, 9, 1],
      [8, 10, 1],
      [10, 11, 2],
      [10, 12, 1],
      [12, 4, 1],
      [12, 13, 1],
    ];

    function resize() {
      var rect = canvas.getBoundingClientRect();
      W = Math.max(1, Math.round(rect.width));
      H = Math.max(1, Math.round(rect.height));
      canvas.width = W * 2;
      canvas.height = H * 2;
      ctx.setTransform(2, 0, 0, 2, 0, 0);
    }

    function rotateX(p, a) {
      var c = Math.cos(a),
        s = Math.sin(a);
      return { x: p.x, y: p.y * c - p.z * s, z: p.y * s + p.z * c };
    }
    function rotateY(p, a) {
      var c = Math.cos(a),
        s = Math.sin(a);
      return { x: p.x * c + p.z * s, y: p.y, z: -p.x * s + p.z * c };
    }
    function rotateZ(p, a) {
      var c = Math.cos(a),
        s = Math.sin(a);
      return { x: p.x * c - p.y * s, y: p.x * s + p.y * c, z: p.z };
    }

    function project(atom) {
      var p = { x: atom.x - 35, y: atom.y + 92, z: atom.z };
      p = rotateX(p, -0.42 + Math.sin(angle * 0.7) * 0.08);
      p = rotateY(p, angle);
      p = rotateZ(p, -0.12);
      var depth = 520;
      var scale = depth / (depth + p.z);
      return {
        px: W * 0.5 + p.x * scale,
        py: H * 0.54 + p.y * scale,
        z: p.z,
        e: atom.e,
        scale: scale,
      };
    }

    function drawBond(a, b, order) {
      var dx = b.px - a.px,
        dy = b.py - a.py;
      var len = Math.max(1, Math.hypot(dx, dy));
      var ox = (-dy / len) * 3.2,
        oy = (dx / len) * 3.2;
      var alpha = Math.max(0.22, Math.min(a.scale, b.scale) * 0.46);

      ctx.strokeStyle = 'rgba(112,122,137,' + alpha + ')';
      ctx.lineCap = 'round';
      ctx.lineWidth = Math.max(1.2, Math.min(a.scale, b.scale) * 1.7);

      if (order === 2) {
        ctx.beginPath();
        ctx.moveTo(a.px + ox, a.py + oy);
        ctx.lineTo(b.px + ox, b.py + oy);
        ctx.moveTo(a.px - ox, a.py - oy);
        ctx.lineTo(b.px - ox, b.py - oy);
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.moveTo(a.px, a.py);
        ctx.lineTo(b.px, b.py);
        ctx.stroke();
      }
    }

    function drawAtom(atom) {
      var style = elementStyle[atom.e];
      var r = style.r * atom.scale;
      var alpha = Math.max(0.42, Math.min(0.88, 0.32 + atom.scale * 0.42));

      ctx.beginPath();
      ctx.arc(atom.px, atom.py, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + style.c + ',' + alpha + ')';
      ctx.fill();

      ctx.beginPath();
      ctx.arc(atom.px - r * 0.25, atom.py - r * 0.28, r * 0.42, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + alpha * 0.2 + ')';
      ctx.fill();

      if (atom.e !== 'C') {
        ctx.fillStyle = 'rgba(255,255,255,' + Math.min(0.9, alpha + 0.08) + ')';
        ctx.font = '700 ' + Math.max(9, r * 1.25) + 'px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(style.label, atom.px, atom.py + 0.3);
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      angle += 0.006;

      var projected = atoms.map(project);
      bonds.forEach(function (bond) {
        drawBond(projected[bond[0]], projected[bond[1]], bond[2]);
      });

      projected
        .slice()
        .sort(function (a, b) {
          return a.z - b.z;
        })
        .forEach(drawAtom);

      animId = requestAnimationFrame(draw);
    }

    resize();
    draw();

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(resize, 120);
    });
    document.addEventListener('astro:after-swap', function () {
      if (animId) cancelAnimationFrame(animId);
    });
  })();
</script>

<style>
  #mol-bg {
    position: fixed;
    top: 86px;
    right: 24px;
    width: min(360px, 34vw);
    height: min(300px, 32vh);
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }
  html.minimal-mode #mol-bg {
    display: none !important;
  }
  @media (max-width: 760px) {
    #mol-bg {
      top: 70px;
      right: 4px;
      width: 190px;
      height: 160px;
      opacity: 0.4;
    }
  }
</style>
