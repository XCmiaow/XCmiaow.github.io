<canvas id="particles-bg" aria-hidden="true"></canvas>

<script>
  (function() {
    var canvas = document.getElementById('particles-bg');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var W, H, particles = [], trail = [];
    var mouse = { x: -1000, y: -1000 };
    var animId;
    var isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W * 2;
      canvas.height = H * 2;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(2, 0, 0, 2, 0, 0);
      init();
    }

    function init() {
      particles = [];
      var count = Math.min(Math.floor((W * H) / 18000), 40);
      for (var i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * W, y: Math.random() * H,
          r: Math.random() * 2 + 0.8,
          vx: (Math.random() - 0.5) * 0.1,
          vy: (Math.random() - 0.5) * 0.1,
          phase: Math.random() * Math.PI * 2,
          speed: 0.02 + Math.random() * 0.03,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      // Deep blue palette
      var starColor = isDark ? '140,170,255' : '60,80,140';
      var glowColor = isDark ? '180,210,255' : '80,110,180';
      var connectColor = isDark ? '100,140,220' : '50,70,130';

      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;

        // Twinkle
        p.phase += p.speed;
        var twinkle = 0.5 + Math.sin(p.phase) * 0.3 + Math.cos(p.phase * 0.7) * 0.2;
        var alpha = 0.25 + twinkle * 0.35;

        // Glow
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + glowColor + ',' + (alpha * 0.08) + ')';
        ctx.fill();

        // Core
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + starColor + ',' + alpha + ')';
        ctx.fill();

        // constellation connections — always visible, brighter near mouse
        for (var j = i + 1; j < Math.min(i + 4, particles.length); j++) {
          var q = particles[j];
          var dx = p.x - q.x, dy = p.y - q.y, dist = Math.hypot(dx, dy);
          if (dist < 130) {
            var baseAlpha = (1 - dist / 130) * 0.08;
            // Mouse proximity boost
            var mBoost = 0;
            if (!isTouch) {
              var mx = (p.x + q.x) / 2 - mouse.x, my = (p.y + q.y) / 2 - mouse.y;
              mBoost = Math.max(0, 1 - Math.hypot(mx, my) / 200) * 0.2;
            }
            var connAlpha = baseAlpha + mBoost;
            if (connAlpha > 0.03) {
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = 'rgba(' + connectColor + ',' + connAlpha + ')';
              ctx.lineWidth = 0.4 + mBoost * 2;
              ctx.stroke();
            }
          }
        }

        // Mouse interaction (desktop only)
        if (!isTouch) {
          var dm = Math.hypot(p.x - mouse.x, p.y - mouse.y);
          if (dm < 120) {
            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(mouse.x, mouse.y);
            ctx.strokeStyle = 'rgba(' + glowColor + ',' + ((1 - dm / 120) * 0.08) + ')';
            ctx.lineWidth = 0.3;
            ctx.stroke();
          }
        }
      }

      // Trail
      for (var t = trail.length - 1; t >= 0; t--) {
        var tp = trail[t];
        tp.x += (mouse.x - tp.x) * 0.06;
        tp.y += (mouse.y - tp.y) * 0.06;
        tp.alpha -= 0.012;
        tp.r *= 0.97;
        if (tp.alpha <= 0) { trail.splice(t, 1); continue; }
        ctx.beginPath(); ctx.arc(tp.x, tp.y, tp.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + glowColor + ',' + (tp.alpha * 0.35) + ')';
        ctx.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    resize(); draw();

    var resizeTimer;
    window.addEventListener('resize', function() { clearTimeout(resizeTimer); resizeTimer = setTimeout(resize, 200); });

    // Always track pointer for trail
    document.addEventListener('mousemove', function(e) {
      mouse.x = e.clientX; mouse.y = e.clientY;
      trail.push({ x: mouse.x, y: mouse.y, r: 3 + Math.random() * 2, alpha: 1 });
      if (trail.length > 15) trail.shift();
    });
    // Touch trail as well
    document.addEventListener('touchmove', function(e) {
      var t = e.touches[0];
      if (t) {
        mouse.x = t.clientX; mouse.y = t.clientY;
        trail.push({ x: mouse.x, y: mouse.y, r: 3 + Math.random() * 2, alpha: 1 });
        if (trail.length > 10) trail.shift();
      }
    }, { passive: true });
    document.addEventListener('mouseleave', function() { mouse.x = -1000; mouse.y = -1000; });
    document.addEventListener('astro:after-swap', function() { if (animId) cancelAnimationFrame(animId); });
  })();
</script>

<style>
  #particles-bg {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    pointer-events: none; z-index: 0;
  }
</style>
