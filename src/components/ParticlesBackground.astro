<canvas id="particles-bg" aria-hidden="true"></canvas>

<script>
  (function() {
    var canvas = document.getElementById('particles-bg');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var W, H, particles = [], trail = [];
    var mouse = { x: -1000, y: -1000 };
    var animId, time = 0;

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W * 2;
      canvas.height = H * 2;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(2, 0, 0, 2, 0, 0);
      init();
    }

    function init() {
      particles = [];
      var count = Math.min(Math.floor((W * H) / 22000), 45);
      for (var i = 0; i < count; i++) {
        var size = Math.random();
        particles.push({
          x: Math.random() * W, y: Math.random() * H,
          r: 0.5 + size * 2.5,
          vx: (Math.random() - 0.5) * 0.06,
          vy: (Math.random() - 0.5) * 0.06,
          phase: Math.random() * Math.PI * 2,
          speed: 0.015 + Math.random() * 0.025,
          bright: 0.4 + size * 0.6,
          // 0 = dim, 1 = medium, 2 = bright
          type: size > 0.7 ? 2 : size > 0.3 ? 1 : 0,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      time += 0.02;

      // Deep blue gradient background
      var grad = ctx.createRadialGradient(W/2, H/2, 0, W/2, H/2, Math.max(W, H) * 0.7);
      grad.addColorStop(0, 'rgba(10,15,40,0.3)');
      grad.addColorStop(1, 'rgba(5,8,20,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      // Star colors: deep blue palette
      var colors = [
        { core: '180,200,255', glow: '140,170,255' },   // blue-white
        { core: '220,230,255', glow: '180,200,255' },   // white-blue
        { core: '200,180,255', glow: '160,140,255' },   // lavender
        { core: '255,220,200', glow: '255,180,140' },   // warm (rare)
      ];

      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;

        p.phase += p.speed;
        var twinkle = 0.5 + Math.sin(p.phase) * 0.3 + Math.cos(p.phase * 0.7) * 0.2;
        var brightness = p.bright * twinkle;
        var col = colors[p.type];
        if (!col) col = colors[0];

        // Outer glow
        var glowR = p.r * (p.type === 2 ? 6 : 4);
        ctx.beginPath(); ctx.arc(p.x, p.y, glowR, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + col.glow + ',' + (brightness * 0.06) + ')';
        ctx.fill();

        // Inner glow (medium)
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r * 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + col.glow + ',' + (brightness * 0.15) + ')';
        ctx.fill();

        // Star core
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + col.core + ',' + (brightness * 0.8) + ')';
        ctx.fill();

        // Bright stars get a cross flare
        if (p.type === 2 && brightness > 0.6) {
          var flareAlpha = (brightness - 0.6) * 0.3;
          ctx.strokeStyle = 'rgba(' + col.glow + ',' + flareAlpha + ')';
          ctx.lineWidth = 0.5;
          ctx.beginPath(); ctx.moveTo(p.x - p.r * 4, p.y); ctx.lineTo(p.x + p.r * 4, p.y);
          ctx.stroke();
          ctx.beginPath(); ctx.moveTo(p.x, p.y - p.r * 4); ctx.lineTo(p.x, p.y + p.r * 4);
          ctx.stroke();
        }

        // Constellation connections (only near mouse, blue-tinted)
        for (var j = i + 1; j < Math.min(i + 4, particles.length); j++) {
          var q = particles[j];
          var dx = p.x - q.x, dy = p.y - q.y, dist = Math.hypot(dx, dy);
          if (dist < 100) {
            var mx = (p.x + q.x) / 2 - mouse.x, my = (p.y + q.y) / 2 - mouse.y;
            var mBoost = Math.max(0, 1 - Math.hypot(mx, my) / 180);
            if (mBoost > 0.05) {
              var alpha = (1 - dist / 100) * mBoost * 0.25;
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = 'rgba(140,170,255,' + alpha + ')';
              ctx.lineWidth = 0.5 + mBoost;
              if (mBoost > 0.5) {
                ctx.shadowColor = 'rgba(140,170,255,' + (mBoost * 0.3) + ')';
                ctx.shadowBlur = 8;
              }
              ctx.stroke();
              ctx.shadowBlur = 0;
            }
          }
        }

        // Mouse starlight trail
        var dm = Math.hypot(p.x - mouse.x, p.y - mouse.y);
        if (dm < 80) {
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = 'rgba(140,170,255,' + ((1 - dm / 80) * 0.06) + ')';
          ctx.lineWidth = 0.3;
          ctx.stroke();
        }
      }

      // Shooting star trail
      for (var t = trail.length - 1; t >= 0; t--) {
        var tp = trail[t];
        tp.x += (mouse.x - tp.x) * 0.05;
        tp.y += (mouse.y - tp.y) * 0.05;
        tp.alpha -= 0.015;
        tp.r *= 0.96;
        if (tp.alpha <= 0) { trail.splice(t, 1); continue; }
        ctx.beginPath(); ctx.arc(tp.x, tp.y, tp.r * 1.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(180,210,255,' + (tp.alpha * 0.4) + ')';
        ctx.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    resize(); draw();

    var resizeTimer;
    window.addEventListener('resize', function() { clearTimeout(resizeTimer); resizeTimer = setTimeout(resize, 200); });

    document.addEventListener('mousemove', function(e) {
      mouse.x = e.clientX; mouse.y = e.clientY;
      trail.push({ x: mouse.x, y: mouse.y, r: 3 + Math.random() * 2, alpha: 1 });
      if (trail.length > 12) trail.shift();
    });
    document.addEventListener('mouseleave', function() { mouse.x = -1000; mouse.y = -1000; });
    document.addEventListener('astro:after-swap', function() { if (animId) cancelAnimationFrame(animId); });
  })();
</script>

<style>
  #particles-bg {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    pointer-events: none; z-index: 0;
  }
</style>
