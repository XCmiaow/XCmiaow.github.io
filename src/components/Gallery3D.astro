<div id="gallery-3d" class="gallery-3d" aria-hidden="true">
  <div class="g3d-cta">🖱 拖动旋转 · 点击放大</div>
  <div id="g3d-stage"></div>
</div>

<script is:inline>
  (function() {
    var container = document.getElementById('g3d-stage');
    var wrapper = document.getElementById('gallery-3d');
    if (!container || !wrapper || window.innerWidth < 640) return;

    // Collect certificate images
    var images = [];
    document.querySelectorAll('.cert-card img').forEach(function(img) {
      // Use data-src or src for the image
      var src = img.getAttribute('data-src') || img.src || '';
      if (src && images.indexOf(src) === -1) images.push(src);
    });
    if (images.length === 0) { wrapper.style.display = 'none'; return; }

    // Load Three.js
    var script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    script.onload = function() {

      var W = container.clientWidth || 600;
      var H = container.clientHeight || 380;

      // Scene
      var scene = new THREE.Scene();
      scene.background = null;

      // Camera
      var camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 1000);
      camera.position.set(0, 0.5, 6);

      // Renderer
      var renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(W, H);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // Lights
      scene.add(new THREE.AmbientLight(0xffffff, 0.5));
      var key = new THREE.DirectionalLight(0xffffff, 0.9);
      key.position.set(3, 4, 5);
      scene.add(key);
      var back = new THREE.DirectionalLight(0x8888cc, 0.3);
      back.position.set(-2, 0, -4);
      scene.add(back);

      // Texture loader
      var loader = new THREE.TextureLoader();
      var cards = [];
      var radius = 4.2;
      var total = images.length;

      var texLoader = new THREE.TextureLoader();

      images.forEach(function(src, i) {
        texLoader.load(src, function(texture) {
          // Calculate aspect ratio
          var aspect = texture.image.width / texture.image.height || 1;
          var h = 2.0;
          var w = h * aspect;

          var geom = new THREE.PlaneGeometry(w, h);
          var mat = new THREE.MeshStandardMaterial({
            map: texture,
            roughness: 0.4,
            metalness: 0.05,
            side: THREE.DoubleSide,
          });
          var mesh = new THREE.Mesh(geom, mat);

          // Arrange in an arc
          var angle = (i / total) * Math.PI * 2 - Math.PI / 2;
          mesh.position.x = Math.cos(angle) * radius;
          mesh.position.z = Math.sin(angle) * radius;
          mesh.position.y = 0;
          mesh.lookAt(0, 0, 0);

          // Gold frame
          var frameMat = new THREE.MeshStandardMaterial({
            color: 0xc9a227,
            roughness: 0.3,
            metalness: 0.3,
            side: THREE.DoubleSide,
          });
          var frameGeom = new THREE.PlaneGeometry(w + 0.08, h + 0.08);
          var frame = new THREE.Mesh(frameGeom, frameMat);
          frame.position.copy(mesh.position);
          frame.position.z = mesh.position.z + (mesh.position.z > 0 ? -0.01 : 0.01);
          frame.lookAt(0, 0, 0);

          scene.add(frame);
          scene.add(mesh);
          cards.push({ mesh: mesh, frame: frame, angle: angle, targetScale: 1 });
        });
      });

      // Interaction
      var isDragging = false;
      var prevX = 0;
      var rotation = 0;
      var targetRotation = 0;
      var velocity = 0;

      renderer.domElement.addEventListener('mousedown', function(e) { isDragging = true; prevX = e.clientX; velocity = 0; });
      window.addEventListener('mouseup', function() { isDragging = false; });
      window.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        var dx = e.clientX - prevX;
        targetRotation += dx * 0.008;
        velocity = dx * 0.008;
        prevX = e.clientX;
      });

      // Click to view certificate
      renderer.domElement.addEventListener('click', function(e) {
        // Simple approach: check if we didn't drag much
        // Open in lightbox or new tab
        if (Math.abs(velocity) < 0.01) {
          // Find closest card to camera
          var minDist = Infinity;
          var closestSrc = '';
          cards.forEach(function(c, i) {
            var angle = c.angle + rotation;
            var dist = Math.abs(angle % (Math.PI * 2));
            if (dist < minDist) { minDist = dist; closestSrc = images[i] || ''; }
          });
          if (closestSrc) window.open(closestSrc, '_blank');
        }
      });

      // Touch support
      var touchX = 0;
      renderer.domElement.addEventListener('touchstart', function(e) {
        touchX = e.touches[0].clientX;
        velocity = 0;
      }, { passive: true });
      renderer.domElement.addEventListener('touchmove', function(e) {
        var dx = e.touches[0].clientX - touchX;
        targetRotation += dx * 0.008;
        velocity = dx * 0.008;
        touchX = e.touches[0].clientX;
      }, { passive: true });

      // Scroll to zoom
      renderer.domElement.addEventListener('wheel', function(e) {
        camera.position.z += Math.sign(e.deltaY) * 0.3;
        camera.position.z = Math.max(2.5, Math.min(10, camera.position.z));
      }, { passive: true });

      // Animate
      function animate() {
        rotation += (targetRotation - rotation) * 0.08;
        // Inertia
        if (!isDragging) { velocity *= 0.97; targetRotation += velocity; }

        cards.forEach(function(c) {
          var a = c.angle + rotation;
          c.mesh.position.x = Math.cos(a) * radius;
          c.mesh.position.z = Math.sin(a) * radius;
          c.mesh.lookAt(0, 0, 0);
          c.frame.position.copy(c.mesh.position);
          c.frame.position.z = c.mesh.position.z + 0.01;
          c.frame.lookAt(0, 0, 0);

          // Scale cards facing the camera
          var dot = Math.cos(a);
          var s = 0.6 + dot * 0.4;
          c.mesh.scale.set(s, s, 1);
          c.frame.scale.set(s, s, 1);
        });

        renderer.render(scene, camera);
        requestAnimationFrame(animate);
      }
      animate();

      // Resize
      var resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          var nw = container.clientWidth || 600;
          var nh = container.clientHeight || 380;
          camera.aspect = nw / nh;
          camera.updateProjectionMatrix();
          renderer.setSize(nw, nh);
        }, 200);
      });
    };
    document.head.appendChild(script);
  })();
</script>

<style>
  .gallery-3d {
    margin: 20px 0;
    position: relative;
  }
  #g3d-stage {
    width: 100%;
    height: 420px;
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(16,42,67,0.02);
  }
  #g3d-stage canvas { display: block; width: 100% !important; height: 100% !important; }
  .g3d-cta {
    text-align: center;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 8px;
  }
  @media (max-width: 640px) {
    .gallery-3d { display: none; }
  }
</style>
