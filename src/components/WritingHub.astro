---
import { getCollection } from 'astro:content';
import common from '../data/common.json';

export interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const homeHref = isZh ? '/silicon-ashes/' : '/en/silicon-ashes/';

const allPosts = (await getCollection('blog', ({ data }) => {
  return data.lang === lang && !data.draft;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
};

const audienceLabel = (a?: string) => {
  if (a === 'teacher') return isZh ? '教师' : 'Teachers';
  if (a === 'researcher') return isZh ? '研究者' : 'Researchers';
  return isZh ? '通用' : 'General';
};

const audienceClass = (a?: string) => {
  if (a === 'teacher') return 'audience-teacher';
  if (a === 'researcher') return 'audience-researcher';
  return 'audience-general';
};

// Group by series
const seriesMap = new Map();
for (const post of allPosts) {
  const key = post.data.series || (isZh ? '独立篇' : 'Standalone');
  if (!seriesMap.has(key)) seriesMap.set(key, []);
  seriesMap.get(key).push(post);
}
---

<div class="wh-shell">
  <a class="skip-link" href="#main">{isZh ? '跳到正文' : 'Skip to content'}</a>

  <header class="wh-nav" aria-label={isZh ? '写作中心导航' : 'Writing navigation'}>
    <a class="wh-brand" href={homeHref}>
      <span class="brand-mark">SA</span>
      <span class="brand-name">{isZh ? '硅基余烬' : 'Silicon Ashes'}</span>
    </a>
    <nav>
      <a href={homeHref}>{isZh ? '主站' : 'Main'}</a>
      <a href={isZh ? '/silicon-ashes/courses/' : '/en/silicon-ashes/courses/'}>{isZh ? '课程' : 'Courses'}</a>
      <a href={isZh ? '/silicon-ashes/resources/' : '/en/silicon-ashes/resources/'}>{isZh ? '资源' : 'Resources'}</a>
      <a href={isZh ? '/silicon-ashes/about/' : '/en/silicon-ashes/about/'}>{isZh ? '关于' : 'About'}</a>
    </nav>
  </header>

  <main id="main">
    <section class="hero">
      <p class="eyebrow">{isZh ? '写作中心' : 'Writing'}</p>
      <h1>{isZh ? '少谈未来感，多看技术如何重排人' : 'Less futurism, more human consequence'}</h1>
      <p class="lead">{isZh ? '关于 AI、教育、科研方法与化工专业的写作。' : 'Writing about AI, education, research methods, and chemistry.'}</p>
    </section>

    <section class="series-section" aria-labelledby="series-title">
      <h2 id="series-title" class="section-title">{isZh ? '系列与文章' : 'Series and articles'}</h2>

      {Array.from(seriesMap.entries()).map(([seriesName, posts]) => (
        <div class="series-group">
          <h3 class="series-name">{seriesName}</h3>
          <div class="article-list">
            {posts.map((post) => (
              <a class="article-card" href={isZh ? `/silicon-ashes/writing/${post.id}/` : `/en/silicon-ashes/writing/${post.id}/`}>
                <div class="article-meta">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  {post.data.readingTime && <span class="reading-time">{post.data.readingTime} min</span>}
                  <span class={`audience-badge ${audienceClass(post.data.audience)}`}>{audienceLabel(post.data.audience)}</span>
                </div>
                <h4 class="article-title">{post.data.title}</h4>
                {post.data.description && <p class="article-desc">{post.data.description}</p>}
                {post.data.tags && (
                  <ul class="article-tags">
                    {post.data.tags.map((tag) => <li>{tag}</li>)}
                  </ul>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}

      {allPosts.length === 0 && (
        <p class="empty-state">{isZh ? '暂无文章，敬请期待。' : 'No articles yet. Stay tuned.'}</p>
      )}
    </section>
  </main>

  <footer class="wh-footer">
    <p>{isZh ? '硅基余烬 · 写作中心' : 'Silicon Ashes · Writing'}</p>
    <div>
      <a href={isZh ? '/silicon-ashes/' : '/en/silicon-ashes/'}>{isZh ? '主站' : 'Main site'}</a>
      <a href={`mailto:${common.person.email}`}>Email</a>
    </div>
  </footer>
</div>

<style>
  :global(html) { scroll-behavior: smooth; background: #080705; }
  :global(body) { margin: 0; background: #080705; color: #e9e0d0; font-family: 'Satoshi', 'Avenir Next', 'Segoe UI', 'Microsoft YaHei', sans-serif; }
  :global(*), :global(*::before), :global(*::after) { box-sizing: border-box; }
  :global(a) { color: inherit; }

  .wh-shell {
    min-height: 100dvh;
    overflow-x: hidden;
    background:
      linear-gradient(90deg, rgba(226,187,116,0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(226,187,116,0.028) 1px, transparent 1px),
      linear-gradient(180deg, #080705 0%, #0e0d0b 42%, #070706 100%);
    background-size: 64px 64px, 64px 64px, auto, auto;
  }

  .skip-link { position: fixed; top: 12px; left: 12px; z-index: 20; transform: translateY(-160%); border: 1px solid #d6a04f; border-radius: 4px; padding: 10px 12px; background: #e3b66c; color: #100d09; font-weight: 800; text-decoration: none; transition: transform 180ms ease; }
  .skip-link:focus { transform: translateY(0); }

  .wh-nav, main, .wh-footer { width: min(100% - 44px, 1240px); margin: 0 auto; }

  .wh-nav { position: sticky; top: 0; z-index: 12; display: flex; min-height: 76px; align-items: center; justify-content: space-between; gap: 24px; border-bottom: 1px solid rgba(218,166,86,0.2); background: rgba(8,7,5,0.86); backdrop-filter: blur(18px); }
  .wh-brand { display: inline-flex; min-height: 40px; align-items: center; gap: 12px; text-decoration: none; }
  .brand-mark { display: grid; width: 40px; height: 40px; place-items: center; border: 1px solid rgba(218,166,86,0.7); border-radius: 5px; background: linear-gradient(135deg, rgba(238,181,92,0.22), transparent 50%), #11100d; color: #ffe4aa; font-family: Consolas, 'SFMo-Regular', monospace; font-size: 13px; font-weight: 900; }
  .brand-name { color: #f3e3c5; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 20px; font-weight: 800; }
  .wh-nav nav { display: flex; align-items: center; gap: 6px; }
  .wh-nav nav a { display: inline-flex; min-height: 38px; align-items: center; border-radius: 4px; padding: 0 10px; color: rgba(233,224,208,0.72); font-size: 14px; font-weight: 700; text-decoration: none; transition: background 160ms ease, color 160ms ease; }
  .wh-nav nav a:hover { background: rgba(218,166,86,0.1); color: #ffe2aa; }

  .hero { padding: 100px 0 48px; max-width: 880px; }
  .eyebrow { margin: 0; color: #d8aa63; font-family: Consolas, 'SFMo-Regular', monospace; font-size: 13px; font-weight: 800; }
  h1, h2, h3, h4, p { overflow-wrap: anywhere; }
  h1 { margin: 22px 0 0; color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: clamp(2.8rem, 5vw, 4.2rem); font-weight: 800; line-height: 1.06; text-wrap: balance; }
  .lead { max-width: 680px; margin: 22px 0 0; color: rgba(233,224,208,0.76); font-size: 19px; line-height: 1.88; }

  .series-section { padding: 48px 0 120px; border-top: 1px solid rgba(218,166,86,0.18); }
  .section-title { color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 28px; font-weight: 800; margin: 0 0 40px; }

  .series-group { margin-bottom: 48px; }
  .series-name { color: #d8aa63; font-family: Consolas, 'SFMo-Regular', monospace; font-size: 15px; font-weight: 800; margin: 0 0 18px; padding-bottom: 10px; border-bottom: 1px solid rgba(218,166,86,0.18); }

  .article-list { display: grid; gap: 0; }
  .article-card { display: block; padding: 24px 0; border-bottom: 1px solid rgba(218,166,86,0.1); text-decoration: none; transition: background 160ms ease; }
  .article-card:hover { background: rgba(218,166,86,0.04); }
  .article-card:first-child { padding-top: 0; }

  .article-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .article-meta time { color: rgba(168,177,176,0.68); font-family: Consolas, 'SFMo-Regular', monospace; font-size: 13px; }
  .reading-time { color: rgba(168,177,176,0.5); font-family: Consolas, 'SFMo-Regular', monospace; font-size: 13px; }
  .audience-badge { display: inline-flex; height: 22px; align-items: center; padding: 0 8px; border-radius: 3px; font-size: 11px; font-weight: 800; }
  .audience-teacher { background: rgba(108,190,120,0.12); color: #6cbe78; }
  .audience-researcher { background: rgba(100,160,220,0.12); color: #6aa0dc; }
  .audience-general { background: rgba(168,177,176,0.08); color: rgba(168,177,176,0.6); }

  .article-title { margin: 0; color: #f2dfbd; font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif; font-size: 22px; font-weight: 800; line-height: 1.3; }
  .article-desc { margin: 8px 0 0; color: rgba(233,224,208,0.6); font-size: 15px; line-height: 1.6; }

  .article-tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; padding: 0; list-style: none; }
  .article-tags li { border: 1px solid rgba(168,177,176,0.18); border-radius: 3px; padding: 3px 8px; color: rgba(220,228,224,0.55); font-size: 12px; }

  .empty-state { color: rgba(233,224,208,0.4); font-size: 16px; }

  .wh-footer { display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 28px; align-items: start; border-top: 1px solid rgba(218,166,86,0.18); padding: 28px 0 40px; }
  .wh-footer p { margin: 0; font-size: 14px; color: rgba(233,224,208,0.5); }
  .wh-footer div { display: flex; gap: 14px; }
  .wh-footer a { display: inline-flex; min-height: 36px; min-width: 36px; align-items: center; color: rgba(233,224,208,0.72); font-size: 14px; text-decoration: none; }
  .wh-footer a:hover { color: #f2dfbd; }

  @media (max-width: 720px) {
    .wh-nav, main, .wh-footer { width: min(100% - 28px, 1240px); }
    .wh-nav { position: static; flex-direction: column; align-items: flex-start; padding: 14px 0; }
    .wh-nav nav { width: 100%; flex-wrap: wrap; }
    .hero { padding: 58px 0 36px; }
    h1 { font-size: 2.4rem; }
    .article-meta { flex-wrap: wrap; gap: 8px; }
    .wh-footer { grid-template-columns: 1fr; }
  }
</style>
