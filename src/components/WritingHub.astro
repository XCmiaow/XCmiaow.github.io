---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { SiliconEmbersLang } from '../data/siliconEmbersHome';

export interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
type BlogPost = CollectionEntry<'blog'>;

const allPosts = (
  await getCollection('blog', ({ data }) => {
    return data.lang === lang && !data.draft;
  })
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
};

const audienceLabel = (a?: string) => {
  if (a === 'teacher') return isZh ? '教师' : 'Teachers';
  if (a === 'researcher') return isZh ? '研究者' : 'Researchers';
  return isZh ? '通用' : 'General';
};

const audienceClass = (a?: string) => {
  if (a === 'teacher') return 'audience-teacher';
  if (a === 'researcher') return 'audience-researcher';
  return 'audience-general';
};

// Group by series
const seriesMap = new Map<string, BlogPost[]>();
for (const post of allPosts) {
  const key = post.data.series || (isZh ? '独立篇' : 'Standalone');
  const seriesPosts = seriesMap.get(key);
  if (seriesPosts) seriesPosts.push(post);
  else seriesMap.set(key, [post]);
}

const copy = isZh
  ? {
      eyebrow: 'blog / field notes',
      title: '少谈未来感，多看技术如何重排人',
      lead: '关于 AI、教育、科研方法与化工专业的博客。先把问题写清楚，再让工具进入现场。',
      articleCount: '文章',
      seriesCount: '系列',
      sectionTitle: '系列与文章',
      empty: '暂无文章，敬请期待。',
    }
  : {
      eyebrow: 'blog / field notes',
      title: 'Less futurism, more human consequence',
      lead: 'Blog essays about AI, education, research methods, and chemistry. Start with the problem, then let the tools enter the field.',
      articleCount: 'articles',
      seriesCount: 'series',
      sectionTitle: 'Series and articles',
      empty: 'No articles yet. Stay tuned.',
    };
---

<div class="writing-hub">
  <section class="writing-hero" aria-labelledby="writing-title">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 id="writing-title">{copy.title}</h1>
      <p class="lead">{copy.lead}</p>
    </div>
    <dl class="writing-stats" aria-label={isZh ? '博客统计' : 'Blog stats'}>
      <div>
        <dt>{copy.articleCount}</dt>
        <dd>{allPosts.length}</dd>
      </div>
      <div>
        <dt>{copy.seriesCount}</dt>
        <dd>{seriesMap.size}</dd>
      </div>
    </dl>
  </section>

  <section class="series-section" aria-labelledby="series-title">
    <h2 id="series-title" class="section-title">{copy.sectionTitle}</h2>

    {
      Array.from(seriesMap.entries()).map(([seriesName, posts]) => (
        <div class="series-group">
          <h3 class="series-name">{seriesName}</h3>
          <div class="article-list">
            {posts.map((post) => (
              <a
                class="article-card"
                href={isZh ? `/silicon-ashes/writing/${post.id}/` : `/en/silicon-ashes/writing/${post.id}/`}
              >
                <div class="article-meta">
                  <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                  {post.data.readingTime && <span class="reading-time">{post.data.readingTime} min</span>}
                  <span class={`audience-badge ${audienceClass(post.data.audience)}`}>
                    {audienceLabel(post.data.audience)}
                  </span>
                </div>
                <h4 class="article-title">{post.data.title}</h4>
                {post.data.description && <p class="article-desc">{post.data.description}</p>}
                {post.data.tags && (
                  <ul class="article-tags">
                    {post.data.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </a>
            ))}
          </div>
        </div>
      ))
    }

    {allPosts.length === 0 && <p class="empty-state">{copy.empty}</p>}
  </section>
</div>

<style>
  .writing-hub {
    padding-bottom: clamp(86px, 10vw, 132px);
  }

  .writing-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(190px, 0.26fr);
    gap: clamp(34px, 7vw, 92px);
    align-items: end;
    border-bottom: 1px solid var(--line);
    padding: clamp(86px, 12vw, 142px) 0 clamp(58px, 8vw, 92px);
  }

  h1,
  h2,
  h3,
  h4,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 960px;
    margin: 22px 0 0;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: clamp(3rem, 6.2vw, 6.4rem);
    font-weight: 850;
    line-height: 0.98;
    text-wrap: balance;
  }

  .lead {
    max-width: 720px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1.06rem, 1.65vw, 1.32rem);
    line-height: 1.86;
    text-wrap: pretty;
  }

  .writing-stats {
    display: grid;
    gap: 1px;
    margin: 0;
    border: 1px solid rgba(232, 174, 98, 0.18);
    background: rgba(232, 174, 98, 0.16);
  }

  .writing-stats div {
    padding: 18px;
    background: rgba(7, 6, 5, 0.88);
  }

  .writing-stats dt {
    color: rgba(239, 227, 205, 0.54);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 12px;
    font-weight: 900;
  }

  .writing-stats dd {
    margin: 8px 0 0;
    color: var(--paper);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    line-height: 1;
  }

  .series-section {
    padding: 48px 0 120px;
    border-top: 1px solid rgba(218, 166, 86, 0.18);
  }
  .section-title {
    color: #f2dfbd;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 40px;
  }

  .series-group {
    margin-bottom: 48px;
  }
  .series-name {
    color: #d8aa63;
    font-family: Consolas, 'SFMo-Regular', monospace;
    font-size: 15px;
    font-weight: 800;
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(218, 166, 86, 0.18);
  }

  .article-list {
    display: grid;
    gap: 0;
  }
  .article-card {
    display: block;
    padding: 24px 0;
    border-bottom: 1px solid rgba(218, 166, 86, 0.1);
    text-decoration: none;
    transition: background 160ms ease;
  }
  .article-card:hover {
    background: rgba(218, 166, 86, 0.04);
  }
  .article-card:first-child {
    padding-top: 0;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .article-meta time {
    color: rgba(168, 177, 176, 0.68);
    font-family: Consolas, 'SFMo-Regular', monospace;
    font-size: 13px;
  }
  .reading-time {
    color: rgba(168, 177, 176, 0.5);
    font-family: Consolas, 'SFMo-Regular', monospace;
    font-size: 13px;
  }
  .audience-badge {
    display: inline-flex;
    height: 22px;
    align-items: center;
    padding: 0 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 800;
  }
  .audience-teacher {
    background: rgba(108, 190, 120, 0.12);
    color: #6cbe78;
  }
  .audience-researcher {
    background: rgba(100, 160, 220, 0.12);
    color: #6aa0dc;
  }
  .audience-general {
    background: rgba(168, 177, 176, 0.08);
    color: rgba(168, 177, 176, 0.6);
  }

  .article-title {
    margin: 0;
    color: #f2dfbd;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    line-height: 1.3;
  }
  .article-desc {
    margin: 8px 0 0;
    color: rgba(233, 224, 208, 0.6);
    font-size: 15px;
    line-height: 1.6;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 10px 0 0;
    padding: 0;
    list-style: none;
  }
  .article-tags li {
    border: 1px solid rgba(168, 177, 176, 0.18);
    border-radius: 3px;
    padding: 3px 8px;
    color: rgba(220, 228, 224, 0.55);
    font-size: 12px;
  }

  .empty-state {
    color: rgba(233, 224, 208, 0.4);
    font-size: 16px;
  }

  @media (max-width: 720px) {
    .writing-hero {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 34px 0 30px;
    }

    h1 {
      margin-top: 12px;
      font-size: clamp(1.45rem, 6.4vw, 1.95rem);
      line-height: 1.16;
    }

    .lead {
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .writing-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .series-section {
      padding: 34px 0 64px;
    }

    .section-title {
      margin-bottom: 24px;
      font-size: 18px;
    }

    .article-card {
      padding: 18px 0;
    }

    .article-title {
      font-size: 16px;
      line-height: 1.34;
    }

    .article-desc {
      font-size: 14px;
      line-height: 1.58;
    }

    .writing-stats div {
      padding: 14px;
    }

    .writing-stats dd {
      font-size: 1.55rem;
    }

    .article-meta {
      flex-wrap: wrap;
      gap: 8px;
    }
  }

  @media (max-width: 360px) {
    h1 {
      font-size: clamp(1.38rem, 6.2vw, 1.72rem);
    }

    .writing-stats div {
      padding: 12px;
    }
  }
</style>
