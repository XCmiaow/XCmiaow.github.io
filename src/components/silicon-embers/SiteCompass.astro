---
import type { SiliconEmbersCompassItem } from '../../data/siliconEmbersHome';

interface Props {
  label: string;
  items: readonly SiliconEmbersCompassItem[];
}

const { label, items } = Astro.props;
---

<section class="compass" aria-label={label}>
  {
    items.map((item, index) => (
      <a class="compass-link" href={item.href}>
        <span class="compass-index">{String(index + 1).padStart(2, '0')}</span>
        <strong>{item.title}</strong>
        <em>{item.body}</em>
      </a>
    ))
  }
</section>

<style>
  .compass {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 0;
    background: transparent;
  }

  .compass::before {
    content: attr(aria-label);
    display: block;
    grid-column: 1 / -1;
    padding: 14px 0 8px;
    color: rgba(120, 155, 145, 0.72);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0;
  }

  .compass-link {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 3px 12px;
    min-height: 86px;
    align-content: center;
    border-right: 1px solid rgba(242, 223, 189, 0.1);
    padding: 16px;
    background: transparent;
    text-decoration: none;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .compass-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(125deg, rgba(232, 174, 98, 0.13), transparent 42%),
      radial-gradient(circle at 18% 0%, rgba(120, 155, 145, 0.18), transparent 34%);
    opacity: 0;
    transform: translateX(-14%);
    transition:
      opacity 180ms ease,
      transform 220ms ease;
  }

  .compass-link:last-child {
    border-right: 0;
  }

  .compass-link:hover,
  .compass-link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(120, 155, 145, 0.36);
    background: linear-gradient(150deg, rgba(232, 174, 98, 0.08), transparent 54%), rgba(242, 223, 189, 0.025);
    box-shadow:
      inset 0 1px 0 rgba(255, 238, 197, 0.08),
      0 18px 40px rgba(0, 0, 0, 0.24);
    outline: none;
  }

  .compass-link:hover::after,
  .compass-link:focus-visible::after {
    opacity: 1;
    transform: translateX(0);
  }

  .compass-index {
    grid-row: span 2;
    align-self: start;
    color: rgba(232, 174, 98, 0.7);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.35;
  }

  .compass-link:active {
    transform: translateY(1px) scale(0.99);
  }

  .compass-link strong {
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: 18px;
    font-weight: 850;
    line-height: 1.22;
  }

  .compass-link em {
    max-width: 24ch;
    color: rgba(239, 227, 205, 0.58);
    font-size: 13px;
    font-style: normal;
    line-height: 1.45;
  }

  @media (max-width: 720px) {
    .compass {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .compass-link:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 720px) {
    .compass {
      background: transparent;
      gap: 0;
    }

    .compass::before {
      grid-column: 1 / -1;
      padding: 10px 0 6px;
    }

    .compass-link {
      min-height: 72px;
      border-bottom: 1px solid var(--line);
      padding: 12px 14px;
      background: transparent;
    }

    .compass-link strong {
      font-size: 17px;
    }

    .compass-link em {
      font-size: 13px;
    }
  }
</style>
