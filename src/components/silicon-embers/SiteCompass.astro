---
import type { SiliconEmbersCompassItem } from '../../data/siliconEmbersHome';

interface Props {
  label: string;
  items: readonly SiliconEmbersCompassItem[];
}

const { label, items } = Astro.props;
---

<section class="compass" aria-labelledby="compass-label">
  <p id="compass-label" class="compass-label">{label}</p>
  <div class="compass-grid">
    {
      items.map((item, index) => (
        <a class="compass-link" href={item.href}>
          <span class="compass-index">{String(index + 1).padStart(2, '0')}</span>
          <strong>{item.title}</strong>
          <em>{item.body}</em>
          <span class="compass-arrow" aria-hidden="true">
            ↗
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .compass {
    border-bottom: 1px solid var(--line);
    padding: 1rem 0 0;
  }

  .compass-label {
    margin: 0 0 0.7rem;
    color: var(--ember-strong);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .compass-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.15fr 0.95fr;
    border-top: 1px solid var(--line);
  }

  .compass-link {
    position: relative;
    display: grid;
    min-height: 13rem;
    grid-template-columns: 2.8rem minmax(0, 1fr) auto;
    grid-template-rows: auto 1fr auto;
    gap: 1rem 1.25rem;
    border-right: 1px solid var(--line);
    padding: 1.25rem 1.5rem 1.5rem 0;
    text-decoration: none;
  }

  .compass-link + .compass-link {
    padding-left: 1.5rem;
  }

  .compass-link:last-child {
    border-right: 0;
  }

  .compass-link::before {
    content: '';
    position: absolute;
    top: -1px;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--ember-strong);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .compass-index {
    grid-row: 1 / span 2;
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  .compass-link strong {
    align-self: start;
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1;
  }

  .compass-link em {
    grid-column: 2;
    align-self: end;
    max-width: 23ch;
    color: var(--muted);
    font-size: 0.86rem;
    font-style: normal;
    line-height: 1.55;
  }

  .compass-arrow {
    grid-column: 3;
    grid-row: 1;
    color: var(--ember-strong);
    font-size: 1.15rem;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .compass-link:hover::before,
  .compass-link:focus-visible::before {
    transform: scaleX(1);
  }

  .compass-link:hover .compass-arrow,
  .compass-link:focus-visible .compass-arrow {
    transform: translate(0.25rem, -0.25rem);
  }

  .compass-link:focus-visible {
    outline: 2px solid var(--ember-strong);
    outline-offset: -2px;
  }

  .compass-link:active .compass-arrow {
    transform: translate(0.1rem, -0.1rem);
  }

  @media (max-width: 720px) {
    .compass-grid {
      grid-template-columns: 1fr;
    }

    .compass-link,
    .compass-link + .compass-link {
      min-height: 9rem;
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding: 1.15rem 0 1.4rem;
    }

    .compass-link:last-child {
      border-bottom: 0;
    }

    .compass-link strong {
      font-size: 2rem;
    }
  }
</style>
