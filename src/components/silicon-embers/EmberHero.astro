---
import EmberField from './EmberField.astro';
import FuzzyText from './FuzzyText.astro';
import type { SiliconEmbersHeroCopy } from '../../data/siliconEmbersHome';

interface Props {
  copy: SiliconEmbersHeroCopy;
  wordmark: string;
}

const { copy, wordmark } = Astro.props;
---

<section class="ember-hero" aria-labelledby="sa-title">
  <EmberField />

  <div class="hero-primary">
    <p class="hero-status" aria-hidden="true">
      <span>silicon—carbon archive</span>
      <span>field / active</span>
    </p>
    <p class="wordmark">{wordmark}</p>
    <h1 id="sa-title" class="hero-title">
      <FuzzyText
        fontSize="var(--hero-title-size)"
        fontWeight={780}
        fontFamily="var(--font-display)"
        color="var(--paper)"
        enableHover={true}
        baseIntensity={0.1}
        hoverIntensity={0.34}
        fuzzRange={18}
        fps={30}
        direction="horizontal"
        transitionDuration={8}
        clickEffect={false}
        gradient={['var(--paper)', 'var(--ember-strong)', 'var(--paper)']}
        letterSpacing={-1}
        className="hero-fuzzy-canvas"
      >
        {copy.title}
      </FuzzyText>
    </h1>
    <p class="lead">{copy.lead}</p>
  </div>

  <div class="hero-secondary">
    <p class="sublead">{copy.sublead}</p>
    <p class="field-note" aria-hidden="true">FIELD 01 · GRAVITY / MEMORY</p>
  </div>
</section>

<style>
  .ember-hero {
    position: relative;
    isolation: isolate;
    min-height: max(42rem, calc(100dvh - 72px));
    overflow: clip;
    border-bottom: 1px solid var(--line);
  }

  .ember-hero::before {
    content: '';
    position: absolute;
    inset: clamp(2.25rem, 6vh, 4.75rem) 0;
    z-index: 1;
    border-left: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
    border-right: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
    pointer-events: none;
  }

  /* carbon-reflection: restrained rust warmth over cold steel geometry. */
  .ember-hero::after {
    content: '';
    position: absolute;
    inset: 48% 0 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, transparent 0 22%, color-mix(in srgb, var(--rust) 10%, transparent) 68%, transparent),
      repeating-linear-gradient(
        96deg,
        transparent 0 3rem,
        color-mix(in srgb, var(--steel) 14%, transparent) 3rem calc(3rem + 1px),
        transparent calc(3rem + 1px) 6rem
      );
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 34%, transparent 94%);
    mask-image: linear-gradient(180deg, transparent, #000 34%, transparent 94%);
    opacity: 0.42;
  }

  .hero-primary,
  .hero-secondary {
    position: absolute;
    z-index: 2;
  }

  .hero-primary {
    top: clamp(2.9rem, 8vh, 5.5rem);
    left: clamp(1rem, 2.4vw, 2.25rem);
    width: min(29vw, 24rem);
  }

  .hero-secondary {
    right: clamp(1rem, 2.4vw, 2.25rem);
    bottom: clamp(3rem, 8vh, 5.75rem);
    display: grid;
    width: min(25vw, 20rem);
    justify-items: end;
    gap: 1.25rem;
    text-align: right;
  }

  .hero-status {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.8rem;
    margin: 0 0 clamp(1.9rem, 4vh, 3rem);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-status::before {
    content: '';
    width: 2rem;
    height: 1px;
    background: var(--ember-strong);
  }

  .wordmark {
    margin: 0 0 0.7rem;
    color: var(--ember-strong);
    font-family: var(--font-mono);
    font-size: clamp(0.74rem, 1vw, 0.88rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: lowercase;
  }

  .hero-title {
    --hero-title-size: clamp(3.1rem, 6vw, 5.2rem);

    display: inline-block;
    max-width: 8ch;
    font-size: clamp(3.1rem, 6vw, 5.2rem);
    line-height: 0.94;
    letter-spacing: -0.045em;
  }

  .hero-title :global(.hero-fuzzy-canvas) {
    filter: drop-shadow(0 0 16px color-mix(in srgb, var(--ember-strong) 35%, transparent));
  }

  .lead,
  .sublead,
  .field-note {
    margin: 0;
  }

  .lead {
    max-width: 21rem;
    margin-top: 1.45rem;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.45vw, 1.3rem);
    line-height: 1.55;
    text-wrap: balance;
  }

  .sublead {
    max-width: 25ch;
    color: var(--muted);
    font-size: clamp(0.86rem, 1vw, 0.98rem);
    line-height: 1.72;
    text-wrap: pretty;
  }

  .field-note {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: color-mix(in srgb, var(--muted) 68%, transparent);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.09em;
  }

  .field-note::before {
    content: '';
    width: 2.4rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ember-strong));
  }

  @media (max-width: 960px) {
    .hero-primary {
      width: min(31vw, 19rem);
    }

    .hero-secondary {
      width: min(28vw, 17rem);
    }

    .hero-title {
      --hero-title-size: clamp(3rem, 7vw, 4.65rem);

      font-size: var(--hero-title-size);
    }
  }

  @media (max-width: 720px) {
    .ember-hero {
      min-height: max(42rem, calc(100dvh - 7.25rem));
    }

    .ember-hero::before {
      inset: 1.25rem 0;
    }

    .hero-primary {
      top: 1.65rem;
      left: 0.8rem;
      width: min(76%, 18rem);
    }

    .hero-secondary {
      right: 0.8rem;
      bottom: 2rem;
      width: min(72%, 18rem);
      gap: 0.85rem;
    }

    .hero-status {
      max-width: 15rem;
      margin-bottom: 1.35rem;
      font-size: 0.55rem;
    }

    .hero-title {
      max-width: 7ch;
      --hero-title-size: clamp(2.65rem, 12.5vw, 3.75rem);

      font-size: var(--hero-title-size);
    }

    .lead {
      max-width: 17rem;
      margin-top: 0.9rem;
      font-size: clamp(0.9rem, 4vw, 1.05rem);
      line-height: 1.48;
    }

    .sublead {
      max-width: 21rem;
      font-size: 0.82rem;
    }
  }

  @media (max-width: 360px) {
    .hero-primary {
      top: 1.3rem;
    }

    .hero-secondary {
      bottom: 1.55rem;
    }

    .field-note {
      font-size: 0.53rem;
    }
  }
</style>
