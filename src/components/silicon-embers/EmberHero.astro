---
import EmberField from './EmberField.astro';
import ActionLinks from './ActionLinks.astro';
import type { SiliconEmbersHeroCopy } from '../../data/siliconEmbersHome';

interface Props {
  copy: SiliconEmbersHeroCopy;
  wordmark: string;
}

const { copy, wordmark } = Astro.props;
---

<section class="ember-hero" aria-labelledby="sa-title">
  <EmberField />

  <div class="hero-copy">
    <p class="observation-label" aria-hidden="true">
      <span>OBSERVATION</span>
      <span>01 / SILICON—CARBON</span>
    </p>
    {copy.eyebrow && <p class="eyebrow">{copy.eyebrow}</p>}
    <p class="wordmark">{wordmark}</p>
    <h1 id="sa-title">{copy.title}</h1>
    <div class="hero-statement">
      <p class="lead">{copy.lead}</p>
      <p class="sublead">{copy.sublead}</p>
    </div>
    <ActionLinks links={copy.actions} label={copy.actionsLabel} className="actions" linkClass="sa-button" />
  </div>

  <p class="scroll-cue" aria-hidden="true"><span></span>INDEX / 01—03</p>
</section>

<style>
  .ember-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: min(52rem, calc(100dvh - 4.5rem));
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: clamp(5rem, 10vh, 7.5rem) 0 clamp(6rem, 12vh, 9rem);
  }

  .ember-hero::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: clamp(12rem, 38vw, 31rem);
    z-index: 1;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--line) 18% 82%, transparent);
    opacity: 0.48;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 62rem;
  }

  .observation-label {
    display: flex;
    max-width: 31rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 clamp(2.5rem, 5.5vh, 4.6rem);
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.66rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.12em;
  }

  .observation-label span:first-child {
    color: var(--ember-strong);
  }

  .wordmark {
    margin: 0 0 0.8rem;
    color: var(--ember-strong);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: clamp(0.8rem, 1.1vw, 1rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: lowercase;
  }

  h1 {
    max-width: 7ch;
    font-size: clamp(4.8rem, 10.5vw, 10.8rem);
    line-height: 0.84;
    letter-spacing: -0.055em;
  }

  .hero-statement {
    display: grid;
    max-width: 47rem;
    grid-template-columns: minmax(0, 1.15fr) minmax(14rem, 0.65fr);
    gap: 1.4rem clamp(2rem, 5vw, 5rem);
    align-items: start;
    margin-top: clamp(2rem, 5vh, 3.5rem);
  }

  .lead,
  .sublead {
    margin: 0;
  }

  .lead {
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(1.25rem, 2.3vw, 2rem);
    line-height: 1.42;
  }

  .sublead {
    max-width: 30ch;
    padding-top: 0.25rem;
    color: var(--muted);
    font-size: clamp(0.92rem, 1.15vw, 1.05rem);
    line-height: 1.72;
  }

  :global(.ember-hero .actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  :global(.ember-hero .actions .sa-button) {
    min-width: 7rem;
  }

  .scroll-cue {
    position: absolute;
    right: 0;
    bottom: 1.1rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }

  .scroll-cue span {
    width: 2.6rem;
    height: 1px;
    background: var(--ember-strong);
  }

  @media (max-width: 960px) {
    .ember-hero::before {
      left: 48%;
    }

    .hero-copy {
      max-width: 49rem;
    }

    h1 {
      font-size: clamp(4.4rem, 13vw, 8rem);
    }
  }

  @media (max-width: 720px) {
    .ember-hero {
      min-height: 42rem;
      align-items: end;
      padding: 4rem 0 5rem;
    }

    .ember-hero::before {
      display: none;
    }

    .hero-copy {
      width: 100%;
      max-width: 34rem;
    }

    .observation-label {
      max-width: 21rem;
      margin-bottom: 10.5rem;
      font-size: 0.58rem;
    }

    h1 {
      max-width: 5.5ch;
      font-size: clamp(3.5rem, 19vw, 6rem);
      line-height: 0.9;
    }

    .hero-statement {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      margin-top: 1.6rem;
    }

    .lead {
      max-width: 23rem;
      font-size: clamp(1.1rem, 5.5vw, 1.45rem);
    }

    .sublead {
      max-width: 26rem;
      padding-top: 0;
      font-size: 0.88rem;
    }

    :global(.ember-hero .actions) {
      margin-top: 1.4rem;
    }

    .scroll-cue {
      display: none;
    }
  }

  @media (max-width: 360px) {
    .observation-label {
      margin-bottom: 9.5rem;
    }

    :global(.ember-hero .actions .sa-button) {
      min-width: 0;
    }
  }
</style>
