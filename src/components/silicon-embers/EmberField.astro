---
import Ferrofluid from './Ferrofluid.astro';
---

<div class="ember-stage" aria-hidden="true">
  <div class="depth-far">
    <div class="cosmic-grain"></div>
    <span class="orbital-guide guide-outer"></span>
    <span class="orbital-guide guide-inner"></span>
  </div>

  <div class="black-hole-scene">
    <div class="gravity-veil"></div>

    <div class="depth-rear">
      <div class="lensing-arc arc-back"></div>
      <div class="accretion-disc disc-back"><span class="disc-filament"></span></div>
    </div>

    <div class="depth-fluid">
      <Ferrofluid
        colors={['#d79a52', '#c9793f', '#9b5630', '#4f2c1d']}
        backgroundColor="transparent"
        speed={0.58}
        scale={1.28}
        turbulence={1.12}
        fluidity={0.08}
        rimWidth={0.12}
        sharpness={3.2}
        shimmer={0.72}
        glow={1.56}
        flowDirection="down"
        opacity={0.24}
        mouseInteraction={true}
        mouseStrength={0.38}
        mouseRadius={0.28}
        mouseDampening={0.24}
        dpr={1}
        mixBlendMode="screen"
        className="magnetic-fluid"
      />
    </div>

    <div class="depth-event">
      <div class="photon-ring"><span class="photon-caustic"></span></div>
      <div class="event-horizon"></div>
    </div>

    <div class="depth-front">
      <div class="accretion-disc disc-front"><span class="disc-filament"></span></div>
      <div class="lensing-arc arc-front"></div>
    </div>
  </div>

  <canvas data-ember-canvas></canvas>
  <div class="depth-near"><span class="foreground-dust"></span></div>
</div>

<style>
  .ember-stage {
    --hole-x: 50%;
    --hole-y: 50%;
    --hole-size: min(42vw, 560px);

    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: clip;
    pointer-events: none;
    mask-image: linear-gradient(90deg, transparent 0%, #000 10%, #000 94%, transparent 100%);
  }

  .ember-stage::before,
  .ember-stage::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ember-stage::before {
    z-index: 1;
    background:
      radial-gradient(
        circle at var(--hole-x) var(--hole-y),
        transparent 0 13%,
        rgba(180, 105, 50, 0.05) 31%,
        transparent 59%
      ),
      linear-gradient(90deg, rgba(7, 6, 4, 0.97), rgba(7, 6, 4, 0.5) 31%, transparent 61%);
  }

  .ember-stage::after {
    z-index: 10;
    background:
      radial-gradient(circle at 0 0, rgba(7, 6, 4, 0.9), rgba(7, 6, 4, 0.34) 24%, transparent 48%),
      radial-gradient(circle at 100% 100%, rgba(7, 6, 4, 0.72), rgba(7, 6, 4, 0.2) 22%, transparent 46%);
  }

  .depth-far,
  .depth-near,
  canvas {
    position: absolute;
    inset: 0;
  }

  .depth-far {
    z-index: 0;
  }

  .cosmic-grain {
    position: absolute;
    inset: 8% 0 10% 14%;
    background-image:
      radial-gradient(circle at 14% 28%, rgba(244, 220, 177, 0.34) 0 0.5px, transparent 1px),
      radial-gradient(circle at 68% 18%, rgba(230, 183, 124, 0.26) 0 0.65px, transparent 1.1px),
      radial-gradient(circle at 87% 72%, rgba(244, 220, 177, 0.2) 0 0.55px, transparent 1.1px),
      radial-gradient(circle at 43% 81%, rgba(210, 137, 77, 0.24) 0 0.7px, transparent 1.25px);
    background-size:
      163px 149px,
      211px 197px,
      241px 223px,
      179px 191px;
    opacity: 0.34;
    mask-image: radial-gradient(ellipse at var(--hole-x) var(--hole-y), #000 0 34%, transparent 76%);
  }

  .orbital-guide {
    position: absolute;
    top: var(--hole-y);
    left: var(--hole-x);
    border: 1px solid rgba(225, 176, 112, 0.075);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.72);
  }

  .guide-outer {
    width: calc(var(--hole-size) * 1.46);
    aspect-ratio: 1;
  }

  .guide-inner {
    width: calc(var(--hole-size) * 0.92);
    aspect-ratio: 1;
    border-style: dashed;
    border-color: rgba(225, 176, 112, 0.055);
    transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.72) rotate(7deg);
  }

  canvas {
    z-index: 8;
    width: 100%;
    height: 100%;
  }

  .black-hole-scene {
    position: absolute;
    top: var(--hole-y);
    left: var(--hole-x);
    z-index: 3;
    width: var(--hole-size);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
  }

  .gravity-veil,
  .depth-rear,
  .depth-event,
  .depth-fluid,
  .depth-front,
  .lensing-arc,
  .accretion-disc,
  .photon-ring,
  .event-horizon {
    position: absolute;
  }

  .gravity-veil {
    inset: -28%;
    z-index: -1;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(0, 0, 0, 0.95) 0 14%, rgba(0, 0, 0, 0.48) 24%, transparent 45%),
      radial-gradient(ellipse, rgba(178, 100, 45, 0.14) 0 13%, rgba(74, 42, 23, 0.1) 34%, transparent 67%);
    filter: blur(23px);
    opacity: 0.9;
    transform: rotate(-12deg) scale(1.2, 0.82);
    animation: gravity-breathe 18s ease-in-out infinite;
  }

  .depth-rear,
  .depth-event,
  .depth-front {
    inset: 0;
  }

  .depth-rear {
    z-index: 2;
  }

  .depth-event {
    z-index: 4;
  }

  .depth-fluid {
    inset: -16%;
    z-index: 5;
    pointer-events: none;
    filter: saturate(0.82) contrast(0.98) blur(0.28px);
    opacity: 0.46;
    transform: rotate(-12deg) scale(1.06, 0.8);
    -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 0 13%, #000 24% 78%, transparent 94%);
    mask-image: radial-gradient(circle at 50% 50%, transparent 0 13%, #000 24% 78%, transparent 94%);
    animation: fluid-tide 8.5s ease-in-out infinite;
    will-change: transform;
  }

  .depth-fluid :global(.magnetic-fluid) {
    width: 100%;
    height: 100%;
  }

  @keyframes fluid-tide {
    0%,
    100% {
      transform: rotate(-12deg) scale(1.06, 0.8) translate3d(-0.7%, 0.2%, 0);
    }
    50% {
      transform: rotate(-10.2deg) scale(1.1, 0.84) translate3d(1.4%, -0.6%, 0);
    }
  }

  .depth-front {
    z-index: 6;
  }

  .lensing-arc {
    top: 50%;
    left: 50%;
    width: 69%;
    height: 69%;
    border-radius: 50%;
    transform-origin: center;
  }

  .arc-back {
    border-top: 1px solid rgba(250, 214, 158, 0.56);
    border-left: 1px solid rgba(197, 119, 57, 0.14);
    clip-path: inset(0 0 50% 0);
    filter: drop-shadow(0 -4px 10px rgba(221, 139, 68, 0.18));
    opacity: 0.72;
    transform: translate(-50%, -50%) rotate(-13deg) scale(1.25, 0.96);
  }

  .arc-front {
    border-right: 1px solid rgba(229, 158, 91, 0.24);
    border-bottom: 1px solid rgba(255, 205, 137, 0.64);
    clip-path: inset(50% 0 0 0);
    filter: drop-shadow(0 5px 12px rgba(226, 142, 69, 0.18));
    opacity: 0.62;
    transform: translate(-50%, -50%) rotate(-13deg) scale(1.19, 0.94);
  }

  .accretion-disc {
    top: 50%;
    left: 50%;
    width: 152%;
    height: 38%;
    border-radius: 50%;
    background:
      radial-gradient(
        ellipse at center,
        transparent 0 31%,
        rgba(255, 226, 167, 0.72) 34%,
        rgba(213, 126, 57, 0.36) 39%,
        transparent 55%
      ),
      conic-gradient(
        from 193deg,
        transparent 0 8%,
        rgba(152, 77, 34, 0.08) 16%,
        rgba(236, 159, 82, 0.5) 29%,
        rgba(255, 226, 159, 0.86) 38%,
        rgba(145, 72, 32, 0.12) 53%,
        transparent 63% 82%,
        rgba(210, 119, 50, 0.2) 91%,
        transparent
      );
    mix-blend-mode: screen;
    mask-image: radial-gradient(ellipse at center, transparent 0 30%, #000 34% 47%, transparent 57%);
    transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.46);
  }

  .disc-back {
    clip-path: inset(0 0 49% 0);
    filter: blur(1.3px);
    opacity: 0.58;
    animation: rear-drift 31s ease-in-out infinite;
  }

  .disc-front {
    clip-path: inset(49% 0 0 0);
    filter: blur(0.45px) drop-shadow(0 4px 9px rgba(215, 128, 54, 0.18));
    opacity: 0.9;
    transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.5);
    animation: front-drift 25s ease-in-out infinite;
  }

  .disc-filament {
    position: absolute;
    inset: 15% 8%;
    border: 1px solid rgba(255, 224, 164, 0.24);
    border-radius: 50%;
    opacity: 0.72;
  }

  .photon-ring {
    top: 50%;
    left: 50%;
    width: 38%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: conic-gradient(
      from 218deg,
      rgba(109, 56, 27, 0.1),
      rgba(244, 180, 101, 0.94) 18%,
      rgba(255, 230, 174, 1) 26%,
      rgba(183, 94, 40, 0.24) 43%,
      rgba(75, 39, 22, 0.08) 66%,
      rgba(224, 138, 65, 0.52) 88%,
      rgba(109, 56, 27, 0.1)
    );
    filter: blur(0.25px) drop-shadow(-7px -1px 11px rgba(229, 151, 74, 0.26));
    mask-image: radial-gradient(circle, transparent 0 41%, #000 44% 50%, transparent 54%);
    transform: translate(-50%, -50%);
    animation: photon-turn 58s linear infinite;
  }

  .photon-caustic {
    position: absolute;
    inset: 2%;
    border: 1px solid transparent;
    border-bottom-color: rgba(255, 235, 194, 0.5);
    border-left-color: rgba(255, 210, 139, 0.32);
    border-radius: 50%;
    filter: blur(0.4px);
    transform: rotate(34deg);
  }

  .event-horizon {
    top: 50%;
    left: 50%;
    width: 29%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 34%, #100b07 0 8%, #060403 38%, #010101 78%);
    box-shadow:
      inset 9px 7px 18px rgba(137, 78, 38, 0.08),
      inset -14px -16px 28px rgba(0, 0, 0, 0.96),
      0 0 0 1px rgba(238, 183, 111, 0.14),
      0 0 38px rgba(0, 0, 0, 0.9),
      0 0 62px rgba(72, 39, 20, 0.18);
    transform: translate(-50%, -50%);
  }

  .event-horizon::after {
    content: '';
    position: absolute;
    inset: 12%;
    border-radius: 50%;
    background: radial-gradient(circle at 42% 38%, rgba(86, 48, 25, 0.12), rgba(2, 2, 1, 0.92) 48%, #000 85%);
    box-shadow: inset -7px -8px 16px rgba(0, 0, 0, 0.88);
  }

  .depth-near {
    z-index: 9;
    overflow: hidden;
    opacity: 0.68;
  }

  .foreground-dust {
    position: absolute;
    top: 24%;
    right: 6%;
    width: 28%;
    height: 48%;
    background-image:
      radial-gradient(circle at 22% 20%, rgba(255, 218, 159, 0.55) 0 0.7px, transparent 1.8px),
      radial-gradient(circle at 78% 39%, rgba(205, 123, 55, 0.42) 0 1px, transparent 2.4px),
      radial-gradient(circle at 47% 81%, rgba(244, 220, 177, 0.38) 0 0.8px, transparent 2px);
    filter: blur(0.25px);
    opacity: 0.5;
    animation: near-drift 19s ease-in-out infinite;
  }

  @keyframes photon-turn {
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  @keyframes gravity-breathe {
    0%,
    100% {
      opacity: 0.78;
      transform: rotate(-12deg) scale(1.17, 0.8);
    }
    50% {
      opacity: 0.94;
      transform: rotate(-10.5deg) scale(1.21, 0.84);
    }
  }

  @keyframes rear-drift {
    0%,
    100% {
      opacity: 0.52;
      transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.46);
    }
    50% {
      opacity: 0.62;
      transform: translate(-50%, -50%) rotate(-10.8deg) scaleY(0.48);
    }
  }

  @keyframes front-drift {
    0%,
    100% {
      opacity: 0.84;
      transform: translate(-50%, -50%) rotate(-12deg) scaleY(0.5);
    }
    50% {
      opacity: 0.94;
      transform: translate(-50%, -50%) rotate(-13deg) scaleY(0.52);
    }
  }

  @keyframes near-drift {
    0%,
    100% {
      opacity: 0.36;
      transform: translate3d(0, 0, 0);
    }
    50% {
      opacity: 0.58;
      transform: translate3d(-6px, 4px, 0);
    }
  }

  @media (max-width: 960px) {
    .ember-stage {
      --hole-size: min(50vw, 460px);

      opacity: 0.9;
    }
  }

  @media (max-width: 720px) {
    .ember-stage {
      --hole-size: min(78vw, 320px);

      opacity: 0.88;
      mask-image: linear-gradient(180deg, transparent 0%, #000 14%, #000 86%, transparent 100%);
    }

    .ember-stage::after {
      background: radial-gradient(circle at var(--hole-x) var(--hole-y), transparent 0 34%, rgba(7, 6, 4, 0.08) 70%);
    }

    .accretion-disc {
      width: 116%;
      height: 42%;
    }

    .guide-outer,
    .guide-inner,
    .foreground-dust {
      display: none;
    }

    .depth-fluid {
      inset: -10%;
      opacity: 0.34;
      animation-duration: 9.5s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gravity-veil,
    .disc-back,
    .disc-front,
    .photon-ring,
    .foreground-dust,
    .depth-fluid {
      animation: none;
    }
  }
</style>

<script>
  import './emberFieldCanvas';
</script>
