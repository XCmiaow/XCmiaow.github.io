---
export type FerrofluidFlowDirection = 'up' | 'down' | 'left' | 'right';

export interface Props {
  colors?: string[];
  backgroundColor?: string;
  speed?: number;
  scale?: number;
  turbulence?: number;
  fluidity?: number;
  rimWidth?: number;
  sharpness?: number;
  shimmer?: number;
  glow?: number;
  flowDirection?: FerrofluidFlowDirection;
  opacity?: number;
  mouseInteraction?: boolean;
  mouseStrength?: number;
  mouseRadius?: number;
  mouseDampening?: number;
  paused?: boolean;
  dpr?: number;
  mixBlendMode?: string;
  className?: string;
}

const {
  colors = ['#d79a52', '#c9793f', '#9b5630', '#4f2c1d'],
  backgroundColor = 'transparent',
  speed = 0.58,
  scale = 1.28,
  turbulence = 1.12,
  fluidity = 0.08,
  rimWidth = 0.12,
  sharpness = 3.2,
  shimmer = 0.72,
  glow = 1.56,
  flowDirection = 'down',
  opacity = 0.24,
  mouseInteraction = true,
  mouseStrength = 0.38,
  mouseRadius = 0.28,
  mouseDampening = 0.24,
  paused = false,
  dpr = 1,
  mixBlendMode,
  className = '',
} = Astro.props;

const config = {
  colors,
  speed,
  scale,
  turbulence,
  fluidity,
  rimWidth,
  sharpness,
  shimmer,
  glow,
  flowDirection,
  opacity,
  mouseInteraction,
  mouseStrength,
  mouseRadius,
  mouseDampening,
  paused,
  dpr,
};
const classes = ['ferrofluid-container', className].filter(Boolean).join(' ');
const style = [
  backgroundColor ? `background: ${backgroundColor}` : '',
  mixBlendMode ? `mix-blend-mode: ${mixBlendMode}` : '',
]
  .filter(Boolean)
  .join('; ');
---

<div
  class={classes}
  data-ferrofluid-root
  data-ferrofluid-config={JSON.stringify(config)}
  style={style}
  aria-hidden="true"
>
</div>

<script>
  import './ferrofluidCanvas';
</script>

<style>
  .ferrofluid-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    contain: strict;
  }

  .ferrofluid-container canvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 260ms ease;
  }

  .ferrofluid-container[data-ferrofluid-ready='true'] canvas {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ferrofluid-container canvas {
      transition: none;
    }
  }
</style>
