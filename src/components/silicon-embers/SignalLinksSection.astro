---
import ActionLinks from './ActionLinks.astro';
import type { SiliconEmbersLinkSectionCopy } from '../../data/siliconEmbersHome';

type SectionVariant = 'course-signal' | 'resource-band';

interface Props {
  id: string;
  titleId: string;
  variant: SectionVariant;
  copy: SiliconEmbersLinkSectionCopy;
}

const { id, titleId, variant, copy } = Astro.props;
---

<section id={id} class={variant} aria-labelledby={titleId}>
  <div class="section-copy">
    <p class="kicker">{copy.kicker}</p>
    <h2 id={titleId}>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>
  <ActionLinks links={copy.links} className={variant === 'course-signal' ? 'signal-links' : 'resource-links'} />
</section>

<style>
  .course-signal,
  .resource-band {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(17rem, 0.55fr);
    gap: clamp(3rem, 9vw, 9rem);
    align-items: end;
    border-block: 1px solid var(--line);
    padding: clamp(88px, 11vw, 148px) 0;
  }

  .course-signal::before,
  .resource-band::before {
    content: '';
    position: absolute;
    inset: -35% -8% -45% 42%;
    z-index: -1;
    background: radial-gradient(circle, rgba(190, 108, 48, 0.12), transparent 64%);
    filter: blur(34px);
  }

  .section-copy h2 {
    max-width: 11ch;
  }

  :global(.signal-links),
  :global(.resource-links) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  :global(.resource-links .sa-control),
  :global(.signal-links .sa-control) {
    justify-content: flex-start;
  }

  @media (max-width: 960px) {
    .course-signal,
    .resource-band {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  @media (max-width: 720px) {
    .course-signal,
    .resource-band {
      padding: 4rem 0;
    }

    :global(.signal-links),
    :global(.resource-links) {
      grid-template-columns: 1fr;
    }
  }
</style>
