---
import ActionButton from './ActionButton.astro';
import type { SiliconEmbersLinkSectionCopy } from '../../data/siliconEmbersHome';

type SectionVariant = 'course-signal' | 'resource-band';

interface Props {
  id: string;
  titleId: string;
  variant: SectionVariant;
  copy: SiliconEmbersLinkSectionCopy;
}

const { id, titleId, variant, copy } = Astro.props;
---

<section id={id} class={variant} aria-labelledby={titleId}>
  <div class="section-copy">
    <p class="kicker">{copy.kicker}</p>
    <h2 id={titleId}>{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <ol class="signal-links">
    {
      copy.links.map((link, index) => (
        <li class="resource-record">
          <span class="resource-index" aria-hidden="true">
            R.{String(index + 1).padStart(2, '0')}
          </span>
          <ActionButton href={link.href} variant="text" className="resource-link">
            {link.label}
          </ActionButton>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .course-signal,
  .resource-band {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(18rem, 0.62fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: end;
    border-block: 1px solid var(--line);
    padding: clamp(5.5rem, 8vw, 8.5rem) 0;
  }

  .course-signal::before,
  .resource-band::before {
    display: none;
  }

  .resource-band {
    grid-template-columns: minmax(0, 0.7fr) minmax(18rem, 0.55fr);
    gap: clamp(2.5rem, 7vw, 7rem);
    padding: var(--space-section) 0;
  }

  .section-copy h2 {
    max-width: 11ch;
  }

  .signal-links {
    display: grid;
    margin: 0;
    border-top: 1px solid var(--line);
    padding: 0;
    list-style: none;
  }

  .resource-record {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr);
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .resource-index {
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.66rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
  }

  :global(.resource-record .resource-link) {
    min-height: 3.35rem;
    justify-content: space-between;
    border: 0;
    padding-inline: 0;
    background: transparent;
    color: var(--paper);
  }

  :global(.resource-record .resource-link:hover),
  :global(.resource-record .resource-link:focus-visible) {
    background: transparent;
  }

  @media (max-width: 960px) {
    .course-signal,
    .resource-band {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  @media (max-width: 720px) {
    .course-signal,
    .resource-band {
      padding: 5rem 0;
    }
  }
</style>
