---
import type { SiliconEmbersThesisCopy } from '../../data/siliconEmbersHome';

interface Props {
  copy: SiliconEmbersThesisCopy;
}

const { copy } = Astro.props;
---

<section class="brand-manifesto" aria-labelledby="manifesto-title">
  <div class="manifesto-copy">
    <p class="kicker">{copy.kicker}</p>
    <h2 id="manifesto-title">{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <ol class="principle-list">
    {
      copy.principles.map((principle, index) => (
        <li class="principle-trace">
          <span class="principle-index">{String(index + 1).padStart(2, '0')}</span>
          <span class="principle-rule" aria-hidden="true" />
          <strong>{principle.title}</strong>
          <p>{principle.body}</p>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .brand-manifesto {
    border-bottom: 1px solid var(--line);
    padding: clamp(5.5rem, 8vw, 8.5rem) 0;
  }

  .manifesto-copy {
    display: grid;
    width: min(100%, 68rem);
    grid-template-columns: minmax(0, 0.95fr) minmax(15rem, 0.52fr);
    gap: 1.4rem 6vw;
    align-items: end;
  }

  .manifesto-copy .kicker,
  .manifesto-copy h2 {
    grid-column: 1;
  }

  .manifesto-copy h2 {
    max-width: 11ch;
    margin-top: 0.8rem;
    font-size: clamp(2.9rem, 5.1vw, 5rem);
    line-height: 0.98;
  }

  .manifesto-copy > p:last-child {
    grid-column: 2;
    grid-row: 2;
    max-width: 34ch;
    margin: 0 0 0.2rem;
    color: var(--muted);
    font-size: clamp(0.94rem, 1.15vw, 1.04rem);
    line-height: 1.78;
  }

  .principle-list {
    display: grid;
    gap: 0;
    width: min(100%, 69rem);
    margin: clamp(3.4rem, 6vw, 5.8rem) 0 0 auto;
    padding: 0;
    list-style: none;
  }

  .principle-trace {
    display: grid;
    width: 76%;
    min-height: 6.8rem;
    grid-template-columns: 2.2rem minmax(2rem, 0.22fr) minmax(8rem, 0.48fr) minmax(13rem, 1fr);
    gap: 1.1rem;
    align-items: center;
    border-top: 1px solid var(--line);
    padding: 1.15rem 0;
  }

  .principle-trace:nth-child(2) {
    width: 68%;
    margin-left: 16%;
  }

  .principle-trace:nth-child(3) {
    width: 74%;
    margin-left: 7%;
    border-bottom: 1px solid var(--line);
  }

  .principle-index {
    color: var(--ember-strong);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  .principle-rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--ember-strong), var(--line));
  }

  .principle-trace strong {
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(1.25rem, 1.8vw, 1.6rem);
  }

  .principle-trace p {
    max-width: 28ch;
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.68;
  }

  @media (max-width: 820px) {
    .principle-trace,
    .principle-trace:nth-child(2),
    .principle-trace:nth-child(3) {
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 720px) {
    .brand-manifesto {
      padding: 5rem 0;
    }

    .manifesto-copy {
      grid-template-columns: 1fr;
    }

    .manifesto-copy > p:last-child {
      grid-column: 1;
      grid-row: auto;
    }

    .principle-list {
      margin-top: 3rem;
    }

    .principle-trace {
      min-height: auto;
      grid-template-columns: 2rem 1.3rem minmax(0, 1fr);
      gap: 0.8rem;
      padding: 1.25rem 0;
    }

    .principle-trace p {
      grid-column: 3;
    }
  }
</style>
