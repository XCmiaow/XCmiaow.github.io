---
import type { SiliconEmbersOperatingSystemCopy, SiliconEmbersThesisCopy } from '../../data/siliconEmbersHome';

interface Props {
  copy: SiliconEmbersThesisCopy;
  method: SiliconEmbersOperatingSystemCopy;
}

const { copy, method } = Astro.props;
---

<section class="brand-manifesto" aria-labelledby="manifesto-title">
  <div class="manifesto-copy">
    <p class="kicker">{copy.kicker}</p>
    <h2 id="manifesto-title">{copy.title}</h2>
    <p>{copy.body}</p>
  </div>

  <ol class="principle-list">
    {
      copy.principles.map((principle, index) => (
        <li class="principle-trace">
          <span class="principle-index">{String(index + 1).padStart(2, '0')}</span>
          <span class="principle-rule" aria-hidden="true" />
          <strong>{principle.title}</strong>
          <p>{principle.body}</p>
        </li>
      ))
    }
  </ol>

  <section class="method-section" aria-labelledby="method-title">
    <div class="method-head">
      <p class="kicker">{method.kicker}</p>
      <h2 id="method-title">{method.title}</h2>
      <p>{method.body}</p>
    </div>

    <ol class="method-rail method-track" aria-label={method.railLabel}>
      {
        method.phases.map((phase, index) => (
          <li>
            <span class="phase-index">{String(index + 1).padStart(2, '0')}</span>
            <span class="phase-code">{phase.code}</span>
            <strong>{phase.title}</strong>
            <p>{phase.body}</p>
            <em>{phase.output}</em>
          </li>
        ))
      }
    </ol>
  </section>
</section>

<style>
  .brand-manifesto {
    border-bottom: 1px solid var(--line);
    padding: clamp(5.5rem, 8vw, 8.5rem) 0;
  }

  .manifesto-copy {
    display: grid;
    width: min(100%, 68rem);
    grid-template-columns: minmax(0, 0.95fr) minmax(15rem, 0.52fr);
    gap: 1.4rem 6vw;
    align-items: end;
  }

  .manifesto-copy .kicker,
  .manifesto-copy h2 {
    grid-column: 1;
  }

  .manifesto-copy h2 {
    max-width: 11ch;
    margin-top: 0.8rem;
    font-size: clamp(2.9rem, 5.1vw, 5rem);
    line-height: 0.98;
  }

  .manifesto-copy > p:last-child {
    grid-column: 2;
    grid-row: 2;
    max-width: 34ch;
    margin: 0 0 0.2rem;
    color: var(--muted);
    font-size: clamp(0.94rem, 1.15vw, 1.04rem);
    line-height: 1.78;
  }

  .principle-list {
    display: grid;
    gap: 0;
    width: min(100%, 69rem);
    margin: clamp(3.4rem, 6vw, 5.8rem) 0 0 auto;
    padding: 0;
    list-style: none;
  }

  .principle-trace {
    display: grid;
    width: 76%;
    min-height: 6.8rem;
    grid-template-columns: 2.2rem minmax(2rem, 0.22fr) minmax(8rem, 0.48fr) minmax(13rem, 1fr);
    gap: 1.1rem;
    align-items: center;
    border-top: 1px solid var(--line);
    padding: 1.15rem 0;
  }

  .principle-trace:nth-child(2) {
    width: 68%;
    margin-left: 16%;
  }

  .principle-trace:nth-child(3) {
    width: 74%;
    margin-left: 7%;
    border-bottom: 1px solid var(--line);
  }

  .principle-index,
  .phase-index,
  .phase-code {
    color: var(--ember-strong);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  .principle-rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--ember-strong), var(--line));
  }

  .principle-trace strong {
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(1.25rem, 1.8vw, 1.6rem);
  }

  .principle-trace p {
    max-width: 28ch;
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.68;
  }

  .method-section {
    margin-top: clamp(5.5rem, 9vw, 8.5rem);
  }

  .method-head {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(16rem, 0.4fr);
    gap: 1rem 6vw;
    align-items: end;
  }

  .method-head .kicker,
  .method-head h2 {
    grid-column: 1;
  }

  .method-head h2 {
    max-width: 12ch;
    margin-top: 0.75rem;
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 1;
  }

  .method-head > p:last-child {
    grid-column: 2;
    grid-row: 2;
    max-width: 34ch;
    margin: 0 0 0.15rem;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.72;
  }

  .method-track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin: 2.8rem 0 0;
    border-top: 1px solid var(--line);
    padding: 0;
    list-style: none;
  }

  .method-track li {
    position: relative;
    display: grid;
    min-height: 12.5rem;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.65rem 1rem;
    padding: 1rem clamp(1rem, 2vw, 1.5rem) 1.25rem 0;
  }

  .method-track li + li {
    padding-left: clamp(1rem, 2vw, 1.5rem);
  }

  .method-track li::before {
    content: '';
    position: absolute;
    top: -3px;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ember-strong);
    box-shadow: 0 0 0 4px var(--coal);
  }

  .phase-code {
    color: var(--muted);
  }

  .method-track strong {
    grid-column: 1 / -1;
    margin-top: 1.4rem;
    color: var(--paper);
    font-size: clamp(1.05rem, 1.35vw, 1.25rem);
  }

  .method-track p {
    grid-column: 1 / -1;
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .method-track em {
    grid-column: 1 / -1;
    align-self: end;
    color: var(--ember-strong);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.72rem;
    font-style: normal;
    letter-spacing: 0.04em;
  }

  @media (max-width: 820px) {
    .principle-trace,
    .principle-trace:nth-child(2),
    .principle-trace:nth-child(3) {
      width: 100%;
      margin-left: 0;
    }

    .method-track {
      grid-template-columns: repeat(2, 1fr);
    }

    .method-track li:nth-child(3),
    .method-track li:nth-child(4) {
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 720px) {
    .brand-manifesto {
      padding: 5rem 0;
    }

    .manifesto-copy,
    .method-head {
      grid-template-columns: 1fr;
    }

    .manifesto-copy > p:last-child,
    .method-head > p:last-child {
      grid-column: 1;
      grid-row: auto;
    }

    .principle-list {
      margin-top: 3rem;
    }

    .principle-trace {
      min-height: auto;
      grid-template-columns: 2rem 1.3rem minmax(0, 1fr);
      gap: 0.8rem;
      padding: 1.25rem 0;
    }

    .principle-trace p {
      grid-column: 3;
    }

    .method-track {
      position: relative;
      grid-template-columns: 1fr;
      margin-left: 0.25rem;
      border-top: 0;
      border-left: 1px solid var(--line);
    }

    .method-track li,
    .method-track li + li {
      min-height: auto;
      border-top: 1px solid var(--line);
      padding: 1.1rem 0 1.5rem 1.25rem;
    }

    .method-track li::before {
      top: -3px;
      left: -3px;
    }
  }
</style>
