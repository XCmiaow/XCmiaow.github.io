---
import type { SiliconEmbersNavCopy } from '../../data/siliconEmbersHome';

interface Props {
  copy: SiliconEmbersNavCopy;
}

const { copy } = Astro.props;

const normalizePath = (path: string) => (path.endsWith('/') ? path : `${path}/`);
const currentPath = normalizePath(Astro.url.pathname);
const homePath = normalizePath(copy.homeHref);
const isHome = currentPath === homePath;
const themeLabel = copy.switchLabel === 'EN' ? '切换明暗模式' : 'Toggle color mode';
const isActive = (href: string) => {
  const targetPath = normalizePath(href);
  return targetPath !== homePath && currentPath.startsWith(targetPath);
};
---

<header class="sa-nav" aria-label={copy.htmlLabel}>
  <a class="sa-brand" href={copy.homeHref} aria-label={copy.brand} aria-current={isHome ? 'page' : undefined}>
    <span class="brand-mark">
      <img src="/silicon-ashes/logo.jpg" alt="" width="38" height="38" decoding="async" />
    </span>
    <span class="brand-name">{copy.brand}</span>
    <span class="archive-index" aria-hidden="true">A/01</span>
  </a>
  <nav aria-label={copy.navLabel}>
    {
      copy.nav.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
    <a class="language-link" href={copy.switchHref}>{copy.switchLabel}</a>
    <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false" aria-label={themeLabel}>
      <span class="aperture" aria-hidden="true"><span></span></span>
    </button>
  </nav>
</header>

<style>
  .sa-nav {
    position: relative;
    z-index: 20;
    display: flex;
    width: min(100% - 56px, 1320px);
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin: 0 auto;
    border-bottom: 1px solid var(--line);
  }

  .sa-nav::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 3.25rem;
    height: 1px;
    background: var(--ember-strong);
  }

  .sa-brand {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    overflow: hidden;
    border: 1px solid rgba(230, 173, 101, 0.38);
    border-radius: 50%;
    background: #090806;
  }

  .brand-mark img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    opacity: 0.9;
    filter: saturate(0.78) contrast(1.06);
    transform: scale(1.08);
  }

  .brand-name {
    color: var(--paper);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 760;
    letter-spacing: 0.02em;
  }

  .archive-index {
    align-self: center;
    margin-left: 0.15rem;
    padding-left: 0.7rem;
    border-left: 1px solid var(--line);
    color: color-mix(in srgb, var(--muted) 72%, transparent);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.58rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.05rem;
  }

  nav a,
  .theme-toggle {
    position: relative;
    display: inline-flex;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 0;
    padding: 0 0.62rem;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.79rem;
    font-weight: 650;
    text-decoration: none;
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  nav a::after {
    content: '';
    position: absolute;
    right: 0.62rem;
    bottom: 0.45rem;
    left: 0.62rem;
    height: 1px;
    background: var(--ember-strong);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 190ms ease;
  }

  nav a:hover,
  nav a:focus-visible,
  nav a[aria-current='page'],
  .theme-toggle:hover,
  .theme-toggle:focus-visible,
  .theme-toggle[aria-pressed='true'] {
    color: var(--paper);
    outline: none;
  }

  nav a:hover,
  nav a:focus-visible {
    transform: translateY(-1px);
  }

  nav a:hover::after,
  nav a:focus-visible::after,
  nav a[aria-current='page']::after {
    transform: scaleX(1);
  }

  nav a:focus-visible,
  .theme-toggle:focus-visible,
  .sa-brand:focus-visible {
    outline: 2px solid var(--ember-strong);
    outline-offset: 2px;
  }

  .language-link {
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .theme-toggle {
    padding: 0;
  }

  .aperture {
    position: relative;
    display: grid;
    width: 1.05rem;
    height: 1.05rem;
    place-items: center;
    border: 1px solid currentColor;
    border-radius: 50%;
    transition: transform 260ms ease;
  }

  .aperture span {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 50%;
    background: linear-gradient(90deg, currentColor 0 50%, transparent 50%);
  }

  .theme-toggle:hover .aperture,
  .theme-toggle:focus-visible .aperture,
  .theme-toggle[aria-pressed='true'] .aperture {
    transform: rotate(180deg);
  }

  @media (max-width: 720px) {
    .sa-nav {
      width: min(100% - 24px, 1320px);
      flex-wrap: wrap;
      gap: 0.35rem 1rem;
      padding: 0.7rem 0 0.55rem;
    }

    nav {
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    nav a,
    .theme-toggle {
      flex: 0 0 auto;
      padding-inline: 0.55rem;
      font-size: 0.76rem;
    }

    nav a::after {
      right: 0.55rem;
      left: 0.55rem;
    }
  }

  @media (max-width: 360px) {
    .brand-name {
      font-size: 1rem;
    }

    .archive-index {
      display: none;
    }
  }
</style>
