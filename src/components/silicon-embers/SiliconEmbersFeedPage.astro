---
import common from '../../data/common.json';
import type { SiliconEmbersLang } from '../../data/siliconEmbersHome';
import ActionButton from './ActionButton.astro';
import CopyButton from './CopyButton.astro';

interface Props {
  lang: SiliconEmbersLang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';
const accountName = common.person.wechatPublicName;
const qrSrc = common.person.wechatPublicQr;
const mediaSrc = qrSrc || '/silicon-ashes/logo.jpg';
const resourcesHref = isZh ? '/silicon-ashes/resources/' : '/en/silicon-ashes/resources/';
const writingHref = isZh ? '/silicon-ashes/writing/' : '/en/silicon-ashes/writing/';
const courseHref = isZh
  ? '/silicon-ashes/resources/#course-materials'
  : '/en/silicon-ashes/resources/#course-materials';
const aboutHref = isZh ? '/silicon-ashes/about/' : '/en/silicon-ashes/about/';

const copy = isZh
  ? {
      eyebrow: '微信公众号',
      title: '硅基余烬',
      lead: '最新更新发布在微信公众号。网站负责引导关注、沉淀资料、展示索引。',
      accountLabel: '公众号名称',
      searchHint: `在微信搜索「${accountName}」。`,
      qrHint: `扫码关注，或在微信搜索「${accountName}」。`,
      copyAction: '复制名称',
      copiedAction: '已复制',
      qrLabel: '公众号二维码',
      logoLabel: '微信搜索',
      qrAlt: '硅基余烬公众号二维码',
      logoAlt: '硅基余烬品牌标识',
      howTitle: '如何关注',
      howSteps: [
        '打开微信，搜索公众号名称「硅基余烬」。',
        '或扫描本页二维码，直接进入关注页。',
        '关注后可在微信内阅读最新更新；网站只做索引和资料沉淀。',
      ],
      noteTitle: '说明',
      noteBody: '本页是公众号入口，不是邮件更新或自动 RSS 更新中心。网站博客可单独浏览；更新节奏以公众号为准。',
      indexTitle: '网站承接',
      indexLead: '公众号负责更新；网站负责把可复用内容收成入口。',
      lanes: [
        {
          title: '博客索引',
          body: '网站内沉淀的文章目录。',
          href: writingHref,
          cta: '进入博客',
        },
        {
          title: '资源中枢',
          body: '课程资料、模板、清单与工具流。',
          href: resourcesHref,
          cta: '进入资源',
        },
        {
          title: '课程资料',
          body: '课程作为资源子模块集中入口。',
          href: courseHref,
          cta: '查看课程',
        },
        {
          title: '关于与联系',
          body: '背景、企业微信与个人信息。',
          href: aboutHref,
          cta: '进入关于',
        },
      ],
    }
  : {
      eyebrow: 'WeChat',
      title: 'silicon-embers',
      lead: 'Updates are published on WeChat. This site guides follow actions, archives materials, and keeps indexes.',
      accountLabel: 'Official account',
      searchHint: `Search "${accountName}" in WeChat.`,
      qrHint: `Scan the QR code, or search "${accountName}" in WeChat.`,
      copyAction: 'Copy name',
      copiedAction: 'Copied',
      qrLabel: 'WeChat QR code',
      logoLabel: 'WeChat search',
      qrAlt: 'silicon-embers WeChat QR code',
      logoAlt: 'silicon-embers brand mark',
      howTitle: 'How to follow',
      howSteps: [
        'Open WeChat and search for "硅基余烬".',
        'Or scan the QR code on this page.',
        'Read new updates in WeChat; the website keeps indexes and reusable materials.',
      ],
      noteTitle: 'Note',
      noteBody:
        'This page is a WeChat entry, not an email or automatic RSS subscription hub. Blog pages remain readable on the site; the update source is WeChat.',
      indexTitle: 'What the site holds',
      indexLead: 'WeChat publishes updates; the site keeps reusable entry points.',
      lanes: [
        {
          title: 'Blog index',
          body: 'Essays archived on the website.',
          href: writingHref,
          cta: 'Open blog',
        },
        {
          title: 'Resource hub',
          body: 'Course materials, templates, checklists, and tools.',
          href: resourcesHref,
          cta: 'Open resources',
        },
        {
          title: 'Course materials',
          body: 'Courses live as a resource submodule.',
          href: courseHref,
          cta: 'View courses',
        },
        {
          title: 'About and contact',
          body: 'Background, WeCom, and personal info.',
          href: aboutHref,
          cta: 'Open about',
        },
      ],
    };
---

<div class="feed-page">
  <section class="feed-hero" aria-labelledby="feed-title">
    <p class="kicker">{copy.eyebrow}</p>
    <h1 id="feed-title">{copy.title}</h1>
    <p class="lead">{copy.lead}</p>
  </section>

  <section class="wechat-panel" aria-label={copy.accountLabel}>
    <div class="wechat-copy">
      <p class="kicker">{copy.accountLabel}</p>
      <strong>{accountName}</strong>
      <p>{qrSrc ? copy.qrHint : copy.searchHint}</p>
      <div class="feed-actions">
        <CopyButton value={accountName} label={copy.copyAction} copiedLabel={copy.copiedAction} variant="primary" />
        <ActionButton href={resourcesHref}>{isZh ? '资源中枢' : 'Resources'}</ActionButton>
        <ActionButton href={writingHref} variant="text">{isZh ? '博客索引' : 'Blog index'}</ActionButton>
      </div>
    </div>

    <figure class:list={['wechat-mark', qrSrc && 'has-qr']}>
      <img src={mediaSrc} alt={qrSrc ? copy.qrAlt : copy.logoAlt} width="240" height="240" loading="eager" />
      <figcaption>{qrSrc ? copy.qrLabel : copy.logoLabel}</figcaption>
    </figure>
  </section>

  <section class="feed-how" aria-labelledby="feed-how-title">
    <div class="section-copy">
      <p class="kicker">guide</p>
      <h2 id="feed-how-title">{copy.howTitle}</h2>
    </div>
    <ol>
      {
        copy.howSteps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="feed-note" aria-labelledby="feed-note-title">
    <p class="kicker">scope</p>
    <h2 id="feed-note-title">{copy.noteTitle}</h2>
    <p>{copy.noteBody}</p>
  </section>

  <section class="feed-index" aria-labelledby="feed-index-title">
    <div class="section-copy">
      <p class="kicker">index</p>
      <h2 id="feed-index-title">{copy.indexTitle}</h2>
      <p>{copy.indexLead}</p>
    </div>
    <div class="lane-list">
      {
        copy.lanes.map((lane) => (
          <article class="lane-card">
            <div>
              <h3>{lane.title}</h3>
              <p>{lane.body}</p>
            </div>
            <ActionButton href={lane.href} size="compact">
              {lane.cta}
            </ActionButton>
          </article>
        ))
      }
    </div>
  </section>
</div>

<style>
  .feed-page {
    padding-bottom: clamp(86px, 10vw, 132px);
  }

  .feed-hero {
    max-width: 900px;
    border-bottom: 1px solid var(--line);
    padding: clamp(76px, 10vw, 118px) 0 clamp(48px, 7vw, 78px);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', 'Times New Roman', serif;
    font-weight: 850;
  }

  h1 {
    margin-top: 18px;
    font-size: clamp(3.2rem, 7vw, 7rem);
    line-height: 1;
    text-wrap: balance;
  }

  .lead {
    max-width: 620px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: clamp(1.04rem, 1.45vw, 1.24rem);
    line-height: 1.76;
  }

  .wechat-panel,
  .feed-how,
  .feed-note,
  .feed-index {
    border-bottom: 1px solid var(--line);
    padding: clamp(48px, 7vw, 84px) 0;
  }

  .wechat-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(190px, 260px);
    gap: clamp(24px, 6vw, 72px);
    align-items: center;
  }

  .wechat-copy {
    max-width: 660px;
  }

  .wechat-copy strong {
    display: block;
    margin-top: 14px;
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(2.1rem, 5vw, 4.4rem);
    font-weight: 850;
    line-height: 1.04;
  }

  .wechat-copy > p:not(.kicker) {
    max-width: 520px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.74;
  }

  .feed-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .copy-control {
    cursor: pointer;
    font: inherit;
  }

  .wechat-mark {
    display: grid;
    justify-items: center;
    gap: 12px;
    margin: 0;
  }

  .wechat-mark img {
    display: block;
    width: min(100%, 240px);
    aspect-ratio: 1;
    border: 1px solid rgba(242, 223, 189, 0.18);
    border-radius: 8px;
    padding: 10px;
    background: rgba(242, 223, 189, 0.06);
    object-fit: cover;
  }

  .wechat-mark.has-qr img {
    background: #f8f4ea;
  }

  figcaption {
    color: rgba(239, 227, 205, 0.56);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 12px;
    font-weight: 850;
  }

  .feed-how,
  .feed-index {
    display: grid;
    grid-template-columns: minmax(0, 0.34fr) minmax(0, 0.66fr);
    gap: clamp(24px, 5vw, 72px);
  }

  .section-copy {
    display: grid;
    align-content: start;
    gap: 12px;
  }

  .section-copy h2,
  .feed-note h2 {
    font-size: clamp(1.7rem, 3vw, 2.8rem);
    line-height: 1.08;
  }

  .section-copy p:not(.kicker),
  .feed-note p:not(.kicker) {
    max-width: 36rem;
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.72;
  }

  .feed-note h2 {
    margin-top: 12px;
  }

  .feed-note > p:not(.kicker) {
    margin-top: 14px;
  }

  .feed-how ol {
    display: grid;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(232, 174, 98, 0.18);
    list-style: none;
  }

  .feed-how li {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 16px;
    border-bottom: 1px solid rgba(232, 174, 98, 0.14);
    padding: 18px 0;
  }

  .feed-how li span {
    color: rgba(244, 212, 155, 0.72);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 13px;
    font-weight: 850;
  }

  .feed-how li p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .lane-list {
    display: grid;
    gap: 0;
    border-top: 1px solid rgba(232, 174, 98, 0.18);
  }

  .lane-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    border-bottom: 1px solid rgba(232, 174, 98, 0.14);
    padding: 18px 0;
  }

  .lane-card h3 {
    font-size: clamp(1.08rem, 1.7vw, 1.34rem);
    line-height: 1.28;
  }

  .lane-card p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.62;
  }

  @media (max-width: 760px) {
    .feed-hero {
      padding: 34px 0 30px;
    }

    h1 {
      font-size: clamp(2.2rem, 12vw, 3.4rem);
      line-height: 1.08;
    }

    .lead {
      margin-top: 14px;
      font-size: 14.5px;
      line-height: 1.68;
    }

    .wechat-panel,
    .feed-how,
    .feed-index {
      grid-template-columns: 1fr;
      gap: 22px;
      padding: 34px 0 42px;
    }

    .wechat-copy strong {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .wechat-copy > p:not(.kicker),
    .feed-how li p,
    .section-copy p:not(.kicker),
    .feed-note p:not(.kicker),
    .lane-card p {
      font-size: 14px;
      line-height: 1.66;
    }

    .feed-actions :global(.sa-control),
    .copy-control {
      flex: 1 1 100%;
    }

    .wechat-mark {
      justify-items: start;
    }

    .wechat-mark img {
      width: min(62vw, 220px);
      min-width: 160px;
    }

    .lane-card {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
