---
import type { CollectionEntry } from 'astro:content';
import type { SiliconEmbersLang, SiliconEmbersWritingCopy } from '../../data/siliconEmbersHome';
import ActionButton from './ActionButton.astro';

interface Props {
  copy: SiliconEmbersWritingCopy;
  lang: SiliconEmbersLang;
  posts: readonly CollectionEntry<'blog'>[];
}

const { copy, lang, posts } = Astro.props;

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
};

const postHref = (id: string) => (lang === 'zh' ? `/silicon-ashes/writing/${id}/` : `/en/silicon-ashes/writing/${id}/`);
---

<section class="writing-preview" aria-labelledby="writing-title">
  <header class="writing-head">
    <div class="section-copy">
      <p class="kicker">{copy.kicker}</p>
      <h2 id="writing-title">{copy.title}</h2>
    </div>
    <ActionButton href={copy.href} variant="text" className="section-link">{copy.more}</ActionButton>
  </header>

  {
    posts.length > 0 ? (
      <div class="writing-list">
        {posts.map((post) => (
          <a class="writing-card" href={postHref(post.id)}>
            <span class="writing-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span>{post.data.readingTime ? `${post.data.readingTime} min` : copy.fallbackReadingTime}</span>
            </span>
            <strong>{post.data.title}</strong>
            <span class="writing-arrow" aria-hidden="true">
              ↗
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-note">{copy.empty}</p>
    )
  }
</section>

<style>
  .writing-preview {
    display: grid;
    grid-template-columns: minmax(13rem, 0.55fr) minmax(0, 1.45fr);
    gap: clamp(3rem, 8vw, 8rem);
    border-bottom: 1px solid var(--line);
    padding: clamp(88px, 11vw, 148px) 0;
  }

  .writing-head {
    display: flex;
    min-height: 18rem;
    flex-direction: column;
    align-items: flex-start;
  }

  .writing-head h2 {
    max-width: 7ch;
    margin-top: 0.9rem;
    font-size: clamp(3rem, 6vw, 6.3rem);
    line-height: 0.95;
  }

  :global(.writing-preview .section-link) {
    margin-top: auto;
  }

  .writing-list {
    border-top: 1px solid var(--line);
  }

  .writing-card {
    position: relative;
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 1.7rem 0;
    text-decoration: none;
  }

  .writing-card::before {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 4rem;
    height: 1px;
    background: var(--ember-strong);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 230ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .writing-meta {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.69rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .writing-card strong {
    color: var(--paper);
    font-family: 'Source Han Serif SC', 'Noto Serif SC', 'Songti SC', serif;
    font-size: clamp(1.35rem, 2.6vw, 2.35rem);
    font-weight: 780;
    line-height: 1.25;
    text-wrap: pretty;
  }

  .writing-arrow {
    color: var(--ember-strong);
    font-size: 1.1rem;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .writing-card:hover::before,
  .writing-card:focus-visible::before {
    transform: scaleX(1);
  }

  .writing-card:hover .writing-arrow,
  .writing-card:focus-visible .writing-arrow {
    transform: translate(0.25rem, -0.25rem);
  }

  .writing-card:focus-visible {
    outline: 2px solid var(--ember-strong);
    outline-offset: 0.35rem;
  }

  .empty-note {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .writing-preview {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 4rem 0;
    }

    .writing-head {
      min-height: auto;
    }

    :global(.writing-preview .section-link) {
      margin-top: 1.5rem;
    }

    .writing-card {
      grid-template-columns: 1fr auto;
      gap: 0.9rem 1rem;
      padding: 1.4rem 0;
    }

    .writing-meta {
      grid-column: 1 / -1;
      grid-template-columns: auto auto;
      justify-content: start;
      gap: 1rem;
    }

    .writing-card strong {
      font-size: 1.45rem;
    }
  }
</style>
