---
import type { CollectionEntry } from 'astro:content';
import type { SiliconEmbersLang, SiliconEmbersWritingCopy } from '../../data/siliconEmbersHome';
import ActionButton from './ActionButton.astro';

interface Props {
  copy: SiliconEmbersWritingCopy;
  lang: SiliconEmbersLang;
  posts: readonly CollectionEntry<'blog'>[];
}

const { copy, lang, posts } = Astro.props;

const formatDate = (date: Date) => {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
};

const postHref = (id: string) => (lang === 'zh' ? `/silicon-ashes/writing/${id}/` : `/en/silicon-ashes/writing/${id}/`);
---

<section class="writing-preview" aria-labelledby="writing-title">
  <header class="writing-head">
    <div class="section-copy">
      <p class="kicker">{copy.kicker}</p>
      <h2 id="writing-title">{copy.title}</h2>
    </div>
    <ActionButton href={copy.href} variant="text" className="section-link">{copy.more}</ActionButton>
  </header>

  {
    posts.length > 0 ? (
      <div class="writing-list">
        {posts.map((post) => (
          <a class="writing-card" href={postHref(post.id)}>
            <span class="writing-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span>{post.data.readingTime ? `${post.data.readingTime} min` : copy.fallbackReadingTime}</span>
            </span>
            <span class="writing-rule" aria-hidden="true" />
            <strong>{post.data.title}</strong>
            <span class="writing-arrow" aria-hidden="true">
              ↗
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-note">{copy.empty}</p>
    )
  }
</section>

<style>
  .writing-preview {
    display: grid;
    grid-template-columns: minmax(9rem, 0.32fr) minmax(0, 1.68fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    border-bottom: 1px solid var(--line);
    padding: var(--space-section) 0;
  }

  .writing-head {
    display: flex;
    min-height: 11rem;
    flex-direction: column;
    align-items: flex-start;
  }

  .writing-head h2 {
    max-width: 7ch;
    margin-top: 0.75rem;
    font-size: clamp(2.1rem, 3.4vw, var(--display-section-max));
    line-height: 1;
  }

  :global(.writing-preview .section-link) {
    margin-top: auto;
  }

  .writing-list {
    border-top: 1px solid var(--line);
  }

  .writing-card {
    position: relative;
    display: grid;
    grid-template-columns: 7.5rem 2rem minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding: 1.35rem 0;
    text-decoration: none;
  }

  .writing-meta {
    display: grid;
    gap: 0.38rem;
    color: var(--muted);
    font-family: Consolas, 'SFMono-Regular', monospace;
    font-size: 0.67rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .writing-rule {
    width: 1.35rem;
    height: 1px;
    background: var(--line);
    transform-origin: left;
    transition:
      width 230ms cubic-bezier(0.2, 0.8, 0.2, 1),
      background 200ms ease;
  }

  .writing-card strong {
    color: var(--paper);
    font-family: var(--font-display);
    font-size: clamp(1.08rem, 1.55vw, 1.55rem);
    font-weight: 720;
    line-height: 1.3;
    text-wrap: pretty;
  }

  .writing-arrow {
    color: var(--ember-strong);
    font-size: 0.96rem;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .writing-card:hover .writing-rule,
  .writing-card:focus-visible .writing-rule {
    width: 1.8rem;
    background: var(--ember-strong);
  }

  .writing-card:hover .writing-arrow,
  .writing-card:focus-visible .writing-arrow {
    transform: translate(2px, -2px);
  }

  .writing-card:focus-visible {
    outline: 2px solid var(--ember-strong);
    outline-offset: 0.3rem;
  }

  .empty-note {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .writing-preview {
      grid-template-columns: 1fr;
      gap: 2.4rem;
      padding: 5rem 0;
    }

    .writing-head {
      min-height: auto;
    }

    :global(.writing-preview .section-link) {
      margin-top: 1.25rem;
    }

    .writing-card {
      grid-template-columns: 1.4rem minmax(0, 1fr) auto;
      gap: 0.8rem;
      padding: 1.25rem 0;
    }

    .writing-meta {
      grid-column: 1 / -1;
      grid-template-columns: auto auto;
      justify-content: start;
      gap: 1rem;
    }

    .writing-rule {
      width: 1rem;
    }

    .writing-card strong {
      font-size: 1.35rem;
    }
  }
</style>
