<div id="avatar-scene" aria-hidden="true"></div>

<script is:inline>
  (function () {
    var container = document.getElementById('avatar-scene');
    if (!container || window.innerWidth < 640) return;

    // Cache check — only load Three.js once per session
    if (window.__threeLoading) {
      var chk = setInterval(function () {
        if (window.__threeLoaded) {
          clearInterval(chk);
          initScene();
        }
      }, 100);
      return;
    }
    window.__threeLoading = true;

    var script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    script.onload = function () {
      window.__threeLoaded = true;
      initScene();
    };
    document.head.appendChild(script);

    function initScene() {
      var scene,
        camera,
        renderer,
        group,
        isHovering = false;
      var targetX = 0,
        targetY = 0,
        currentX = 0,
        currentY = 0;
      var animId;

      function setup() {
        var W = container.clientWidth || 180;
        var H = container.clientHeight || 180;

        if (!scene) {
          scene = new THREE.Scene();
          camera = new THREE.PerspectiveCamera(30, W / H, 0.1, 1000);
          camera.position.set(0, 0, 7);
          renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          container.appendChild(renderer.domElement);

          var ambient = new THREE.AmbientLight(0xffffff, 0.6);
          scene.add(ambient);
          var key = new THREE.DirectionalLight(0xffffff, 1.0);
          key.position.set(2, 3, 5);
          scene.add(key);
          var rim = new THREE.DirectionalLight(0xc9a227, 0.5);
          rim.position.set(-2, 1, -3);
          scene.add(rim);
          var fill = new THREE.DirectionalLight(0xffffff, 0.3);
          fill.position.set(0, -1, 2);
          scene.add(fill);

          group = new THREE.Group();
          scene.add(group);
        }

        renderer.setSize(W, H);

        var loader = new THREE.TextureLoader();
        loader.load('/assets/avatar.jpg', function (texture) {
          // Clear old meshes
          while (group.children.length) group.remove(group.children[0]);

          // Card with MeshPhysicalMaterial for depth/reflection
          var geom = new THREE.BoxGeometry(2.6, 2.6, 0.06);
          var mat = new THREE.MeshPhysicalMaterial({
            map: texture,
            roughness: 0.3,
            metalness: 0.05,
            clearcoat: 0.08,
          });
          var card = new THREE.Mesh(geom, mat);
          group.add(card);

          // Gold rim frame
          var frameMat = new THREE.MeshStandardMaterial({
            color: 0xc9a227,
            roughness: 0.25,
            metalness: 0.5,
          });
          var frame = new THREE.BoxGeometry(2.66, 2.66, 0.015);
          var frameMesh = new THREE.Mesh(frame, frameMat);
          frameMesh.position.z = -0.05;
          group.add(frameMesh);

          // Floating ambient particles
          var pCount = 40;
          var pGeom = new THREE.BufferGeometry();
          var positions = new Float32Array(pCount * 3);
          var sizes = new Float32Array(pCount);
          for (var i = 0; i < pCount; i++) {
            var theta = Math.random() * Math.PI * 2;
            var phi = Math.random() * Math.PI;
            var r = 1.8 + Math.random() * 1.2;
            positions[i * 3] = Math.sin(phi) * Math.cos(theta) * r;
            positions[i * 3 + 1] = Math.sin(phi) * Math.sin(theta) * r;
            positions[i * 3 + 2] = Math.cos(phi) * r;
            sizes[i] = 0.02 + Math.random() * 0.04;
          }
          pGeom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
          pGeom.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
          var pMat = new THREE.PointsMaterial({
            color: 0xc9a227,
            size: 0.04,
            transparent: true,
            opacity: 0.4,
            blending: THREE.AdditiveBlending,
          });
          var particles = new THREE.Points(pGeom, pMat);
          group.add(particles);
        });
      }

      setup();
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(setup, 200);
      });

      container.addEventListener('mouseenter', function () {
        isHovering = true;
      });
      container.addEventListener('mouseleave', function () {
        isHovering = false;
        targetX = 0;
        targetY = 0;
      });
      document.addEventListener('mousemove', function (e) {
        if (!isHovering) return;
        var r = container.getBoundingClientRect();
        var x = (e.clientX - r.left) / r.width - 0.5;
        var y = (e.clientY - r.top) / r.height - 0.5;
        targetX = x * 0.35;
        targetY = -y * 0.35;
      });

      function animate() {
        currentX += (targetX - currentX) * 0.06;
        currentY += (targetY - currentY) * 0.06;
        if (group) {
          group.rotation.x = currentY;
          group.rotation.y = currentX;
        }
        if (renderer && scene && camera) renderer.render(scene, camera);
        animId = requestAnimationFrame(animate);
      }
      animate();

      document.addEventListener('astro:after-swap', function () {
        if (animId) cancelAnimationFrame(animId);
      });
    }
  })();
</script>

<style>
  #avatar-scene {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    z-index: 2;
    cursor: pointer;
  }
  #avatar-scene canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    pointer-events: none;
  }
  @media (min-width: 641px) {
    #avatar-scene ~ .profile-photo {
      display: none;
    }
  }
  @media (max-width: 640px) {
    #avatar-scene {
      display: none;
    }
  }
</style>
