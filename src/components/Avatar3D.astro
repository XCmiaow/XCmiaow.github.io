<div id="avatar-scene" aria-hidden="true"></div>

<script is:inline>
  (function() {
    var container = document.getElementById('avatar-scene');
    if (!container || window.innerWidth < 640) return;

    // Load Three.js
    var script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    script.onload = function() {
      var W = container.clientWidth || 180;
      var H = container.clientHeight || 180;

      // Scene
      var scene = new THREE.Scene();
      scene.background = null;

      // Camera
      var camera = new THREE.PerspectiveCamera(28, W / H, 0.1, 1000);
      camera.position.set(0, 0, 8);

      // Renderer with alpha
      var renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(W, H);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // Lights
      var ambient = new THREE.AmbientLight(0xffffff, 0.5);
      scene.add(ambient);
      var key = new THREE.DirectionalLight(0xffffff, 1.0);
      key.position.set(2, 3, 5);
      scene.add(key);
      var rim = new THREE.DirectionalLight(0xc9a227, 0.4);
      rim.position.set(-2, 1, -3);
      scene.add(rim);
      var fill = new THREE.DirectionalLight(0xffffff, 0.3);
      fill.position.set(0, -1, 2);
      scene.add(fill);

      // Load avatar texture
      var loader = new THREE.TextureLoader();
      loader.load('/assets/avatar.jpg', function(texture) {
        // Card group
        var group = new THREE.Group();
        scene.add(group);

        // Card base with rounded corners via box
        var geom = new THREE.BoxGeometry(2.8, 2.8, 0.08);
        var mat = new THREE.MeshStandardMaterial({
          map: texture,
          roughness: 0.35,
          metalness: 0.02,
        });
        var card = new THREE.Mesh(geom, mat);
        card.position.z = 0;
        group.add(card);

        // Gold border frame
        var frameMat = new THREE.MeshStandardMaterial({
          color: 0xc9a227,
          roughness: 0.3,
          metalness: 0.4,
        });
        var frame = new THREE.BoxGeometry(2.86, 2.86, 0.02);
        var frameMesh = new THREE.Mesh(frame, frameMat);
        frameMesh.position.z = -0.06;
        group.add(frameMesh);

        // Subtle shadow plane below
        var shadowMat = new THREE.MeshBasicMaterial({
          color: 0x000000,
          transparent: true,
          opacity: 0.12,
        });
        var shadow = new THREE.Mesh(new THREE.PlaneGeometry(2.4, 2.4), shadowMat);
        shadow.position.set(0.12, -0.12, -0.2);
        group.add(shadow);

        // Mouse tracking with inertia
        var targetX = 0, targetY = 0;
        var currentX = 0, currentY = 0;
        var isHovering = false;

        container.addEventListener('mouseenter', function() { isHovering = true; });
        container.addEventListener('mouseleave', function() { isHovering = false; targetX = 0; targetY = 0; });

        document.addEventListener('mousemove', function(e) {
          if (!isHovering) return;
          var r = container.getBoundingClientRect();
          var x = (e.clientX - r.left) / r.width - 0.5;
          var y = (e.clientY - r.top) / r.height - 0.5;
          targetX = x * 0.4;
          targetY = -y * 0.4;
        });

        // Animate
        function animate() {
          currentX += (targetX - currentX) * 0.08;
          currentY += (targetY - currentY) * 0.08;
          group.rotation.x = currentY;
          group.rotation.y = currentX;
          group.position.y = currentY * 0.15;
          group.position.x = currentX * 0.15;
          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        }
        animate();

        // Window resize
        var resizeTimer;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(function() {
            var nw = container.clientWidth || 180;
            var nh = container.clientHeight || 180;
            camera.aspect = nw / nh;
            camera.updateProjectionMatrix();
            renderer.setSize(nw, nh);
          }, 200);
        });
      });
    };
    document.head.appendChild(script);
  })();
</script>

<style>
  #avatar-scene {
    position: absolute;
    top: 28px;
    left: 28px;
    width: calc(100% - 56px);
    height: calc(100% - 160px);
    pointer-events: auto;
    z-index: 2;
    cursor: pointer;
  }
  #avatar-scene canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
  /* Hide the original photo when 3D is active on desktop */
  @media (min-width: 641px) {
    #avatar-scene ~ .profile-photo { display: none; }
    .profile-meta { margin-top: 100px; }
  }
</style>
