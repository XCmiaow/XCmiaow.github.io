<div id="cursor-glow" aria-hidden="true"></div>

<script>
  (function() {
    var glow = document.getElementById('cursor-glow');
    if (!glow) return;
    var mx = -200, my = -200;

    document.addEventListener('mousemove', function(e) { mx = e.clientX; my = e.clientY; });
    document.addEventListener('mouseleave', function() { mx = -200; my = -200; });

    function animate() {
      var cx = mx, cy = my;
      glow.style.transform = 'translate(' + (cx - 150) + 'px,' + (cy - 150) + 'px)';

      try {
        var el = document.elementFromPoint(cx, cy);
        if (el && el.closest) {
          var isLink = el.closest('a,button,.tl-card,.project-card,.skill-card,.highlight');
          glow.style.width = isLink ? '400px' : '300px';
          glow.style.height = isLink ? '400px' : '300px';
        }
      } catch(e) { /* elementFromPoint may fail in some contexts */ }

      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  })();
</script>

<style>
  #cursor-glow {
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 2147483647;
    width: 300px; height: 300px; border-radius: 50%;
    background: radial-gradient(circle, rgba(201,162,39,0.12) 0%, transparent 70%);
    transition: width 0.3s, height 0.3s;
    will-change: transform;
  }
  [data-theme="dark"] #cursor-glow {
    background: radial-gradient(circle, rgba(224,189,78,0.15) 0%, transparent 70%);
  }
  @media (max-width: 980px) { #cursor-glow { display: none !important; } }
</style>
