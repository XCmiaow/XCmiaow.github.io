---
export interface Props {
  variant?: 'hero' | 'course';
}

const { variant = 'hero' } = Astro.props;
---

<div class:list={['burning-circuit', `is-${variant}`]} data-burning-circuit aria-hidden="true">
  <canvas data-burning-circuit-canvas></canvas>
  <div class="circuit-vignette"></div>
</div>

<script>
  (() => {
    const roots = document.querySelectorAll("[data-burning-circuit]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.circuitReady === "true") return;
      const canvas = root.querySelector("[data-burning-circuit-canvas]");
      if (!(canvas instanceof HTMLCanvasElement)) return;

      root.dataset.circuitReady = "true";
      const context = canvas.getContext("2d", { alpha: true });
      if (!context) return;

      const particles = [];
      const hotspots = [
        { x: 0.22, y: 0.64, r: 0.22, power: 0.8 },
        { x: 0.54, y: 0.58, r: 0.28, power: 1 },
        { x: 0.78, y: 0.66, r: 0.24, power: 0.9 },
      ];

      let width = 0;
      let height = 0;
      let frameId = 0;
      let lastTime = performance.now();

      const rand = (min, max) => min + Math.random() * (max - min);
      const seeded = (seed) => {
        const value = Math.sin(seed * 127.1) * 43758.5453;
        return value - Math.floor(value);
      };
      const seededRange = (seed, min, max) => min + seeded(seed) * (max - min);

      const resize = () => {
        const rect = root.getBoundingClientRect();
        const ratio = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, rect.width);
        height = Math.max(1, rect.height);
        canvas.width = Math.floor(width * ratio);
        canvas.height = Math.floor(height * ratio);
        canvas.style.width = width + "px";
        canvas.style.height = height + "px";
        context.setTransform(ratio, 0, 0, ratio, 0, 0);
      };

      const boardMetrics = () => {
        const boardWidth = width * 0.86;
        const boardHeight = height * 0.48;
        return {
          x: width * 0.51 - boardWidth * 0.5,
          y: height * 0.49 - boardHeight * 0.5,
          w: boardWidth,
          h: boardHeight,
          angle: -0.17,
        };
      };

      const withBoard = (draw) => {
        const board = boardMetrics();
        context.save();
        context.translate(board.x + board.w * 0.5, board.y + board.h * 0.5);
        context.rotate(board.angle);
        context.translate(-board.w * 0.5, -board.h * 0.5);
        draw(board);
        context.restore();
      };

      const boardPoint = (nx, ny) => {
        const board = boardMetrics();
        const lx = (nx - 0.5) * board.w;
        const ly = (ny - 0.5) * board.h;
        const cos = Math.cos(board.angle);
        const sin = Math.sin(board.angle);
        return {
          x: board.x + board.w * 0.5 + lx * cos - ly * sin,
          y: board.y + board.h * 0.5 + lx * sin + ly * cos,
        };
      };

      const roundedBoard = (board) => {
        const radius = Math.min(board.w, board.h) * 0.045;
        context.beginPath();
        context.roundRect(0, 0, board.w, board.h, radius);
      };

      const drawBoardBase = (time) => {
        withBoard((board) => {
          context.save();
          context.shadowColor = "rgba(255, 104, 26, 0.28)";
          context.shadowBlur = board.w * 0.06;
          roundedBoard(board);
          const base = context.createLinearGradient(0, 0, board.w, board.h);
          base.addColorStop(0, "#142d26");
          base.addColorStop(0.36, "#0b1816");
          base.addColorStop(0.72, "#10110d");
          base.addColorStop(1, "#030302");
          context.fillStyle = base;
          context.fill();
          context.restore();

          roundedBoard(board);
          context.clip();

          const fiber = context.createLinearGradient(0, 0, board.w, 0);
          fiber.addColorStop(0, "rgba(132, 190, 160, 0.04)");
          fiber.addColorStop(0.5, "rgba(255, 190, 92, 0.035)");
          fiber.addColorStop(1, "rgba(255, 255, 255, 0.012)");
          for (let y = board.h * 0.08; y < board.h; y += board.h * 0.075) {
            context.fillStyle = fiber;
            context.fillRect(board.w * 0.04, y, board.w * 0.92, 1);
          }

          context.strokeStyle = "rgba(155, 235, 192, 0.26)";
          context.lineWidth = Math.max(1, board.w * 0.003);
          context.lineCap = "round";
          context.lineJoin = "round";

          for (let i = 0; i < 9; i += 1) {
            const y = board.h * (0.13 + i * 0.085);
            const x0 = board.w * (0.06 + (i % 3) * 0.035);
            const x1 = board.w * (0.86 - (i % 2) * 0.08);
            context.beginPath();
            context.moveTo(x0, y);
            context.lineTo(board.w * (0.24 + (i % 4) * 0.09), y);
            context.lineTo(board.w * (0.24 + (i % 4) * 0.09), y + board.h * seededRange(i + 3, -0.055, 0.055));
            context.lineTo(x1, y + Math.sin(time * 0.001 + i) * 1.5);
            context.stroke();
          }

          context.strokeStyle = "rgba(230, 164, 74, 0.42)";
          context.lineWidth = Math.max(1.1, board.w * 0.004);
          for (let i = 0; i < 7; i += 1) {
            const x = board.w * (0.14 + i * 0.115);
            context.beginPath();
            context.moveTo(x, board.h * 0.1);
            context.lineTo(x, board.h * (0.34 + (i % 3) * 0.08));
            context.lineTo(x + board.w * 0.06, board.h * (0.34 + (i % 3) * 0.08));
            context.lineTo(x + board.w * 0.06, board.h * 0.78);
            context.stroke();
          }

          const drawPad = (nx, ny, r, heat = 0) => {
            const glow = 0.35 + heat * 0.65 + Math.sin(time * 0.005 + nx * 20) * 0.08;
            context.beginPath();
            context.fillStyle = `rgba(255, ${Math.floor(170 + heat * 65)}, 70, ${0.2 + glow * 0.28})`;
            context.shadowColor = `rgba(255, 124, 26, ${0.25 + heat * 0.45})`;
            context.shadowBlur = r * 5;
            context.arc(board.w * nx, board.h * ny, r, 0, Math.PI * 2);
            context.fill();
            context.shadowBlur = 0;
          };

          for (let i = 0; i < 42; i += 1) {
            const nx = 0.08 + ((i * 0.173) % 0.82);
            const ny = 0.12 + ((i * 0.317) % 0.74);
            const heat = hotspots.reduce((max, spot) => {
              const dx = nx - spot.x;
              const dy = ny - spot.y;
              return Math.max(max, Math.max(0, 1 - Math.hypot(dx, dy) / spot.r) * spot.power);
            }, 0);
            drawPad(nx, ny, board.w * seededRange(i + 19, 0.004, 0.009), heat);
          }

          const drawChip = (nx, ny, w, h) => {
            const x = board.w * nx;
            const y = board.h * ny;
            const chipW = board.w * w;
            const chipH = board.h * h;
            context.save();
            context.translate(x, y);
            context.fillStyle = "#050605";
            context.shadowColor = "rgba(0, 0, 0, 0.65)";
            context.shadowBlur = 14;
            context.fillRect(-chipW * 0.5, -chipH * 0.5, chipW, chipH);
            context.shadowBlur = 0;
            context.strokeStyle = "rgba(230, 164, 74, 0.34)";
            context.lineWidth = 1;
            context.strokeRect(-chipW * 0.5, -chipH * 0.5, chipW, chipH);
            context.fillStyle = "rgba(216, 198, 160, 0.38)";
            const pins = 8;
            for (let i = 0; i < pins; i += 1) {
              const px = -chipW * 0.44 + (chipW * 0.88 * i) / (pins - 1);
              context.fillRect(px, -chipH * 0.62, chipW * 0.035, chipH * 0.12);
              context.fillRect(px, chipH * 0.5, chipW * 0.035, chipH * 0.12);
            }
            context.restore();
          };

          drawChip(0.33, 0.42, 0.18, 0.24);
          drawChip(0.64, 0.38, 0.22, 0.18);
          drawChip(0.72, 0.7, 0.15, 0.16);

          hotspots.forEach((spot, index) => {
            const pulse = 0.82 + Math.sin(time * 0.004 + index * 2.1) * 0.18;
            const g = context.createRadialGradient(
              board.w * spot.x,
              board.h * spot.y,
              0,
              board.w * spot.x,
              board.h * spot.y,
              board.w * spot.r * pulse
            );
            g.addColorStop(0, `rgba(255, 235, 176, ${0.22 * spot.power})`);
            g.addColorStop(0.24, `rgba(241, 89, 26, ${0.26 * spot.power})`);
            g.addColorStop(0.58, "rgba(32, 12, 5, 0.62)");
            g.addColorStop(1, "rgba(0, 0, 0, 0)");
            context.fillStyle = g;
            context.fillRect(0, 0, board.w, board.h);
          });

          context.globalCompositeOperation = "multiply";
          const char = context.createLinearGradient(board.w * 0.16, board.h * 0.48, board.w, board.h);
          char.addColorStop(0, "rgba(0,0,0,0)");
          char.addColorStop(0.45, "rgba(16,8,4,0.24)");
          char.addColorStop(1, "rgba(0,0,0,0.68)");
          context.fillStyle = char;
          context.fillRect(0, 0, board.w, board.h);
          context.globalCompositeOperation = "source-over";

          roundedBoard(board);
          context.strokeStyle = "rgba(255, 196, 108, 0.18)";
          context.lineWidth = 1.5;
          context.stroke();
        });
      };

      const emit = (type) => {
        const spot = hotspots[Math.floor(rand(0, hotspots.length))];
        const edge = Math.random() < 0.55;
        const origin = edge
          ? boardPoint(rand(0.06, 0.94), rand(0.7, 0.94))
          : boardPoint(spot.x + rand(-spot.r * 0.34, spot.r * 0.34), spot.y + rand(-spot.r * 0.24, spot.r * 0.24));
        const base = {
          type,
          x: origin.x,
          y: origin.y,
          life: 0,
          seed: rand(0, 1000),
          drift: rand(0.001, 0.006),
        };

        if (type === "flame") {
          particles.push({
            ...base,
            vx: rand(-0.45, 0.55),
            vy: rand(-2.9, -0.9),
            size: rand(7, 18),
            maxLife: rand(760, 1550),
            heat: rand(0.55, 1),
          });
        } else if (type === "ember") {
          particles.push({
            ...base,
            vx: rand(-0.65, 0.75),
            vy: rand(-1.9, -0.35),
            size: rand(1.2, 3.8),
            maxLife: rand(1500, 3600),
            heat: rand(0.5, 1),
          });
        } else if (type === "spark") {
          particles.push({
            ...base,
            vx: rand(-2.8, 2.4),
            vy: rand(-5.8, -2.1),
            size: rand(0.7, 2.1),
            maxLife: rand(460, 1100),
            gravity: rand(0.012, 0.024),
          });
        } else {
          particles.push({
            ...base,
            vx: rand(-0.18, 0.28),
            vy: rand(-0.9, -0.28),
            size: rand(22, 58),
            maxLife: rand(2500, 5200),
          });
        }
      };

      const drawParticle = (p, time) => {
        const progress = p.life / p.maxLife;
        const fade = Math.max(0, 1 - progress);
        const wind = Math.sin(time * 0.00042) * 0.42;
        p.x += p.vx + Math.sin(time * p.drift + p.seed) * 0.42 + wind;
        p.y += p.vy + Math.cos(time * p.drift * 0.7 + p.seed) * 0.1;
        p.vx *= 0.989;
        p.vy *= p.type === "spark" ? 0.982 : 0.992;
        if (p.gravity) p.vy += p.gravity;

        if (p.type === "flame") {
          const r = p.size * (1 + progress * 2.2);
          const g = context.createRadialGradient(p.x, p.y, 0, p.x, p.y, r * 2.8);
          g.addColorStop(0, `rgba(255, 232, 176, ${fade * 0.44})`);
          g.addColorStop(0.2, `rgba(255, 160, 58, ${fade * 0.36})`);
          g.addColorStop(0.48, `rgba(214, ${Math.floor(58 + p.heat * 58)}, 20, ${fade * 0.22})`);
          g.addColorStop(1, "rgba(89, 20, 4, 0)");
          context.fillStyle = g;
          context.beginPath();
          context.ellipse(p.x, p.y, r * 1.25, r * 2.6, Math.sin(p.seed) * 0.45, 0, Math.PI * 2);
          context.fill();
        } else if (p.type === "ember") {
          const r = p.size * (1 + progress * 1.4);
          const g = context.createRadialGradient(p.x, p.y, 0, p.x, p.y, r * 5);
          g.addColorStop(0, `rgba(255, 236, 150, ${fade})`);
          g.addColorStop(0.36, `rgba(255, 116, 26, ${fade * 0.36})`);
          g.addColorStop(1, "rgba(255, 70, 10, 0)");
          context.fillStyle = g;
          context.beginPath();
          context.arc(p.x, p.y, r * 5, 0, Math.PI * 2);
          context.fill();
        } else if (p.type === "spark") {
          context.save();
          context.globalAlpha = fade;
          context.strokeStyle = "#fff0b4";
          context.shadowColor = "rgba(255, 155, 34, 0.85)";
          context.shadowBlur = 10;
          context.lineWidth = Math.max(1, p.size);
          context.beginPath();
          context.moveTo(p.x, p.y);
          context.lineTo(p.x - p.vx * 4, p.y - p.vy * 3);
          context.stroke();
          context.restore();
        } else {
          const r = p.size * (1 + progress * 1.9);
          const alpha = Math.pow(fade, 0.7) * 0.09;
          const g = context.createRadialGradient(p.x, p.y, 0, p.x, p.y, r);
          g.addColorStop(0, `rgba(176, 166, 148, ${alpha})`);
          g.addColorStop(1, "rgba(80, 72, 62, 0)");
          context.fillStyle = g;
          context.beginPath();
          context.arc(p.x, p.y, r, 0, Math.PI * 2);
          context.fill();
        }
      };

      const render = (time, animated = true) => {
        context.clearRect(0, 0, width, height);
        drawBoardBase(time);

        context.save();
        context.globalCompositeOperation = "lighter";

        if (animated) {
          const narrow = width < 430;
          for (let i = 0; i < (narrow ? 4 : 8); i += 1) emit("flame");
          for (let i = 0; i < (narrow ? 3 : 5); i += 1) emit("ember");
          if (Math.random() < (narrow ? 0.22 : 0.4)) emit("spark");
          if (Math.random() < (narrow ? 0.12 : 0.2)) emit("smoke");
        } else {
          for (let i = 0; i < 28; i += 1) emit(i % 4 === 0 ? "flame" : "ember");
        }

        for (let i = particles.length - 1; i >= 0; i -= 1) {
          const p = particles[i];
          p.life += animated ? Math.min(42, time - lastTime) : 24;
          if (p.life >= p.maxLife || p.y < -100 || p.x < -100 || p.x > width + 100) {
            particles.splice(i, 1);
          } else {
            drawParticle(p, time);
          }
        }

        while (particles.length > 760) particles.shift();
        context.restore();
      };

      const tick = (time) => {
        render(time, true);
        lastTime = time;
        frameId = window.requestAnimationFrame(tick);
      };

      const start = () => {
        window.cancelAnimationFrame(frameId);
        particles.length = 0;
        resize();
        lastTime = performance.now();
        if (reducedMotion.matches) {
          render(lastTime, false);
          return;
        }
        frameId = window.requestAnimationFrame(tick);
      };

      const observer = new ResizeObserver(start);
      observer.observe(root);
      reducedMotion.addEventListener("change", start);
      window.addEventListener("pagehide", () => window.cancelAnimationFrame(frameId), { once: true });
      start();
    });
  })();
</script>

<style>
  .burning-circuit {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    contain: layout paint size;
    filter: saturate(1.06) contrast(1.08);
    isolation: isolate;
  }

  .burning-circuit canvas,
  .circuit-vignette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .burning-circuit canvas {
    z-index: 2;
  }

  .circuit-vignette {
    z-index: 3;
    background:
      radial-gradient(ellipse at 61% 58%, transparent 0 44%, rgba(7, 6, 4, 0.56) 76%),
      linear-gradient(90deg, rgba(8, 7, 5, 0.12), transparent 30%, rgba(8, 7, 5, 0.2));
    mix-blend-mode: multiply;
  }

  .burning-circuit.is-hero {
    right: max(-11vw, -150px);
    bottom: -52px;
    width: min(58vw, 780px);
    height: min(78vh, 720px);
    min-height: 480px;
    opacity: 0.96;
    mask-image: radial-gradient(ellipse at 58% 56%, #000 0 64%, transparent 86%);
  }

  .burning-circuit.is-course {
    right: max(-10vw, -150px);
    top: -48px;
    width: min(56vw, 720px);
    height: min(58vh, 560px);
    min-height: 420px;
    opacity: 0.72;
    mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 84%, transparent 100%);
  }

  @media (max-width: 1040px) {
    .burning-circuit.is-hero {
      right: -24vw;
      width: 94vw;
      opacity: 0.5;
    }

    .burning-circuit.is-course {
      right: -24vw;
      width: 92vw;
      opacity: 0.38;
    }
  }

  @media (max-width: 720px) {
    .burning-circuit.is-hero {
      right: -52vw;
      bottom: -34px;
      width: 128vw;
      height: 500px;
      min-height: 400px;
      opacity: 0.38;
    }

    .burning-circuit.is-course {
      right: -58vw;
      top: 210px;
      width: 132vw;
      height: 430px;
      min-height: 360px;
      opacity: 0.2;
    }
  }
</style>
